{
    "name": "zikirmatik",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "cap:sync": "npm run build && npx cap sync",
        "cap:open:android": "npx cap open android",
        "cap:icons": "node scripts/ensure-icon-source.cjs && capacitor-assets generate --android --pwa --assetPath resources --iconBackgroundColor \"#0f2918\" --pwaManifestPath public/manifest.json && node scripts/patch-adaptive-icon.cjs",
        "test": "node --test lib/*.test.js quran-ref-search.test.js quran-ayah-text-search.test.js quotes.test.js",
        "translit:en:verify": "node scripts/verify-quran-translit-en.cjs",
        "translit:en:build": "node scripts/convert-quran-translit-en.cjs",
        "translit:en:build:tanzil": "node scripts/convert-quran-translit-en.cjs --tanzil",
        "quran:meal-search-index": "node scripts/build-quran-meal-search-index.cjs",
        "quran:ar-ayah-search-index": "node scripts/build-quran-ar-ayah-search-index.cjs",
        "quran:translit-search-index": "node scripts/build-quran-translit-search-index.cjs",
        "quran:search-index": "npm run quran:meal-search-index && npm run quran:ar-ayah-search-index && npm run quran:translit-search-index"
    },
    "dependencies": {
        "@capacitor-community/keep-awake": "^5.0.1",
        "@capacitor/android": "^6.1.3",
        "@capacitor/app": "^6.0.3",
        "@capacitor/core": "^6.1.3",
        "@capacitor/haptics": "^6.0.3",
        "@capacitor/local-notifications": "^6.1.3",
        "@capacitor/status-bar": "^6.0.3",
        "material-icons": "^1.13.14"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@capacitor/cli": "^6.1.3",
        "vite": "^6.0.3"
    }
}
