{
  "mealId": "indonesian",
  "n": 107,
  "ayahCount": 7,
  "ayahs": [
    {
      "n": 1,
      "tr": "Tahukah kamu (orang) yang mendustakan agama?"
    },
    {
      "n": 2,
      "tr": "Itulah orang yang menghardik anak yatim,"
    },
    {
      "n": 3,
      "tr": "dan tidak menganjurkan memberi makan orang miskin."
    },
    {
      "n": 4,
      "tr": "Maka kecelakaanlah bagi orang-orang yang shalat,"
    },
    {
      "n": 5,
      "tr": "(yaitu) orang-orang yang lalai dari shalatnya,"
    },
    {
      "n": 6,
      "tr": "orang-orang yang berbuat riya,"
    },
    {
      "n": 7,
      "tr": "dan enggan (menolong dengan) barang berguna."
    }
  ]
}
