{
  "mealId": "bn",
  "n": 107,
  "ayahCount": 7,
  "ayahs": [
    {
      "n": 1,
      "tr": "আপনি কি দেখেছেন তাকে, যে বিচারদিবসকে মিথ্যা বলে?"
    },
    {
      "n": 2,
      "tr": "সে সেই ব্যক্তি, যে এতীমকে গলা ধাক্কা দেয়"
    },
    {
      "n": 3,
      "tr": "এবং মিসকীনকে অন্ন দিতে উৎসাহিত করে না।"
    },
    {
      "n": 4,
      "tr": "অতএব দুর্ভোগ সেসব নামাযীর,"
    },
    {
      "n": 5,
      "tr": "যারা তাদের নামায সম্বন্ধে বে-খবর;"
    },
    {
      "n": 6,
      "tr": "যারা তা লোক-দেখানোর জন্য করে"
    },
    {
      "n": 7,
      "tr": "এবং নিত্য ব্যবহার্য্য বস্তু অন্যকে দেয় না।"
    }
  ]
}
