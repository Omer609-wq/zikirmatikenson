{
  "mealId": "bn",
  "n": 94,
  "ayahCount": 8,
  "ayahs": [
    {
      "n": 1,
      "tr": "আমি কি আপনার বক্ষ উম্মুক্ত করে দেইনি?"
    },
    {
      "n": 2,
      "tr": "আমি লাঘব করেছি আপনার বোঝা,"
    },
    {
      "n": 3,
      "tr": "যা ছিল আপনার জন্যে অতিশয় দুঃসহ।"
    },
    {
      "n": 4,
      "tr": "আমি আপনার আলোচনাকে সমুচ্চ করেছি।"
    },
    {
      "n": 5,
      "tr": "নিশ্চয় কষ্টের সাথে স্বস্তি রয়েছে।"
    },
    {
      "n": 6,
      "tr": "নিশ্চয় কষ্টের সাথে স্বস্তি রয়েছে।"
    },
    {
      "n": 7,
      "tr": "অতএব, যখন অবসর পান পরিশ্রম করুন।"
    },
    {
      "n": 8,
      "tr": "এবং আপনার পালনকর্তার প্রতি মনোনিবেশ করুন।"
    }
  ]
}
