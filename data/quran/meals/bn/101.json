{
  "mealId": "bn",
  "n": 101,
  "ayahCount": 11,
  "ayahs": [
    {
      "n": 1,
      "tr": "করাঘাতকারী,"
    },
    {
      "n": 2,
      "tr": "করাঘাতকারী কি?"
    },
    {
      "n": 3,
      "tr": "করাঘাতকারী সম্পর্কে আপনি কি জানেন ?"
    },
    {
      "n": 4,
      "tr": "যেদিন মানুষ হবে বিক্ষিপ্ত পতংগের মত"
    },
    {
      "n": 5,
      "tr": "এবং পর্বতমালা হবে ধুনিত রঙ্গীন পশমের মত।"
    },
    {
      "n": 6,
      "tr": "অতএব যার পাল্লা ভারী হবে,"
    },
    {
      "n": 7,
      "tr": "সে সুখীজীবন যাপন করবে।"
    },
    {
      "n": 8,
      "tr": "আর যার পাল্লা হালকা হবে,"
    },
    {
      "n": 9,
      "tr": "তার ঠিকানা হবে হাবিয়া।"
    },
    {
      "n": 10,
      "tr": "আপনি জানেন তা কি?"
    },
    {
      "n": 11,
      "tr": "প্রজ্জ্বলিত অগ্নি!"
    }
  ]
}
