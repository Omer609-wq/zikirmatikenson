{
  "mealId": "bn",
  "n": 104,
  "ayahCount": 9,
  "ayahs": [
    {
      "n": 1,
      "tr": "প্রত্যেক পশ্চাতে ও সম্মুখে পরনিন্দাকারীর দুর্ভোগ,"
    },
    {
      "n": 2,
      "tr": "যে অর্থ সঞ্চিত করে ও গণনা করে"
    },
    {
      "n": 3,
      "tr": "সে মনে করে যে, তার অর্থ চিরকাল তার সাথে থাকবে!"
    },
    {
      "n": 4,
      "tr": "কখনও না, সে অবশ্যই নিক্ষিপ্ত হবে পিষ্টকারীর মধ্যে।"
    },
    {
      "n": 5,
      "tr": "আপনি কি জানেন, পিষ্টকারী কি?"
    },
    {
      "n": 6,
      "tr": "এটা আল্লাহর প্রজ্জ্বলিত অগ্নি,"
    },
    {
      "n": 7,
      "tr": "যা হৃদয় পর্যন্ত পৌছবে।"
    },
    {
      "n": 8,
      "tr": "এতে তাদেরকে বেঁধে দেয়া হবে,"
    },
    {
      "n": 9,
      "tr": "লম্বা লম্বা খুঁটিতে।"
    }
  ]
}
