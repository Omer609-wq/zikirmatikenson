{
  "mealId": "bn",
  "n": 88,
  "ayahCount": 26,
  "ayahs": [
    {
      "n": 1,
      "tr": "আপনার কাছে আচ্ছন্নকারী কেয়ামতের বৃত্তান্ত পৌঁছেছে কি?"
    },
    {
      "n": 2,
      "tr": "অনেক মুখমন্ডল সেদিন হবে লাঞ্ছিত,"
    },
    {
      "n": 3,
      "tr": "ক্লিষ্ট, ক্লান্ত।"
    },
    {
      "n": 4,
      "tr": "তারা জ্বলন্ত আগুনে পতিত হবে।"
    },
    {
      "n": 5,
      "tr": "তাদেরকে ফুটন্ত নহর থেকে পান করানো হবে।"
    },
    {
      "n": 6,
      "tr": "কন্টকপূর্ণ ঝাড় ব্যতীত তাদের জন্যে কোন খাদ্য নেই।"
    },
    {
      "n": 7,
      "tr": "এটা তাদেরকে পুষ্ট করবে না এবং ক্ষুধায়ও উপকার করবে না।"
    },
    {
      "n": 8,
      "tr": "অনেক মুখমন্ডল সেদিন হবে, সজীব,"
    },
    {
      "n": 9,
      "tr": "তাদের কর্মের কারণে সন্তুষ্ট।"
    },
    {
      "n": 10,
      "tr": "তারা থাকবে, সুউচ্চ জান্নাতে।"
    },
    {
      "n": 11,
      "tr": "তথায় শুনবে না কোন অসার কথাবার্তা।"
    },
    {
      "n": 12,
      "tr": "তথায় থাকবে প্রবাহিত ঝরণা।"
    },
    {
      "n": 13,
      "tr": "তথায় থাকবে উন্নত সুসজ্জিত আসন।"
    },
    {
      "n": 14,
      "tr": "এবং সংরক্ষিত পানপাত্র"
    },
    {
      "n": 15,
      "tr": "এবং সারি সারি গালিচা"
    },
    {
      "n": 16,
      "tr": "এবং বিস্তৃত বিছানো কার্পেট।"
    },
    {
      "n": 17,
      "tr": "তারা কি উষ্ট্রের প্রতি লক্ষ্য করে না যে, তা কিভাবে সৃষ্টি করা হয়েছে?"
    },
    {
      "n": 18,
      "tr": "এবং আকাশের প্রতি লক্ষ্য করে না যে, তা কিভাবে উচ্চ করা হয়েছে?"
    },
    {
      "n": 19,
      "tr": "এবং পাহাড়ের দিকে যে, তা কিভাবে স্থাপন করা হয়েছে?"
    },
    {
      "n": 20,
      "tr": "এবং পৃথিবীর দিকে যে, তা কিভাবে সমতল বিছানো হয়েছে?"
    },
    {
      "n": 21,
      "tr": "অতএব, আপনি উপদেশ দিন, আপনি তো কেবল একজন উপদেশদাতা,"
    },
    {
      "n": 22,
      "tr": "আপনি তাদের শাসক নন,"
    },
    {
      "n": 23,
      "tr": "কিন্তু যে মুখ ফিরিয়ে নেয় ও কাফের হয়ে যায়,"
    },
    {
      "n": 24,
      "tr": "আল্লাহ তাকে মহা আযাব দেবেন।"
    },
    {
      "n": 25,
      "tr": "নিশ্চয় তাদের প্রত্যাবর্তন আমারই নিকট,"
    },
    {
      "n": 26,
      "tr": "অতঃপর তাদের হিসাব-নিকাশ আমারই দায়িত্ব।"
    }
  ]
}
