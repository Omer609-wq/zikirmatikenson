{
  "mealId": "bn",
  "n": 86,
  "ayahCount": 17,
  "ayahs": [
    {
      "n": 1,
      "tr": "শপথ আকাশের এবং রাত্রিতে আগমনকারীর।"
    },
    {
      "n": 2,
      "tr": "আপনি জানেন, যে রাত্রিতে আসে সেটা কি?"
    },
    {
      "n": 3,
      "tr": "সেটা এক উজ্জ্বল নক্ষত্র।"
    },
    {
      "n": 4,
      "tr": "প্রত্যেকের উপর একজন তত্ত্বাবধায়ক রয়েছে।"
    },
    {
      "n": 5,
      "tr": "অতএব, মানুষের দেখা উচিত কি বস্তু থেকে সে সৃজিত হয়েছে।"
    },
    {
      "n": 6,
      "tr": "সে সৃজিত হয়েছে সবেগে স্খলিত পানি থেকে।"
    },
    {
      "n": 7,
      "tr": "এটা নির্গত হয় মেরুদন্ড ও বক্ষপাজরের মধ্য থেকে।"
    },
    {
      "n": 8,
      "tr": "নিশ্চয় তিনি তাকে ফিরিয়ে নিতে সক্ষম।"
    },
    {
      "n": 9,
      "tr": "যেদিন গোপন বিষয়াদি পরীক্ষিত হবে,"
    },
    {
      "n": 10,
      "tr": "সেদিন তার কোন শক্তি থাকবে না এবং সাহায্যকারীও থাকবে না।"
    },
    {
      "n": 11,
      "tr": "শপথ চক্রশীল আকাশের"
    },
    {
      "n": 12,
      "tr": "এবং বিদারনশীল পৃথিবীর"
    },
    {
      "n": 13,
      "tr": "নিশ্চয় কোরআন সত্য-মিথ্যার ফয়সালা।"
    },
    {
      "n": 14,
      "tr": "এবং এটা উপহাস নয়।"
    },
    {
      "n": 15,
      "tr": "তারা ভীষণ চক্রান্ত করে,"
    },
    {
      "n": 16,
      "tr": "আর আমিও কৌশল করি।"
    },
    {
      "n": 17,
      "tr": "অতএব, কাফেরদেরকে অবকাশ দিন, তাদেরকে অবকাশ দিন, কিছু দিনের জন্যে।"
    }
  ]
}
