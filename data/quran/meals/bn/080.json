{
  "mealId": "bn",
  "n": 80,
  "ayahCount": 42,
  "ayahs": [
    {
      "n": 1,
      "tr": "তিনি ভ্রূকুঞ্চিত করলেন এবং মুখ ফিরিয়ে নিলেন।"
    },
    {
      "n": 2,
      "tr": "কারণ, তাঁর কাছে এক অন্ধ আগমন করল।"
    },
    {
      "n": 3,
      "tr": "আপনি কি জানেন, সে হয়তো পরিশুদ্ধ হত,"
    },
    {
      "n": 4,
      "tr": "অথবা উপদেশ গ্রহণ করতো এবং উপদেশ তার উপকার হত।"
    },
    {
      "n": 5,
      "tr": "পরন্তু যে বেপরোয়া,"
    },
    {
      "n": 6,
      "tr": "আপনি তার চিন্তায় মশগুল।"
    },
    {
      "n": 7,
      "tr": "সে শুদ্ধ না হলে আপনার কোন দোষ নেই।"
    },
    {
      "n": 8,
      "tr": "যে আপনার কাছে দৌড়ে আসলো"
    },
    {
      "n": 9,
      "tr": "এমতাবস্থায় যে, সে ভয় করে,"
    },
    {
      "n": 10,
      "tr": "আপনি তাকে অবজ্ঞা করলেন।"
    },
    {
      "n": 11,
      "tr": "কখনও এরূপ করবেন না, এটা উপদেশবানী।"
    },
    {
      "n": 12,
      "tr": "অতএব, যে ইচ্ছা করবে, সে একে গ্রহণ করবে।"
    },
    {
      "n": 13,
      "tr": "এটা লিখিত আছে সম্মানিত,"
    },
    {
      "n": 14,
      "tr": "উচ্চ পবিত্র পত্রসমূহে,"
    },
    {
      "n": 15,
      "tr": "লিপিকারের হস্তে,"
    },
    {
      "n": 16,
      "tr": "যারা মহৎ, পূত চরিত্র।"
    },
    {
      "n": 17,
      "tr": "মানুষ ধ্বংস হোক, সে কত অকৃতজ্ঞ!"
    },
    {
      "n": 18,
      "tr": "তিনি তাকে কি বস্তু থেকে সৃষ্টি করেছেন?"
    },
    {
      "n": 19,
      "tr": "শুক্র থেকে তাকে সৃষ্টি করেছেন, অতঃপর তাকে সুপরিমিত করেছেন।"
    },
    {
      "n": 20,
      "tr": "অতঃপর তার পথ সহজ করেছেন,"
    },
    {
      "n": 21,
      "tr": "অতঃপর তার মৃত্যু ঘটান ও কবরস্থ করেন তাকে।"
    },
    {
      "n": 22,
      "tr": "এরপর যখন ইচ্ছা করবেন তখন তাকে পুনরুজ্জীবিত করবেন।"
    },
    {
      "n": 23,
      "tr": "সে কখনও কৃতজ্ঞ হয়নি, তিনি তাকে যা আদেশ করেছেন, সে তা পূর্ণ করেনি।"
    },
    {
      "n": 24,
      "tr": "মানুষ তার খাদ্যের প্রতি লক্ষ্য করুক,"
    },
    {
      "n": 25,
      "tr": "আমি আশ্চর্য উপায়ে পানি বর্ষণ করেছি,"
    },
    {
      "n": 26,
      "tr": "এরপর আমি ভূমিকে বিদীর্ণ করেছি,"
    },
    {
      "n": 27,
      "tr": "অতঃপর তাতে উৎপন্ন করেছি শস্য,"
    },
    {
      "n": 28,
      "tr": "আঙ্গুর, শাক-সব্জি,"
    },
    {
      "n": 29,
      "tr": "যয়তুন, খর্জূর,"
    },
    {
      "n": 30,
      "tr": "ঘন উদ্যান,"
    },
    {
      "n": 31,
      "tr": "ফল এবং ঘাস"
    },
    {
      "n": 32,
      "tr": "তোমাদেরও তোমাদের চতুস্পদ জন্তুদের উপাকারার্থে।"
    },
    {
      "n": 33,
      "tr": "অতঃপর যেদিন কর্ণবিদারক নাদ আসবে,"
    },
    {
      "n": 34,
      "tr": "সেদিন পলায়ন করবে মানুষ তার ভ্রাতার কাছ থেকে,"
    },
    {
      "n": 35,
      "tr": "তার মাতা, তার পিতা,"
    },
    {
      "n": 36,
      "tr": "তার পত্নী ও তার সন্তানদের কাছ থেকে।"
    },
    {
      "n": 37,
      "tr": "সেদিন প্রত্যেকেরই নিজের এক চিন্তা থাকবে, যা তাকে ব্যতিব্যস্ত করে রাখবে।"
    },
    {
      "n": 38,
      "tr": "অনেক মুখমন্ডল সেদিন হবে উজ্জ্বল,"
    },
    {
      "n": 39,
      "tr": "সহাস্য ও প্রফুল্ল।"
    },
    {
      "n": 40,
      "tr": "এবং অনেক মুখমন্ডল সেদিন হবে ধুলি ধূসরিত।"
    },
    {
      "n": 41,
      "tr": "তাদেরকে কালিমা আচ্ছন্ন করে রাখবে।"
    },
    {
      "n": 42,
      "tr": "তারাই কাফের পাপিষ্ঠের দল।"
    }
  ]
}
