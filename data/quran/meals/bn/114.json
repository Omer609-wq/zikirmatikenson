{
  "mealId": "bn",
  "n": 114,
  "ayahCount": 6,
  "ayahs": [
    {
      "n": 1,
      "tr": "বলুন, আমি আশ্রয় গ্রহণ করিতেছি মানুষের পালনকর্তার,"
    },
    {
      "n": 2,
      "tr": "মানুষের অধিপতির,"
    },
    {
      "n": 3,
      "tr": "মানুষের মা’বুদের"
    },
    {
      "n": 4,
      "tr": "তার অনিষ্ট থেকে, যে কুমন্ত্রণা দেয় ও আত্নগোপন করে,"
    },
    {
      "n": 5,
      "tr": "যে কুমন্ত্রণা দেয় মানুষের অন্তরে"
    },
    {
      "n": 6,
      "tr": "জ্বিনের মধ্য থেকে অথবা মানুষের মধ্য থেকে।"
    }
  ]
}
