  "ayahs": [
    {
      "n": 1,
      "tr": "کہہ دو میں لوگوں کے رب کی پناہ میں آیا"
    },
    {
      "n": 2,
      "tr": "لوگوں کے بادشاہ کی"
    },
    {
      "n": 3,
      "tr": "لوگوں کے معبود کی"
    },
    {
      "n": 4,
      "tr": "اس شیطان کے شر سے جووسوسہ ڈال کر چھپ جاتا ہے"
    },
    {
      "n": 5,
      "tr": "جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے"
    },
    {
      "n": 6,
      "tr": "جنوں اور انسانوں میں سے"
    }
  ]
