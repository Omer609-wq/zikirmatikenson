{
  "mealId": "vakfi",
  "n": 80,
  "ayahCount": 42,
  "ayahs": [
    {
      "n": 1,
      "tr": "(Peygamber), yüzünü ekşitti ve geri döndü."
    },
    {
      "n": 2,
      "tr": "Âmanın kendisine gelmesinden ötürü"
    },
    {
      "n": 3,
      "tr": "Belki o temizlenecek,"
    },
    {
      "n": 4,
      "tr": "Yahut öğüt alacak da o öğüt ona fayda verecek."
    },
    {
      "n": 5,
      "tr": "Kendini (sana) muhtaç görmeyene gelince,"
    },
    {
      "n": 6,
      "tr": "Sen ona yöneliyorsun,"
    },
    {
      "n": 7,
      "tr": "Oysa ki onun temizlenip arınmasından sen sorumlu değilsin."
    },
    {
      "n": 8,
      "tr": "Fakat koşarak sana gelen,"
    },
    {
      "n": 9,
      "tr": "Ve (Allah'tan) korkarak gelenle,"
    },
    {
      "n": 10,
      "tr": "Sen onunla ilgilenmiyorsun."
    },
    {
      "n": 11,
      "tr": "Hayır! Şüphesiz bunlar bir öğüttür,"
    },
    {
      "n": 12,
      "tr": "Dileyen ondan (Kur'an'dan) öğüt alır,"
    },
    {
      "n": 13,
      "tr": "O, değerli sahifelerdir,"
    },
    {
      "n": 14,
      "tr": "Tertemiz kılınmış, yüce makamlara kaldırılmış mukaddes sahifelerde,"
    },
    {
      "n": 15,
      "tr": "Katiplerin ellerindedir,"
    },
    {
      "n": 16,
      "tr": "Değerli ve güvenilir katiplerin."
    },
    {
      "n": 17,
      "tr": "Kahrolası insan! Ne inkarcıdır!"
    },
    {
      "n": 18,
      "tr": "Allah onu neden yarattı?"
    },
    {
      "n": 19,
      "tr": "Bir nutfeden (spermadan) yarattı da ona şekil verdi."
    },
    {
      "n": 20,
      "tr": "Sonra ona yolu kolaylaştırdı."
    },
    {
      "n": 21,
      "tr": "Sonra onun canını aldı ve kabre soktu."
    },
    {
      "n": 22,
      "tr": "Sonra dilediği bir vakitte onu yeniden diriltir."
    },
    {
      "n": 23,
      "tr": "Hayır! (İnsan) Allah'ın emrettiğini yapmadı."
    },
    {
      "n": 24,
      "tr": "İnsan, yediğine bir baksın!"
    },
    {
      "n": 25,
      "tr": "Yağmurlar yağdırdık,"
    },
    {
      "n": 26,
      "tr": "Sonra toprağı göz göz yardık,"
    },
    {
      "n": 27,
      "tr": "Bu suretle orada ekinler bitirdik,"
    },
    {
      "n": 28,
      "tr": "Üzümler, yoncalar,"
    },
    {
      "n": 29,
      "tr": "Zeytinlikler, hurmalıklar,"
    },
    {
      "n": 30,
      "tr": "İri ve sık ağaçlı bahçeler,"
    },
    {
      "n": 31,
      "tr": "Meyveler ve çayırlar bitirdik."
    },
    {
      "n": 32,
      "tr": "(Bütün bunlar) sizi ve hayvanlarınızı yararlandırmak içindir."
    },
    {
      "n": 33,
      "tr": "Kulakları sağır eden o ses geldiğinde,"
    },
    {
      "n": 34,
      "tr": "İşte o gün kişi kardeşinden, kaçar."
    },
    {
      "n": 35,
      "tr": "Annesinden, babasından,"
    },
    {
      "n": 36,
      "tr": "Eşinden ve çocuklarından."
    },
    {
      "n": 37,
      "tr": "O gün, herkesin kendine yetip artacak bir derdi vardır."
    },
    {
      "n": 38,
      "tr": "O gün bir takım yüzler parıl parıl,"
    },
    {
      "n": 39,
      "tr": "Güler ve sevinir."
    },
    {
      "n": 40,
      "tr": "Yine o gün birtakım yüzleri de keder bürümüş,"
    },
    {
      "n": 41,
      "tr": "Hüzünden kapkara kesilmiştir."
    },
    {
      "n": 42,
      "tr": "İşte bunlar kafirlerdir, günahkarlardır."
    }
  ]
}
