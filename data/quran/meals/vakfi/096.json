{
  "mealId": "vakfi",
  "n": 96,
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "tr": "Yaratan Rabbinin adıyla oku!"
    },
    {
      "n": 2,
      "tr": "O, insanı bir aşılanmış yumurtadan yarattı."
    },
    {
      "n": 3,
      "tr": "Oku! Rabbin, en büyük kerem sahibidir."
    },
    {
      "n": 4,
      "tr": "O Rab ki kalemle (yazmayı) öğretti."
    },
    {
      "n": 5,
      "tr": "İnsana bilmedikleri şeyi öğretti."
    },
    {
      "n": 6,
      "tr": "Gerçek şu ki, insan azar."
    },
    {
      "n": 7,
      "tr": "Kendini kendine yeterli gördüğü için."
    },
    {
      "n": 8,
      "tr": "Kuşkusuz dönüş Rabbinedir."
    },
    {
      "n": 9,
      "tr": "Gördün mü şu men edeni,"
    },
    {
      "n": 10,
      "tr": "Namaz kılarken bir kulu (Peygamber'i namazdan)?"
    },
    {
      "n": 11,
      "tr": "Gördün mü, ya o (Peygamber) doğru yolda olur,"
    },
    {
      "n": 12,
      "tr": "Yahut takvayı emrediyorsa?"
    },
    {
      "n": 13,
      "tr": "Ne dersin o (meneden, Peygamber'i) yalanlıyor ve doğru yoldan yüz çeviriyorsa!"
    },
    {
      "n": 14,
      "tr": "(Bu adam) Allah'ın, (yaptıklarını) gördüğünü bilmez mi!"
    },
    {
      "n": 15,
      "tr": "Hayır, hayır! Eğer vazgeçmezse, derhal onu alnından (perçeminden), yakalarız (cehenneme atarız)."
    },
    {
      "n": 16,
      "tr": "O yalancı, günahkar alından (perçemden),"
    },
    {
      "n": 17,
      "tr": "O, hemen gidip meclisini (kendi taraftarlarını) çağırsın."
    },
    {
      "n": 18,
      "tr": "Biz de zebanileri çağıracağız."
    },
    {
      "n": 19,
      "tr": "Hayır! Ona uyma! Allah'a secde et ve (yalnızca O'na) yaklaş!"
    }
  ]
}
