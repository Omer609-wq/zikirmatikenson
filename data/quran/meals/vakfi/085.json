{
  "mealId": "vakfi",
  "n": 85,
  "ayahCount": 22,
  "ayahs": [
    {
      "n": 1,
      "tr": "Burçlara sahip gökyüzüne,"
    },
    {
      "n": 2,
      "tr": "Geleceği bildirilmiş olan güne,"
    },
    {
      "n": 3,
      "tr": "(O günde) tanıklık edene ve edilene andolsun ki,"
    },
    {
      "n": 4,
      "tr": "Kahroldu o hendeğin sahipleri,"
    },
    {
      "n": 5,
      "tr": "O çıralı ateşin,"
    },
    {
      "n": 6,
      "tr": "Onlar (yakanlar) da başlarına oturmuşlar,"
    },
    {
      "n": 7,
      "tr": "Müminlere yapmakta oldukları işkenceyi seyrediyorlardı."
    },
    {
      "n": 8,
      "tr": "Onlardan, sırf, aziz ve hamid olan Allah'a iman ettikleri için intikam aldılar."
    },
    {
      "n": 9,
      "tr": "O Allah ki, göklerin ve yerin mülkü kendisine aittir, ve Allah her şeye şahittir."
    },
    {
      "n": 10,
      "tr": "Şüphesiz inanmış erkeklerle inanmış kadınlara işkence edip sonra tevbe de etmeyenlere cehennem azabı ve (orada) yanma cezası vardır."
    },
    {
      "n": 11,
      "tr": "İman edip salih ameller işleyenlere ise, zemininden ırmaklar akan cennetler vardır. İşte büyük kurtuluş budur."
    },
    {
      "n": 12,
      "tr": "Şüphesiz Rabbinin yakalaması çok şiddetlidir."
    },
    {
      "n": 13,
      "tr": "Bilin ki O, (kainat yokken) ilk olarak yaratan, (ölümden sonra tekrar hayatı) geri getirendir."
    },
    {
      "n": 14,
      "tr": "O, çok bağışlayan ve çok sevendir."
    },
    {
      "n": 15,
      "tr": "Şerefli Arş'ın sahibidir."
    },
    {
      "n": 16,
      "tr": "Dilediği şeyleri mutlaka yapandır."
    },
    {
      "n": 17,
      "tr": "Orduların, haberi sana geldi mi?"
    },
    {
      "n": 18,
      "tr": "Yani Firavun ve Semud'un"
    },
    {
      "n": 19,
      "tr": "Doğrusu inkarcılar (gerçeği) yalanlayıp dururlar."
    },
    {
      "n": 20,
      "tr": "Allah onları arkalarından kuşatmıştır."
    },
    {
      "n": 21,
      "tr": "Hayır o şerefli bir Kur'an'dır."
    },
    {
      "n": 22,
      "tr": "Levh-i Mahfuz'dadır."
    }
  ]
}
