{
  "mealId": "vakfi",
  "n": 84,
  "ayahCount": 25,
  "ayahs": [
    {
      "n": 1,
      "tr": "Gök yarıldığı,"
    },
    {
      "n": 2,
      "tr": "Rabbine kulak verip boyun eğecek hale getirildiği zaman,"
    },
    {
      "n": 3,
      "tr": "Yer dümdüz edildiği,"
    },
    {
      "n": 4,
      "tr": "İçinde bulunanları atıp boşaldığı,"
    },
    {
      "n": 5,
      "tr": "Ve Rabb'ini dinleyip O'na hakkıyla itaata mecbur kılındığı vakit (insanoğlu yaptıkları ile karşılaşır)."
    },
    {
      "n": 6,
      "tr": "Ey insan! Şüphe yok ki sen Rabbine karşı çaba üstüne çaba göstermektesin; sonunda O'na varacaksın."
    },
    {
      "n": 7,
      "tr": "Kimin kitabı sağından verilirse,"
    },
    {
      "n": 8,
      "tr": "Kolay bir hesapla hesaba çekilecek;"
    },
    {
      "n": 9,
      "tr": "Ve sevinçli olarak ailesine dönecektir."
    },
    {
      "n": 10,
      "tr": "Kimin de kitabı arkasından verilirse,"
    },
    {
      "n": 11,
      "tr": "Derhal yok olmayı isteyecek,"
    },
    {
      "n": 12,
      "tr": "Ve alevli ateşe girecektir."
    },
    {
      "n": 13,
      "tr": "Zira o, (dünyada) ailesi içinde (mal-mülk sebebiyle) şımarmıştı."
    },
    {
      "n": 14,
      "tr": "O hiçbir zaman Rabbine dönmeyeceğini sandı."
    },
    {
      "n": 15,
      "tr": "Oysa gerçekten Rabbi onu görüyordu."
    },
    {
      "n": 16,
      "tr": "Hayır! Şafağa, yemin ederim ki,"
    },
    {
      "n": 17,
      "tr": "Geceye ve onda basan karanlığa,"
    },
    {
      "n": 18,
      "tr": "Dolunay olmuş aya,"
    },
    {
      "n": 19,
      "tr": "Ki, siz elbette halden hale geçeceksiniz."
    },
    {
      "n": 20,
      "tr": "Böyleyken onlar acaba neden iman etmezler?"
    },
    {
      "n": 21,
      "tr": "Onlar kendilerine Kur'an okununca secde de etmezler."
    },
    {
      "n": 22,
      "tr": "Aksine, kafirler yalanlıyorlar."
    },
    {
      "n": 23,
      "tr": "Halbuki Allah onların gizlediği şeyleri çok iyi bilir."
    },
    {
      "n": 24,
      "tr": "(Resulüm!) Onlara acı azabı müjdele!"
    },
    {
      "n": 25,
      "tr": "İman edip salih amel işleyenler başkadır; onlar için arkası kesilmeyen bir mükafat vardır."
    }
  ]
}
