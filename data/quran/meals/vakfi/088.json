{
  "mealId": "vakfi",
  "n": 88,
  "ayahCount": 26,
  "ayahs": [
    {
      "n": 1,
      "tr": "(Resulüm!) Dehşeti her şeyi kaplayan kıyametin haberi sana geldi mi?"
    },
    {
      "n": 2,
      "tr": "O gün bir takım yüzler zelildir,"
    },
    {
      "n": 3,
      "tr": "Durmadan çalışır, (fakat boşuna) yorulur,"
    },
    {
      "n": 4,
      "tr": "Kızgın ateşe girer."
    },
    {
      "n": 5,
      "tr": "Onlara kaynar su pınarından içirilir."
    },
    {
      "n": 6,
      "tr": "Onlar için kuru dikenden başka yemek yoktur,"
    },
    {
      "n": 7,
      "tr": "O ise ne besler ne de açlığı giderir."
    },
    {
      "n": 8,
      "tr": "O gün bir takım yüzler de vardır ki, mutludurlar,"
    },
    {
      "n": 9,
      "tr": "(dünyadaki) çabalarından hoşnut olmuşlardır,"
    },
    {
      "n": 10,
      "tr": "Yüce bir cennettedirler."
    },
    {
      "n": 11,
      "tr": "Orada boş bir söz işitmezler."
    },
    {
      "n": 12,
      "tr": "Orada (cennette) devamlı akan bir pınar,"
    },
    {
      "n": 13,
      "tr": "Yükseltilmiş tahtlar,"
    },
    {
      "n": 14,
      "tr": "Konulmuş kadehler,"
    },
    {
      "n": 15,
      "tr": "Sıra sıra dizilmiş yastıklar,"
    },
    {
      "n": 16,
      "tr": "Serilmiş halılar vardır."
    },
    {
      "n": 17,
      "tr": "(İnsanlar) devenin nasıl yaratıldığına, bakmazlar mı?"
    },
    {
      "n": 18,
      "tr": "Göğe bakmıyorlar mı nasıl yükseltilmiş?"
    },
    {
      "n": 19,
      "tr": "Dağların nasıl dikildiğine, bakmazlar mı?"
    },
    {
      "n": 20,
      "tr": "Yeryüzünün nasıl yayıldığına bir bakmazlar mı?"
    },
    {
      "n": 21,
      "tr": "O halde (Resulüm), öğüt ver. Çünkü sen ancak öğüt vericisin."
    },
    {
      "n": 22,
      "tr": "Onların üzerinde bir zorba değilsin."
    },
    {
      "n": 23,
      "tr": "Ancak yüz çevirir inkar ederse,"
    },
    {
      "n": 24,
      "tr": "İşte öylesini Allah en büyük azap ile cezalandırır."
    },
    {
      "n": 25,
      "tr": "Şüphesiz onların dönüşü sadece bizedir."
    },
    {
      "n": 26,
      "tr": "Sonra onların sorguya çekilmesi de sadece bize aittir."
    }
  ]
}
