{
  "mealId": "vakfi",
  "n": 81,
  "ayahCount": 29,
  "ayahs": [
    {
      "n": 1,
      "tr": "Güneş katlanıp dürüldüğünde,"
    },
    {
      "n": 2,
      "tr": "Yıldızlar (kararıp) döküldüğünde,"
    },
    {
      "n": 3,
      "tr": "Dağlar (sallanıp) yürütüldüğünde,"
    },
    {
      "n": 4,
      "tr": "Gebe develer salıverildiğinde,"
    },
    {
      "n": 5,
      "tr": "Vahşi hayvanlar toplanıp bir araya getirildiğinde,"
    },
    {
      "n": 6,
      "tr": "Denizler kaynatıldığında,"
    },
    {
      "n": 7,
      "tr": "Ruhlar (bedenlerle) birleştirildiğinde,"
    },
    {
      "n": 8,
      "tr": "Diri diri toprağa gömülen kıza, sorulduğunda,"
    },
    {
      "n": 9,
      "tr": "\"Hangi günah sebebiyle öldürüldü? diye."
    },
    {
      "n": 10,
      "tr": "(Amellerin yazılı olduğu) defterler açıldığında,"
    },
    {
      "n": 11,
      "tr": "Gökyüzü sıyrılıp alındığında,"
    },
    {
      "n": 12,
      "tr": "Cehennem tutuşturulduğunda,"
    },
    {
      "n": 13,
      "tr": "Ve cennet yaklaştırıldığında,"
    },
    {
      "n": 14,
      "tr": "Kişi neler getirdiğini öğrenmiş olacaktır."
    },
    {
      "n": 15,
      "tr": "Şimdi yemin ederim o sinenlere,"
    },
    {
      "n": 16,
      "tr": "O akıp akıp yuvasına gidenlere,"
    },
    {
      "n": 17,
      "tr": "Kararmaya yüz tuttuğunda geceye andolsun,"
    },
    {
      "n": 18,
      "tr": "Ağarmaya başladığında sabaha andolsun ki,"
    },
    {
      "n": 19,
      "tr": "O (Kur'an), şüphesiz değerli, bir elçinin (Cebrail'in) getirdiği sözdür."
    },
    {
      "n": 20,
      "tr": "O elçi güçlü, Arş'ın sahibi (Allah'ın) katında çok itibarlıdır."
    },
    {
      "n": 21,
      "tr": "O orada sayılan, güvenilen (bir elçi) dir."
    },
    {
      "n": 22,
      "tr": "Arkadaşınız (Muhammed) de mecnun değildir."
    },
    {
      "n": 23,
      "tr": "Andolsun ki, onu (Cebrail'i) apaçık ufukta görmüştür."
    },
    {
      "n": 24,
      "tr": "O, gaybın bilgilerini (sizden) esirgemez."
    },
    {
      "n": 25,
      "tr": "O lanetlenmiş şeytanın sözü de değildir."
    },
    {
      "n": 26,
      "tr": "Hal böyle iken nereye gidiyorsunuz?"
    },
    {
      "n": 27,
      "tr": "O, herkes için, bir öğüttür,"
    },
    {
      "n": 28,
      "tr": "Sizden doğru yolda gitmek isteyenler için de."
    },
    {
      "n": 29,
      "tr": "Alemlerin Rabbi Allah dilemedikçe siz dileyemezsiniz."
    }
  ]
}
