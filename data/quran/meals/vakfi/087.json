{
  "mealId": "vakfi",
  "n": 87,
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "tr": "Yüce Rabbinin adını,"
    },
    {
      "n": 2,
      "tr": "Yaratıp düzene koyan,"
    },
    {
      "n": 3,
      "tr": "Takdir edip yol gösteren,"
    },
    {
      "n": 4,
      "tr": "(Topraktan) yeşil otu çıkaran,"
    },
    {
      "n": 5,
      "tr": "Sonra da onu kapkara bir sel artığına çeviren yüce Rabbinin adını tesbih (ve takdis) et."
    },
    {
      "n": 6,
      "tr": "Sana (Kur an'ı) okutacağız; sen hiç unutmayacaksın."
    },
    {
      "n": 7,
      "tr": "Artık Allah'ın dilediği hariç, Şüphesiz Allah, açığı ve gizleneni bilir."
    },
    {
      "n": 8,
      "tr": "Seni en kolaya muvaffak kılacağız."
    },
    {
      "n": 9,
      "tr": "O halde eğer öğüt fayda verirse öğüt ver."
    },
    {
      "n": 10,
      "tr": "(Allah'tan) korkan öğütten yararlanacak."
    },
    {
      "n": 11,
      "tr": "Kötü kimse ise öğütten kaçınacaktır."
    },
    {
      "n": 12,
      "tr": "O ki, en büyük ateşe girecektir."
    },
    {
      "n": 13,
      "tr": "Sonra o, ateşte ne ölür ne de yaşar."
    },
    {
      "n": 14,
      "tr": "Doğrusu feraha ermiştir temizlenen,"
    },
    {
      "n": 15,
      "tr": "Rabbinin adını anıp O'na kulluk eden."
    },
    {
      "n": 16,
      "tr": "Fakat siz (ey insanlar! ) dünya hayatını tercih ediyorsunuz."
    },
    {
      "n": 17,
      "tr": "Oysa ahiret daha hayırlı daha devamlıdır."
    },
    {
      "n": 18,
      "tr": "Şüphesiz bu (anlatılanlar), önceki kitaplarda, vardır."
    },
    {
      "n": 19,
      "tr": "İbrahim ve Musa'nın kitaplarında."
    }
  ]
}
