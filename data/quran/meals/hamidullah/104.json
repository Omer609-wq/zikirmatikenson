{
  "mealId": "hamidullah",
  "n": 104,
  "ayahCount": 9,
  "ayahs": [
    {
      "n": 1,
      "tr": "Malheur à tout calomniateur diffamateur,"
    },
    {
      "n": 2,
      "tr": "qui amasse une fortune et la compte,"
    },
    {
      "n": 3,
      "tr": "pensant que sa fortune l'immortalisera."
    },
    {
      "n": 4,
      "tr": "Mais non! Il sera certes, jeté dans la Hutamah."
    },
    {
      "n": 5,
      "tr": "Et qui te dira ce qu'est la Hutamah?"
    },
    {
      "n": 6,
      "tr": "Le Feu attisé d'Allah"
    },
    {
      "n": 7,
      "tr": "qui monte jusqu'aux cœurs."
    },
    {
      "n": 8,
      "tr": "Il se refermera sur eux,"
    },
    {
      "n": 9,
      "tr": "en colonnes (de flammes) étendues."
    }
  ]
}
