{
  "translitId": "translit-tr",
  "n": 84,
  "ayahCount": 25,
  "ayahs": [
    {
      "n": 1,
      "lat": "İẕe-ssemâü-nşeḳḳat"
    },
    {
      "n": 2,
      "lat": "Veeẕinet lirabbihâ veḥuḳḳat"
    },
    {
      "n": 3,
      "lat": "Veiẕe-l'arḍu müddet"
    },
    {
      "n": 4,
      "lat": "Veelḳat mâ fîhâ veteḫallet"
    },
    {
      "n": 5,
      "lat": "Veeẕinet lirabbihâ veḥuḳḳat"
    },
    {
      "n": 6,
      "lat": "Yâ eyyühe-l'insânü inneke kâdiḥun ilâ rabbike kedḥan femülâḳîh"
    },
    {
      "n": 7,
      "lat": "Feemmâ men ûtiye kitâbehû biyemînih"
    },
    {
      "n": 8,
      "lat": "Fesevfe yüḥâsebü ḥisâbey yesîrâ"
    },
    {
      "n": 9,
      "lat": "Veyenḳalibü ilâ ehlihî mesrûrâ"
    },
    {
      "n": 10,
      "lat": "Veemmâ men ûtiye kitâbehû verâe żahrih"
    },
    {
      "n": 11,
      "lat": "Fesevfe yed`û ŝübûrâ"
    },
    {
      "n": 12,
      "lat": "Veyaṣlâ se`îrâ"
    },
    {
      "n": 13,
      "lat": "İnnehû kâne fî ehlihî mesrûrâ"
    },
    {
      "n": 14,
      "lat": "İnnehû żanne el ley yeḥûr"
    },
    {
      "n": 15,
      "lat": "Belâ. İnne rabbehû kâne bihî beṣîrâ"
    },
    {
      "n": 16,
      "lat": "Felâ uḳsimü bişşefeḳ"
    },
    {
      "n": 17,
      "lat": "Velleyli vemâ veseḳa"
    },
    {
      "n": 18,
      "lat": "Velḳameri iẕe-tteseḳa"
    },
    {
      "n": 19,
      "lat": "Leterkebünne ṭabeḳan `an ṭabaḳ"
    },
    {
      "n": 20,
      "lat": "Femâ lehüm lâ yü'minûn"
    },
    {
      "n": 21,
      "lat": "Veiẕâ ḳurie `aleyhimü-lḳur'ânü lâ yescüdûn"
    },
    {
      "n": 22,
      "lat": "Beli-lleẕîne keferû yükeẕẕibûn"
    },
    {
      "n": 23,
      "lat": "Vellâhü a`lemü bimâ yû`ûn"
    },
    {
      "n": 24,
      "lat": "Febeşşirhüm bi`aẕâbin elîm"
    },
    {
      "n": 25,
      "lat": "İlle-lleẕîne âmenû ve`amilu-ṣṣâliḥâti lehüm ecrun gayru memnûn"
    }
  ]
}
