  "ayahs": [
    {
      "n": 1,
      "lat": "Velleyli iẕâ yagşâ"
    },
    {
      "n": 2,
      "lat": "Vennehâri iẕâ tecellâ"
    },
    {
      "n": 3,
      "lat": "Vemâ ḫaleḳa-ẕẕekera vel'ünŝâ"
    },
    {
      "n": 4,
      "lat": "İnne sa`yeküm leşettâ"
    },
    {
      "n": 5,
      "lat": "Feemmâ men a`ṭâ vetteḳâ"
    },
    {
      "n": 6,
      "lat": "Veṣaddeḳa bilḥusnâ"
    },
    {
      "n": 7,
      "lat": "Fesenüyessiruhû lilyüsrâ"
    },
    {
      "n": 8,
      "lat": "Veemmâ mem beḫile vestagnâ"
    },
    {
      "n": 9,
      "lat": "Vekeẕẕebe bilḥusnâ"
    },
    {
      "n": 10,
      "lat": "Fesenüyessiruhû lil`usrâ"
    },
    {
      "n": 11,
      "lat": "Vemâ yugnî `anhü mâlühû iẕâ teraddâ"
    },
    {
      "n": 12,
      "lat": "İnne `aleynâ lelhüdâ"
    },
    {
      "n": 13,
      "lat": "Veinne lenâ lel'âḫirate vel'ûlâ"
    },
    {
      "n": 14,
      "lat": "Feenẕertüküm nâran teleżżâ"
    },
    {
      "n": 15,
      "lat": "Lâ yaṣlâhâ ille-l'eşḳâ"
    },
    {
      "n": 16,
      "lat": "Elleẕî keẕẕebe vetevellâ"
    },
    {
      "n": 17,
      "lat": "Veseyücennebühe-l'etḳâ"
    },
    {
      "n": 18,
      "lat": "Elleẕî yü'tî mâlehû yetezekkâ"
    },
    {
      "n": 19,
      "lat": "Vemâ lieḥadin `indehû min ni`metin tüczâ"
    },
    {
      "n": 20,
      "lat": "İlle-btigâe vechi rabbihi-l'a`lâ"
