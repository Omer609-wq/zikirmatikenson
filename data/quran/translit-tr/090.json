{
  "translitId": "translit-tr",
  "n": 90,
  "ayahCount": 20,
  "ayahs": [
    {
      "n": 1,
      "lat": "Lâ uḳsimü bihâẕe-lbeled"
    },
    {
      "n": 2,
      "lat": "Veente ḥillüm bihâẕe-lbeled"
    },
    {
      "n": 3,
      "lat": "Vevâlidiv vemâ veled"
    },
    {
      "n": 4,
      "lat": "Leḳad ḫalaḳne-l'insâne fî kebed"
    },
    {
      "n": 5,
      "lat": "Eyaḥsebü el ley yaḳdira `aleyhi eḥad"
    },
    {
      "n": 6,
      "lat": "Yeḳûlü ehlektü mâlel lübedâ"
    },
    {
      "n": 7,
      "lat": "Eyaḥsebü el lem yerahû eḥad"
    },
    {
      "n": 8,
      "lat": "Elem nec`al lehû `ayneyn"
    },
    {
      "n": 9,
      "lat": "Velisânev veşefeteyn"
    },
    {
      "n": 10,
      "lat": "Vehedeynâhü-nnecdeyn"
    },
    {
      "n": 11,
      "lat": "Fele-ḳteḥame-l`aḳabeh"
    },
    {
      "n": 12,
      "lat": "Vemâ edrâke me-l`aḳabeh"
    },
    {
      "n": 13,
      "lat": "Fekkü raḳabeh"
    },
    {
      "n": 14,
      "lat": "Ev iṭ`âmün fî yevmin ẕî mesgabeh"
    },
    {
      "n": 15,
      "lat": "Yetîmen ẕâ maḳrabeh"
    },
    {
      "n": 16,
      "lat": "Ev miskînen ẕâ metrabeh"
    },
    {
      "n": 17,
      "lat": "Ŝümme kâne mine-lleẕîne âmenû vetevâṣav biṣṣabri vetevâṣav bilmerḥameh"
    },
    {
      "n": 18,
      "lat": "Ülâike aṣḥâbü-lmeymeneh"
    },
    {
      "n": 19,
      "lat": "Velleẕîne keferû biâyâtinâ hüm aṣḥâbü-lmeş'emeh"
    },
    {
      "n": 20,
      "lat": "Aleyhim nârum mü'ṣadeh"
    }
  ]
}
