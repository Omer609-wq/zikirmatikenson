  "ayahs": [
    {
      "n": 1,
      "lat": "Veşşemsi veḍuḥâhâ"
    },
    {
      "n": 2,
      "lat": "Velḳameri iẕâ telâhâ"
    },
    {
      "n": 3,
      "lat": "Vennehâri iẕâ cellâhâ"
    },
    {
      "n": 4,
      "lat": "Velleyli iẕâ yagşâhâ"
    },
    {
      "n": 5,
      "lat": "Vessemâi vemâ benâhâ"
    },
    {
      "n": 6,
      "lat": "Vel'arḍi vemâ ṭaḥâhâ"
    },
    {
      "n": 7,
      "lat": "Venefsiv vemâ sevvâhâ"
    },
    {
      "n": 8,
      "lat": "Feelhemehâ fücûrahâ vetaḳvâhâ"
    },
    {
      "n": 9,
      "lat": "Ḳad efleḥa men zekkâhâ"
    },
    {
      "n": 10,
      "lat": "Veḳad ḫâbe men dessâhâ"
    },
    {
      "n": 11,
      "lat": "Keẕẕebet ŝemûdü biṭagvâhâ"
    },
    {
      "n": 12,
      "lat": "İẕi-mbe`aŝe eşḳâhâ"
    },
    {
      "n": 13,
      "lat": "Feḳâle lehüm rasûlü-llâhi nâḳate-llâhi vesuḳyâhâ"
    },
    {
      "n": 14,
      "lat": "Fekeẕẕebûhü fe`aḳarûhâ. Fedemdeme `aleyhim rabbühüm biẕembihim fesevvâhâ"
    },
    {
      "n": 15,
      "lat": "Velâ yeḫâfü `uḳbâhâ"
    }
  ]
