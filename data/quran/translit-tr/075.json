{
  "translitId": "translit-tr",
  "n": 75,
  "ayahCount": 40,
  "ayahs": [
    {
      "n": 1,
      "lat": "Lâ uḳsimü biyevmi-lḳiyâmeh"
    },
    {
      "n": 2,
      "lat": "Velâ uḳsimü binnefsi-llevvâmeh"
    },
    {
      "n": 3,
      "lat": "Eyaḥsebü-l'insânü ellen necme`a `iżâmeh"
    },
    {
      "n": 4,
      "lat": "Belâ ḳâdirîne `alâ en nüsevviye benâneh"
    },
    {
      "n": 5,
      "lat": "Bel yürîdü-l'insânü liyefcüra emâmeh"
    },
    {
      "n": 6,
      "lat": "Yes'elü eyyâne yevmü-lḳiyâmeh"
    },
    {
      "n": 7,
      "lat": "Feiẕâ beriḳa-lbeṣar"
    },
    {
      "n": 8,
      "lat": "Veḫasefe-lḳamer"
    },
    {
      "n": 9,
      "lat": "Vecümi`a-şşemsü velḳamer"
    },
    {
      "n": 10,
      "lat": "Yeḳûlü-l'insânü yevmeiẕin eyne-lmeferr"
    },
    {
      "n": 11,
      "lat": "Kellâ lâ vezer"
    },
    {
      "n": 12,
      "lat": "İlâ rabbike yevmeiẕin-lmüsteḳarr"
    },
    {
      "n": 13,
      "lat": "Yünebbeü-l'insânü yevmeiẕim bimâ ḳaddeme veeḫḫar"
    },
    {
      "n": 14,
      "lat": "Beli-l'insânü `alâ nefsihî beṣîrah"
    },
    {
      "n": 15,
      "lat": "Velev elḳâ me`âẕîrah"
    },
    {
      "n": 16,
      "lat": "Lâ tüḥarrik bihî lisâneke lita`cele bih"
    },
    {
      "n": 17,
      "lat": "İnne `aleynâ cem`ahû veḳur'âneh"
    },
    {
      "n": 18,
      "lat": "Feiẕâ ḳara'nâhü fettebi` ḳur'âneh"
    },
    {
      "n": 19,
      "lat": "Ŝümme inne `aleynâ beyâneh"
    },
    {
      "n": 20,
      "lat": "Kellâ bel tüḥibbûne-l`âcileh"
    },
    {
      "n": 21,
      "lat": "Veteẕerûne-l'âḫirah"
    },
    {
      "n": 22,
      "lat": "Vucûhüy yevmeiẕin nâḍirah"
    },
    {
      "n": 23,
      "lat": "İlâ rabbihâ nâżirah"
    },
    {
      "n": 24,
      "lat": "Vevucûhüy yevmeiẕim bâsirah"
    },
    {
      "n": 25,
      "lat": "Teżunnü ey yüf`ale bihâ fâḳirah"
    },
    {
      "n": 26,
      "lat": "Kellâ iẕâ belegati-tterâḳiy"
    },
    {
      "n": 27,
      "lat": "Veḳîle men râḳ"
    },
    {
      "n": 28,
      "lat": "Veżanne ennehü-lfirâḳ"
    },
    {
      "n": 29,
      "lat": "Velteffeti-ssâḳu bissâḳ"
    },
    {
      "n": 30,
      "lat": "İlâ rabbike yevmeiẕin-lmesâḳ"
    },
    {
      "n": 31,
      "lat": "Felâ ṣaddeḳa velâ ṣallâ"
    },
    {
      "n": 32,
      "lat": "Velâkin keẕẕebe vetevellâ"
    },
    {
      "n": 33,
      "lat": "Ŝümme ẕehebe ilâ ehlihî yetemeṭṭâ"
    },
    {
      "n": 34,
      "lat": "Evlâ leke feevlâ"
    },
    {
      "n": 35,
      "lat": "Ŝümme evlâ leke feevlâ"
    },
    {
      "n": 36,
      "lat": "Eyaḥsebü-l'insânü ey yütrake südâ"
    },
    {
      "n": 37,
      "lat": "Elem yekü nuṭfetem mim meniyyiy yümnâ"
    },
    {
      "n": 38,
      "lat": "Ŝümme kâne `aleḳaten feḫaleḳa fesevvâ"
    },
    {
      "n": 39,
      "lat": "Fece`ale minhü-zzevceyni-ẕẕekera vel'ünŝâ"
    },
    {
      "n": 40,
      "lat": "Eleyse ẕâlike biḳâdirin `alâ ey yuḥyiye-lmevtâ"
    }
  ]
}
