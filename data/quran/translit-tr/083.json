{
  "translitId": "translit-tr",
  "n": 83,
  "ayahCount": 36,
  "ayahs": [
    {
      "n": 1,
      "lat": "Veylül lilmüṭaffifîn"
    },
    {
      "n": 2,
      "lat": "Elleẕîne iẕe-ktâlû `ale-nnâsi yestevfûn"
    },
    {
      "n": 3,
      "lat": "Veiẕâ kâlûhüm ev vezenûhüm yuḫsirûn"
    },
    {
      "n": 4,
      "lat": "Elâ yeżunnü ülâike ennehüm meb`ûŝûn"
    },
    {
      "n": 5,
      "lat": "Liyevmin `ażîm"
    },
    {
      "n": 6,
      "lat": "Yevme yeḳûmü-nnâsü lirabbi-l`âlemîn"
    },
    {
      "n": 7,
      "lat": "Kellâ inne kitâbe-lfüccâri lefî siccîn"
    },
    {
      "n": 8,
      "lat": "Vemâ edrâke mâ siccîn"
    },
    {
      "n": 9,
      "lat": "Kitâbüm merḳûm"
    },
    {
      "n": 10,
      "lat": "Veylüy yevmeiẕil lilmükeẕẕibîn"
    },
    {
      "n": 11,
      "lat": "Elleẕîne yükeẕẕibûne biyevmi-ddîn"
    },
    {
      "n": 12,
      "lat": "Vemâ yükeẕẕibü bihî illâ küllü mü`tedin eŝîm"
    },
    {
      "n": 13,
      "lat": "İẕâ tütlâ `aleyhi âyâtünâ ḳâle esâṭîru-l'evvelîn"
    },
    {
      "n": 14,
      "lat": "Kellâ bel râne `alâ ḳulûbihim mâ kânû yeksibûn"
    },
    {
      "n": 15,
      "lat": "Kellâ innehüm `ar rabbihim yevmeiẕil lemaḥcûbûn"
    },
    {
      "n": 16,
      "lat": "Ŝümme innehüm leṣâlü-lceḥîm"
    },
    {
      "n": 17,
      "lat": "Ŝümme yüḳâlü hâẕe-lleẕî küntüm bihî tükeẕẕibûn"
    },
    {
      "n": 18,
      "lat": "Kellâ inne kitâbe-l'ebrâri lefî `illiyyîn"
    },
    {
      "n": 19,
      "lat": "Vemâ edrâke mâ `illiyyûn"
    },
    {
      "n": 20,
      "lat": "Kitâbüm merḳûm"
    },
    {
      "n": 21,
      "lat": "Yeşhedühü-lmüḳarrabûn"
    },
    {
      "n": 22,
      "lat": "İnne-l'ebrâra lefî ne`îm"
    },
    {
      "n": 23,
      "lat": "Ale-l'erâiki yenżurûn"
    },
    {
      "n": 24,
      "lat": "Ta`rifü fî vucûhihim naḍrate-nne`îm"
    },
    {
      "n": 25,
      "lat": "Yüsḳavne mir raḥîḳim maḫtûm"
    },
    {
      "n": 26,
      "lat": "Ḫitâmühû misk. Vefî ẕâlike felyetenâfesi-lmütenâfisûn"
    },
    {
      "n": 27,
      "lat": "Vemizâcühû min tesnîm"
    },
    {
      "n": 28,
      "lat": "Ayney yeşrabü bihe-lmüḳarrabûn"
    },
    {
      "n": 29,
      "lat": "İnne-lleẕîne ecramû kânû mine-lleẕîne âmenû yaḍḥakûn"
    },
    {
      "n": 30,
      "lat": "Veiẕâ merrû bihim yetegâmezûn"
    },
    {
      "n": 31,
      "lat": "Veiẕe-nḳalebû ilâ ehlihimü-nḳalebû fekihîn"
    },
    {
      "n": 32,
      "lat": "Veiẕâ raevhüm ḳâlû inne hâülâi leḍâllûn"
    },
    {
      "n": 33,
      "lat": "Vemâ ürsilû `aleyhim ḥâfiżîn"
    },
    {
      "n": 34,
      "lat": "Felyevme-lleẕîne âmenû mine-lküffâri yaḍḥakûn"
    },
    {
      "n": 35,
      "lat": "Ale-l'erâiki yenżurûn"
    },
    {
      "n": 36,
      "lat": "Hel ŝüvvibe-lküffâru mâ kânû yef`alûn"
    }
  ]
}
