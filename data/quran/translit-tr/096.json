{
  "translitId": "translit-tr",
  "n": 96,
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "lat": "İḳra' bismi rabbike-lleẕî ḫaleḳ"
    },
    {
      "n": 2,
      "lat": "Ḫaleḳa-l'insâne min `alaḳ"
    },
    {
      "n": 3,
      "lat": "İḳra' verabbüke-l'ekram"
    },
    {
      "n": 4,
      "lat": "Elleẕî `alleme bilḳalem"
    },
    {
      "n": 5,
      "lat": "Alleme-l'insâne mâ lem ya`lem"
    },
    {
      "n": 6,
      "lat": "Kellâ inne-l'insâne leyaṭgâ"
    },
    {
      "n": 7,
      "lat": "Er raâhü-stagnâ"
    },
    {
      "n": 8,
      "lat": "İnne ilâ rabbike-rruc`â"
    },
    {
      "n": 9,
      "lat": "Era'eyte-lleẕî yenhâ"
    },
    {
      "n": 10,
      "lat": "Abden iẕâ ṣallâ"
    },
    {
      "n": 11,
      "lat": "Era'eyte in kâne `ale-lhüdâ"
    },
    {
      "n": 12,
      "lat": "Ev emera bittaḳvâ"
    },
    {
      "n": 13,
      "lat": "Era'eyte in keẕẕebe vetevellâ"
    },
    {
      "n": 14,
      "lat": "Elem ya`lem bienne-llâhe yerâ"
    },
    {
      "n": 15,
      "lat": "Kellâ leil lem yentehi lenesfe`am binnâṣiyeh"
    },
    {
      "n": 16,
      "lat": "Nâṣiyetin kâẕibetin ḫâṭieh"
    },
    {
      "n": 17,
      "lat": "Felyed`u nâdiyeh"
    },
    {
      "n": 18,
      "lat": "Sened`u-zzebâniyeh"
    },
    {
      "n": 19,
      "lat": "Kellâ. Lâ tüṭi`hü vescüd vaḳterib"
    }
  ]
}
