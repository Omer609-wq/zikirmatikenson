  "ayahs": [
    {
      "n": 1,
      "lat": "Veylül likülli hümezetil lümezeh"
    },
    {
      "n": 2,
      "lat": "Elleẕî ceme`a mâlev ve`addedeh"
    },
    {
      "n": 3,
      "lat": "Yaḥsebü enne mâlehû aḫledeh"
    },
    {
      "n": 4,
      "lat": "Kellâ leyümbeẕenne fi-lḥuṭameh"
    },
    {
      "n": 5,
      "lat": "Vemâ edrâke me-lḥuṭameh"
    },
    {
      "n": 6,
      "lat": "Nâru-llâhi-lmûḳadeh"
    },
    {
      "n": 7,
      "lat": "Elletî teṭṭali`u `ale-l'ef'ideh"
    },
    {
      "n": 8,
      "lat": "İnnehâ `aleyhim mü'ṣadeh"
    },
    {
      "n": 9,
      "lat": "Fî `amedim mümeddedeh"
    }
  ]
}
