{
  "translitId": "translit-tr",
  "n": 53,
  "ayahCount": 62,
  "ayahs": [
    {
      "n": 1,
      "lat": "Vennecmi iẕâ hevâ"
    },
    {
      "n": 2,
      "lat": "Mâ ḍalle ṣâḥibüküm vemâ gavâ"
    },
    {
      "n": 3,
      "lat": "Vemâ yenṭiḳu `ani-lhevâ"
    },
    {
      "n": 4,
      "lat": "İn hüve illâ vaḥyüy yûḥâ"
    },
    {
      "n": 5,
      "lat": "Allemehû şedîdü-lḳuvâ"
    },
    {
      "n": 6,
      "lat": "Ẕû mirrah. Festevâ"
    },
    {
      "n": 7,
      "lat": "Vehüve bil'üfüḳi-l'a`lâ"
    },
    {
      "n": 8,
      "lat": "Ŝümme denâ fetedellâ"
    },
    {
      "n": 9,
      "lat": "Fekâne ḳâbe ḳavseyni ev ednâ"
    },
    {
      "n": 10,
      "lat": "Feevḥâ ilâ `abdihî mâ evḥâ"
    },
    {
      "n": 11,
      "lat": "Mâ keẕebe-lfüâdü mâ raâ"
    },
    {
      "n": 12,
      "lat": "Efetümârûnehû `alâ mâ yerâ"
    },
    {
      "n": 13,
      "lat": "Veleḳad raâhü nezleten uḫrâ"
    },
    {
      "n": 14,
      "lat": "İnde sidrati-lmüntehâ"
    },
    {
      "n": 15,
      "lat": "İndehâ cennetü-lme'vâ"
    },
    {
      "n": 16,
      "lat": "İẕ yagşe-ssidrate mâ yagşâ"
    },
    {
      "n": 17,
      "lat": "Mâ zâga-lbeṣaru vemâ ṭagâ"
    },
    {
      "n": 18,
      "lat": "Leḳad raâ min âyâti rabbihi-lkübrâ"
    },
    {
      "n": 19,
      "lat": "Eferaeytümü-llâte vel`uzzâ"
    },
    {
      "n": 20,
      "lat": "Vemenâte-ŝŝâliŝete-l'uḫrâ"
    },
    {
      "n": 21,
      "lat": "Elekümü-ẕẕekeru velehü-l'ünŝâ"
    },
    {
      "n": 22,
      "lat": "Tilke iẕen ḳismetün ḍîzâ"
    },
    {
      "n": 23,
      "lat": "İn hiye illâ esmâün semmeytümûhâ entüm veâbâüküm mâ enzele-llâhü bihâ min sülṭân. İy yettebi`ûne ille-żżanne vemâ tehve-l'enfüs. Veleḳad câehüm mir rabbihimü-lhüdâ"
    },
    {
      "n": 24,
      "lat": "Em lil'insâni mâ temennâ"
    },
    {
      "n": 25,
      "lat": "Felillâhi-l'âḫiratü vel'ûlâ"
    },
    {
      "n": 26,
      "lat": "Vekem mim melekin fi-ssemâvâti lâ tugnî şefâ`atühüm şey'en illâ mim ba`di ey ye'ẕene-llâhü limey yeşâü veyerḍâ"
    },
    {
      "n": 27,
      "lat": "İnne-lleẕîne lâ yü'minûne bil'âḫirati leyüsemmûne-lmelâikete tesmiyete-l'ünŝâ"
    },
    {
      "n": 28,
      "lat": "Vemâ lehüm bihî min `ilm. İy yettebi`ûne ille-żżanne. Veinne-żżanne lâ yugnî mine-lḥaḳḳi şey'â"
    },
    {
      "n": 29,
      "lat": "Fea`riḍ `am men tevellâ `an ẕikrinâ velem yürid ille-lḥayâte-ddünyâ"
    },
    {
      "n": 30,
      "lat": "Ẕâlike mebleguhüm mine-l`ilm. İnne rabbeke hüve a`lemü bimen ḍalle `an sebîlihî vehüve a`lemü bimeni-htedâ"
    },
    {
      "n": 31,
      "lat": "Velillâhi mâ fi-ssemâvâti vemâ fi-l'arḍi liyecziye-lleẕîne esâü bimâ `amilû veyecziye-lleẕîne aḥsenû bilḥusnâ"
    },
    {
      "n": 32,
      "lat": "Elleẕîne yectenibûne kebâira-l'iŝmi velfevâḥişe ille-llemem. İnne rabbeke vâsi`u-lmagfirah. Hüve a`lemü biküm iẕ enşeeküm mine-l'arḍi veiẕ entüm ecinnetün fî büṭûni ümmehâtiküm. Felâ tüzekkû enfüseküm. Hüve a`lemü bimeni-tteḳâ"
    },
    {
      "n": 33,
      "lat": "Eferaeyte-lleẕî tevellâ"
    },
    {
      "n": 34,
      "lat": "Vea`ṭâ ḳalîlev veekdâ"
    },
    {
      "n": 35,
      "lat": "E`indehû `ilmü-lgaybi fehüve yerâ"
    },
    {
      "n": 36,
      "lat": "Em lem yünebbe' bimâ fî ṣuḥufi mûsâ"
    },
    {
      "n": 37,
      "lat": "Veibrâhime-lleẕî veffâ"
    },
    {
      "n": 38,
      "lat": "Ellâ teziru vâziratüv vizra uḫrâ"
    },
    {
      "n": 39,
      "lat": "Veel leyse lil'insâni illâ mâ se`â"
    },
    {
      "n": 40,
      "lat": "Veenne sa`yehû sevfe yürâ"
    },
    {
      "n": 41,
      "lat": "Ŝümme yüczâhü-lcezâe-l'evfâ"
    },
    {
      "n": 42,
      "lat": "Veenne ilâ rabbike-lmüntehâ"
    },
    {
      "n": 43,
      "lat": "Veennehû hüve aḍḥake veebkâ"
    },
    {
      "n": 44,
      "lat": "Veennehû hüve emâte veaḥyâ"
    },
    {
      "n": 45,
      "lat": "Veennehû ḫaleḳa-zzevceyni-ẕẕekera vel'ünŝâ"
    },
    {
      "n": 46,
      "lat": "Min nuṭfetin iẕâ tümnâ"
    },
    {
      "n": 47,
      "lat": "Veenne `aleyhi-nneş'ete-l'uḫrâ"
    },
    {
      "n": 48,
      "lat": "Veennehû hüve agnâ veaḳnâ"
    },
    {
      "n": 49,
      "lat": "Veennehû hüve rabbü-şşi`râ"
    },
    {
      "n": 50,
      "lat": "Veennehû ehleke `âden-l'ûlâ"
    },
    {
      "n": 51,
      "lat": "Veŝemûde femâ ebḳâ"
    },
    {
      "n": 52,
      "lat": "Veḳavme nûḥim min ḳabl. İnnehüm kânû hüm ażleme veaṭgâ"
    },
    {
      "n": 53,
      "lat": "Velmü'tefikete ehvâ"
    },
    {
      "n": 54,
      "lat": "Fegaşşâhâ mâ gaşşâ"
    },
    {
      "n": 55,
      "lat": "Febieyyi âlâi rabbike tetemârâ"
    },
    {
      "n": 56,
      "lat": "Hâẕâ neẕîrum mine-nnüẕüri-l'ûlâ"
    },
    {
      "n": 57,
      "lat": "Ezifeti-l'âzifeh"
    },
    {
      "n": 58,
      "lat": "Leyse lehâ min dûni-llâhi kâşifeh"
    },
    {
      "n": 59,
      "lat": "Efemin hâẕe-lḥadîŝi ta`cebûn"
    },
    {
      "n": 60,
      "lat": "Vetaḍḥakûne velâ tebkûn"
    },
    {
      "n": 61,
      "lat": "Ventüm sâmidûn"
    },
    {
      "n": 62,
      "lat": "Fescüdû lillâhi va`büdû"
    }
  ]
}
