  "ayahs": [
    {
      "n": 1,
      "lat": "Velfecr"
    },
    {
      "n": 2,
      "lat": "Veleyâlin `aşr"
    },
    {
      "n": 3,
      "lat": "Veşşef`i velvetr"
    },
    {
      "n": 4,
      "lat": "Velleyli iẕâ yesr"
    },
    {
      "n": 5,
      "lat": "Hel fî ẕâlike ḳasemül liẕî ḥicr"
    },
    {
      "n": 6,
      "lat": "Elem tera keyfe fe`ale rabbüke bi`âd"
    },
    {
      "n": 7,
      "lat": "İrame ẕâti-l`imâd"
    },
    {
      "n": 8,
      "lat": "Elletî lem yuḫlaḳ miŝlühâ fi-lbilâd"
    },
    {
      "n": 9,
      "lat": "Veŝemûde-lleẕîne câbu-ṣṣaḫra bilvâd"
    },
    {
      "n": 10,
      "lat": "Vefir`avne ẕi-l'evtâd"
    },
    {
      "n": 11,
      "lat": "Elleẕîne ṭagav fi-lbilâd"
    },
    {
      "n": 12,
      "lat": "Feekŝerû fîhe-lfesâd"
    },
    {
      "n": 13,
      "lat": "Feṣabbe `aleyhim rabbüke sevṭa `aẕâb"
    },
    {
      "n": 14,
      "lat": "İnne rabbeke lebilmirṣâd"
    },
    {
      "n": 15,
      "lat": "Feemme-l'insânü iẕâ me-btelâhü rabbühû feekramehû vene``amehû feyeḳûlü rabbî ekramen"
    },
    {
      "n": 16,
      "lat": "Veemmâ iẕâ me-btelâhü feḳadera `aleyhi rizḳahû feyeḳûlü rabbî ehânen"
    },
    {
      "n": 17,
      "lat": "Kellâ bel lâ tükrimûne-lyetîm"
    },
    {
      "n": 18,
      "lat": "Velâ teḥâḍḍûne `alâ ṭa`âmi-lmiskîn"
    },
    {
      "n": 19,
      "lat": "Vete'külûne-ttürâŝe eklel lemmâ"
    },
    {
      "n": 20,
      "lat": "Vetüḥibbûne-lmâle ḥubben cemmâ"
    },
    {
      "n": 21,
      "lat": "Kellâ iẕâ dükketi-l'arḍu dekken dekkâ"
    },
    {
      "n": 22,
      "lat": "Vecâe rabbüke velmelekü ṣaffen ṣaffâ"
    },
    {
      "n": 23,
      "lat": "Vecîe yevmeiẕim bicehenneme yevmeiẕiy yeteẕekkeru-l'insânü veennâ lehü-ẕẕikrâ"
    },
    {
      "n": 24,
      "lat": "Yeḳûlü yâ leytenî ḳaddemtü liḥayâtî"
    },
    {
      "n": 25,
      "lat": "Feyevmeiẕil lâ yü`aẕẕibü `aẕâbehû eḥad"
    },
    {
      "n": 26,
      "lat": "Velâ yûŝiḳu veŝâḳahû eḥad"
    },
    {
      "n": 27,
      "lat": "Yâ eyyetühe-nnefsü-lmuṭmeinneh"
    },
    {
      "n": 28,
      "lat": "İrci`î ilâ rabbiki râḍiyetem merḍiyyeh"
    },
    {
      "n": 29,
      "lat": "Fedḫulî fî `ibâdî"
    },
    {
      "n": 30,
      "lat": "Vedḫulî cennetî"
    }
  ]
}
