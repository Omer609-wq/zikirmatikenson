{
  "translitId": "translit-tr",
  "n": 44,
  "ayahCount": 59,
  "ayahs": [
    {
      "n": 1,
      "lat": "Ḥâ-mîm"
    },
    {
      "n": 2,
      "lat": "Velkitâbi-lmübîn"
    },
    {
      "n": 3,
      "lat": "İnnâ enzelnâhü fî leyletim mübâraketin innâ künnâ münẕirîn"
    },
    {
      "n": 4,
      "lat": "Fîhâ yüfraḳu küllü emrin ḥakîm"
    },
    {
      "n": 5,
      "lat": "Emram min `indinâ. İnnâ künnâ mürsilîn"
    },
    {
      "n": 6,
      "lat": "Raḥmetem mir rabbik. İnnehû hüve-ssemî`u-l`alîm"
    },
    {
      "n": 7,
      "lat": "Rabbi-ssemâvâti vel'arḍi vemâ beynehümâ. İn küntüm mûḳinîn"
    },
    {
      "n": 8,
      "lat": "Lâ ilâhe illâ hüve yuḥyî veyümît. Rabbüküm verabbü âbâikümü-l'evvelîn"
    },
    {
      "n": 9,
      "lat": "Bel hüm fî şekkiy yel`abûn"
    },
    {
      "n": 10,
      "lat": "Ferteḳib yevme te'ti-ssemâü bidüḫânim mübîn"
    },
    {
      "n": 11,
      "lat": "Yagşe-nnâs. Hâẕâ `aẕâbün elîm"
    },
    {
      "n": 12,
      "lat": "Rabbene-kşif `anne-l`aẕâbe innâ mü'minûn"
    },
    {
      "n": 13,
      "lat": "Ennâ lehümü-ẕẕikrâ veḳad câehüm rasûlüm mübîn"
    },
    {
      "n": 14,
      "lat": "Ŝümme tevellev `anhü veḳâlû mü`allemüm mecnûn"
    },
    {
      "n": 15,
      "lat": "İnnâ kâşifü-l`aẕâbi ḳalîlen inneküm `âidûn"
    },
    {
      "n": 16,
      "lat": "Yevme nebṭişü-lbaṭşete-lkübrâ. İnnâ münteḳimûn"
    },
    {
      "n": 17,
      "lat": "Veleḳad fetennâ ḳablehüm ḳavme fir`avne vecâehüm rasûlün kerîm"
    },
    {
      "n": 18,
      "lat": "En eddû ileyye `ibâde-llâh. İnnî leküm rasûlün emîn"
    },
    {
      "n": 19,
      "lat": "Veel lâ ta`lû `ale-llâh. İnnî âtîküm bisülṭânim mübîn"
    },
    {
      "n": 20,
      "lat": "Veinnî `uẕtü birabbî verabbiküm en tercümûn"
    },
    {
      "n": 21,
      "lat": "Veil lem tü'minû lî fa`tezilûn"
    },
    {
      "n": 22,
      "lat": "Fede`â rabbehû enne hâülâi ḳavmüm mücrimûn"
    },
    {
      "n": 23,
      "lat": "Feesri bi`ibâdî leylen inneküm müttebe`ûn"
    },
    {
      "n": 24,
      "lat": "Vetruki-lbaḥra rahvâ. İnnehüm cündüm mugraḳûn"
    },
    {
      "n": 25,
      "lat": "Kem terakû min cennâtiv ve`uyûn"
    },
    {
      "n": 26,
      "lat": "Vezürû`iv vemeḳâmin kerîm"
    },
    {
      "n": 27,
      "lat": "Vena`metin kânû fîhâ fâkihîn"
    },
    {
      "n": 28,
      "lat": "Keẕâlik. Veevraŝnâhâ ḳavmen âḫarîn"
    },
    {
      "n": 29,
      "lat": "Femâ beket `aleyhimü-ssemâü vel'arḍu vemâ kânû münżarîn"
    },
    {
      "n": 30,
      "lat": "Veleḳad necceynâ benî isrâîle mine-l`aẕâbi-lmühîn"
    },
    {
      "n": 31,
      "lat": "Min fir`avn. İnnehû kâne `âliyem mine-lmüsrifîn"
    },
    {
      "n": 32,
      "lat": "Veleḳadi-ḫternâhüm `alâ `ilmin `ale-l`âlemîn"
    },
    {
      "n": 33,
      "lat": "Veâteynâhüm mine-l'âyâti mâ fîhi belâüm mübîn"
    },
    {
      "n": 34,
      "lat": "İnne hâülâi leyeḳûlûn"
    },
    {
      "n": 35,
      "lat": "İn hiye illâ mevtetüne-l'ûlâ vemâ naḥnü bimünşerîn"
    },
    {
      "n": 36,
      "lat": "Fe'tû biâbâinâ in küntüm ṣâdiḳîn"
    },
    {
      "n": 37,
      "lat": "Ehüm ḫayrun em ḳavmü tübbe`iv velleẕîne min ḳablihim. Ehleknâhüm. İnnehüm kânû mücrimîn"
    },
    {
      "n": 38,
      "lat": "Vemâ ḫalaḳne-ssemâvâti vel'arḍa vemâ beynehümâ lâ`ibîn"
    },
    {
      "n": 39,
      "lat": "Mâ ḫalaḳnâhümâ illâ bilḥaḳḳi velâkinne ekŝerahüm lâ ya`lemûn"
    },
    {
      "n": 40,
      "lat": "İnne yevme-lfaṣli mîḳâtühüm ecme`în"
    },
    {
      "n": 41,
      "lat": "Yevme lâ yugnî mevlen `am mevlen şey'ev velâ hüm yünṣarûn"
    },
    {
      "n": 42,
      "lat": "İllâ mer raḥime-llâh. İnnehû hüve-l`azîzü-rraḥîm"
    },
    {
      "n": 43,
      "lat": "İnne şecerate-zzeḳḳûm"
    },
    {
      "n": 44,
      "lat": "Ṭa`âmü-l'eŝîm"
    },
    {
      "n": 45,
      "lat": "Kelmühl. Yaglî fi-lbüṭûn"
    },
    {
      "n": 46,
      "lat": "Kegalyi-lḥamîm"
    },
    {
      "n": 47,
      "lat": "Ḫuẕûhü fa`tilûhü ilâ sevâi-lceḥîm"
    },
    {
      "n": 48,
      "lat": "Ŝümme ṣubbû fevḳa ra'sihî min `aẕâbi-lḥamîm"
    },
    {
      "n": 49,
      "lat": "Ẕuḳ. İnneke ente-l`azîzü-lkerîm"
    },
    {
      "n": 50,
      "lat": "İnne hâẕâ mâ küntüm bihî temterûn"
    },
    {
      "n": 51,
      "lat": "İnne-lmütteḳîne fî meḳâmin emîn"
    },
    {
      "n": 52,
      "lat": "Fî cennâtiv ve`uyûn"
    },
    {
      "n": 53,
      "lat": "Yelbesûne min sündüsiv veistebraḳim müteḳâbilîn"
    },
    {
      "n": 54,
      "lat": "Keẕâlik. Vezevvecnâhüm biḥûrin `în"
    },
    {
      "n": 55,
      "lat": "Yed`ûne fîhâ bikülli fâkihetin âminîn"
    },
    {
      "n": 56,
      "lat": "Lâ yeẕûḳûne fîhe-lmevte ille-lmevtete-l'ûlâ. Veveḳâhüm `aẕâbe-lceḥîm"
    },
    {
      "n": 57,
      "lat": "Faḍlem mir rabbik. Ẕâlike hüve-lfevzü-l`ażîm"
    },
    {
      "n": 58,
      "lat": "Feinnemâ yessernâhü bilisânike le`allehüm yeteẕekkerûn"
    },
    {
      "n": 59,
      "lat": "Ferteḳib innehüm mürteḳibûn"
    }
  ]
}
