{
  "translitId": "translit-tr",
  "n": 85,
  "ayahCount": 22,
  "ayahs": [
    {
      "n": 1,
      "lat": "Vessemâi ẕâti-lbürûc"
    },
    {
      "n": 2,
      "lat": "Velyevmi-lmev`ûd"
    },
    {
      "n": 3,
      "lat": "Veşâhidiv vemeşhûd"
    },
    {
      "n": 4,
      "lat": "Ḳutile aṣḥâbü-l'uḫdûd"
    },
    {
      "n": 5,
      "lat": "Ennâri ẕâti-lveḳûd"
    },
    {
      "n": 6,
      "lat": "İẕ hüm `aleyhâ ḳu`ûd"
    },
    {
      "n": 7,
      "lat": "Vehüm `alâ mâ yef`alûne bilmü'minîne şühûd"
    },
    {
      "n": 8,
      "lat": "Vemâ neḳamû minhüm illâ ey yü'minû billâhi-l`azîzi-lḥamîd"
    },
    {
      "n": 9,
      "lat": "Elleẕî lehû mülkü-ssemâvâti vel'arḍ. Vellâhü `alâ külli şey'in şehîd"
    },
    {
      "n": 10,
      "lat": "İnne-lleẕîne fetenü-lmü'minîne velmü'minâti ŝümme lem yetûbû felehüm `aẕâbü cehenneme velehüm `aẕâbü-lḥarîḳ"
    },
    {
      "n": 11,
      "lat": "İnne-lleẕîne âmenû ve`amilu-ṣṣâliḥâti lehüm cennâtün tecrî min taḥtihe-l'enhâr. Ẕâlike-lfevzü-lkebîr"
    },
    {
      "n": 12,
      "lat": "İnne baṭşe rabbike leşedîd"
    },
    {
      "n": 13,
      "lat": "İnnehû hüve yübdiü veyü`îd"
    },
    {
      "n": 14,
      "lat": "Vehüve-lgafûru-lvedûd"
    },
    {
      "n": 15,
      "lat": "Ẕü-l`arşi-lmecîd"
    },
    {
      "n": 16,
      "lat": "Fa``âlül limâ yürîd"
    },
    {
      "n": 17,
      "lat": "Hel etâke ḥadîŝü-lcünûd"
    },
    {
      "n": 18,
      "lat": "Fir`avne veŝemûd"
    },
    {
      "n": 19,
      "lat": "Beli-lleẕîne keferû fî tekẕîb"
    },
    {
      "n": 20,
      "lat": "Vellâhü miv verâihim müḥîṭ"
    },
    {
      "n": 21,
      "lat": "Bel hüve ḳur'ânüm mecîd"
    },
    {
      "n": 22,
      "lat": "Fî levḥim maḥfûż"
    }
  ]
}
