{
  "translitId": "translit-tr",
  "n": 82,
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "lat": "İẕe-ssemâü-nfeṭarat"
    },
    {
      "n": 2,
      "lat": "Veiẕe-lkevâkibü-nteŝerat"
    },
    {
      "n": 3,
      "lat": "Veiẕe-lbiḥâru füccirat"
    },
    {
      "n": 4,
      "lat": "Veiẕe-lḳubûru bü`ŝirat"
    },
    {
      "n": 5,
      "lat": "Alimet nefsüm mâ ḳaddemet veeḫḫarat"
    },
    {
      "n": 6,
      "lat": "Yâ eyyühe-l'insânü mâ garrake birabbike-lkerîm"
    },
    {
      "n": 7,
      "lat": "Elleẕî ḫaleḳake fesevvâke fe`adelek"
    },
    {
      "n": 8,
      "lat": "Fî eyyi ṣûratim mâ şâe rakkebek"
    },
    {
      "n": 9,
      "lat": "Kellâ bel tükeẕẕibûne biddîn"
    },
    {
      "n": 10,
      "lat": "Veinne `aleyküm leḥâfiżîn"
    },
    {
      "n": 11,
      "lat": "Kirâmen kâtibîn"
    },
    {
      "n": 12,
      "lat": "Ya`lemûne mâ tef`alûn"
    },
    {
      "n": 13,
      "lat": "İnne-l'ebrâra lefî ne`îm"
    },
    {
      "n": 14,
      "lat": "Veinne-lfüccâra lefî ceḥîm"
    },
    {
      "n": 15,
      "lat": "Yaṣlevnehâ yevme-ddîn"
    },
    {
      "n": 16,
      "lat": "Vemâ hüm `anhâ bigâibîn"
    },
    {
      "n": 17,
      "lat": "Vemâ edrâke mâ yevmü-ddîn"
    },
    {
      "n": 18,
      "lat": "Ŝümme mâ edrâke mâ yevmü-ddîn"
    },
    {
      "n": 19,
      "lat": "Yevme lâ temlikü nefsül linefsin şey'â. Vel'emru yevmeiẕil lillâh"
    }
  ]
}
