{
  "translitId": "translit-tr",
  "n": 54,
  "ayahCount": 55,
  "ayahs": [
    {
      "n": 1,
      "lat": "İḳterabeti-ssâ`atü venşeḳḳa-lḳamer"
    },
    {
      "n": 2,
      "lat": "Veiy yerav âyetey yü`riḍû veyeḳûlû siḥrum müstemirr"
    },
    {
      "n": 3,
      "lat": "Vekeẕẕebû vettebe`û ehvâehüm veküllü emrim müsteḳirr"
    },
    {
      "n": 4,
      "lat": "Veleḳad câehüm mine-l'embâi mâ fîhi müzdecer"
    },
    {
      "n": 5,
      "lat": "Ḥikmetüm bâligatün femâ tugni-nnüẕür"
    },
    {
      "n": 6,
      "lat": "Fetevelle `anhüm. Yevme yed`u-ddâ`i ilâ şey'in nükür"
    },
    {
      "n": 7,
      "lat": "Ḫuşşe`an ebṣâruhüm yaḫrucûne mine-l'ecdâŝi keennehüm cerâdüm münteşir"
    },
    {
      "n": 8,
      "lat": "Mühti`îne ile-ddâ`. Yeḳûlü-lkâfirûne hâẕâ yevmün `asir"
    },
    {
      "n": 9,
      "lat": "Keẕẕebet ḳablehüm ḳavmü nûḥin fekeẕẕebû `abdenâ veḳâlû mecnûnüv vezdücira"
    },
    {
      "n": 10,
      "lat": "Fede`â rabbehû ennî maglûbün fenteṣir"
    },
    {
      "n": 11,
      "lat": "Fefetaḥnâ ebvâbe-ssemâi bimâim münhemir"
    },
    {
      "n": 12,
      "lat": "Vefeccerne-l'arḍa `uyûnen felteḳe-lmâü `alâ emrin ḳad ḳudir"
    },
    {
      "n": 13,
      "lat": "Veḥamelnâhü `alâ ẕâti elvâḥiv vedüsür"
    },
    {
      "n": 14,
      "lat": "Tecrî bia`yüninâ. Cezâel limen kâne küfira"
    },
    {
      "n": 15,
      "lat": "Veleḳat teraknâhâ âyeten fehel mim müddekir"
    },
    {
      "n": 16,
      "lat": "Fekeyfe kâne `aẕâbî venüẕür"
    },
    {
      "n": 17,
      "lat": "Veleḳad yesserne-lḳur'âne liẕẕikri fehel mim müddekir"
    },
    {
      "n": 18,
      "lat": "Keẕẕebet `âdün fekeyfe kâne `aẕâbî venüẕür"
    },
    {
      "n": 19,
      "lat": "İnnâ erselnâ `aleyhim rîḥan ṣarṣaran fî yevmi naḥsim müstemirr"
    },
    {
      "n": 20,
      "lat": "Tenzi`u-nnâse keennehüm a`câzü naḫlim münḳa`ir"
    },
    {
      "n": 21,
      "lat": "Fekeyfe kâne `aẕâbî venüẕür"
    },
    {
      "n": 22,
      "lat": "Veleḳad yesserne-lḳur'âne liẕẕikri fehel mim müddekir"
    },
    {
      "n": 23,
      "lat": "Keẕẕebet ŝemûdü binnüẕür"
    },
    {
      "n": 24,
      "lat": "Feḳâlû ebeşeram minnâ vâḥiden nettebi`uhû innâ iẕel lefî ḍalâliv vesü`ur"
    },
    {
      "n": 25,
      "lat": "Eülḳiye-ẕẕikru `aleyhi mim beyninâ bel hüve keẕẕâbün eşir"
    },
    {
      "n": 26,
      "lat": "Seya`lemûne gadem meni-lkeẕẕâbü-l'eşir"
    },
    {
      "n": 27,
      "lat": "İnnâ mürsilü-nnâḳati fitnetel lehüm ferteḳibhüm vaṣṭabir"
    },
    {
      "n": 28,
      "lat": "Venebbi'hüm enne-lmâe ḳismetüm beynehüm. Küllü şirbim muḥteḍar"
    },
    {
      "n": 29,
      "lat": "Fenâdev ṣâḥibehüm fete`âṭâ fe`aḳara"
    },
    {
      "n": 30,
      "lat": "Fekeyfe kâne `aẕâbî venüẕür"
    },
    {
      "n": 31,
      "lat": "İnnâ erselnâ `aleyhim ṣayḥatev vâḥideten fekânû keheşîmi-lmuḥteżir"
    },
    {
      "n": 32,
      "lat": "Veleḳad yesserne-lḳur'âne liẕẕikri fehel mim müddekir"
    },
    {
      "n": 33,
      "lat": "Keẕẕebet ḳavmü lûṭim binnüẕür"
    },
    {
      "n": 34,
      "lat": "İnnâ erselnâ `aleyhim ḥâṣiben illâ âle lûṭ. Necceynâhüm biseḥar"
    },
    {
      "n": 35,
      "lat": "Ni`metem min `indinâ. Keẕâlike neczî men şekera"
    },
    {
      "n": 36,
      "lat": "Veleḳad enẕerahüm baṭşetenâ fetemârav binnüẕür"
    },
    {
      "n": 37,
      "lat": "Veleḳad râvedûhü `an ḍayfihî feṭamesnâ a`yünehüm feẕûḳû `aẕâbî venüẕür"
    },
    {
      "n": 38,
      "lat": "Veleḳad ṣabbeḥahüm bükraten `aẕâbüm müsteḳirr"
    },
    {
      "n": 39,
      "lat": "Feẕûḳû `aẕâbî venüẕür"
    },
    {
      "n": 40,
      "lat": "Veleḳad yesserne-lḳur'âne liẕẕikri fehel mim müddekir"
    },
    {
      "n": 41,
      "lat": "Veleḳad câe âle fir`avne-nnüẕür"
    },
    {
      "n": 42,
      "lat": "Keẕẕebû biâyâtinâ küllihâ feeḫaẕnâhüm aḫẕe `azîzim muḳtedir"
    },
    {
      "n": 43,
      "lat": "Eküffâruküm ḫayrum min ülâiküm em leküm berâetün fi-zzübür"
    },
    {
      "n": 44,
      "lat": "Em yeḳûlûne naḥnü cemî`um münteṣir"
    },
    {
      "n": 45,
      "lat": "Seyühzemü-lcem`u veyüvellûne-ddübüra"
    },
    {
      "n": 46,
      "lat": "Beli-ssâ`atü mev`idühüm vessâ`atü edhâ veemerr"
    },
    {
      "n": 47,
      "lat": "İnne-lmücrimîne fî ḍalâliv vesü`ur"
    },
    {
      "n": 48,
      "lat": "Yevme yüsḥabûne fi-nnâri `alâ vucûhihim. Ẕûḳû messe seḳara"
    },
    {
      "n": 49,
      "lat": "İnnâ külle şey'in ḫalaḳnâhü biḳader"
    },
    {
      "n": 50,
      "lat": "Vemâ emrunâ illâ vâḥidetün kelemḥim bilbeṣar"
    },
    {
      "n": 51,
      "lat": "Veleḳad ehleknâ eşyâ`aküm fehel mim müddekir"
    },
    {
      "n": 52,
      "lat": "Veküllü şey'in fe`alûhü fi-zzübür"
    },
    {
      "n": 53,
      "lat": "Veküllü ṣagîriv vekebîrim müsteṭar"
    },
    {
      "n": 54,
      "lat": "İnne-lmütteḳîne fî cennâtiv veneher"
    },
    {
      "n": 55,
      "lat": "Fî maḳ`adi ṣidḳin `inde melîkim muḳtedir"
    }
  ]
}
