{
  "translitId": "translit-tr",
  "n": 78,
  "ayahCount": 40,
  "ayahs": [
    {
      "n": 1,
      "lat": "Amme yetesâelûn"
    },
    {
      "n": 2,
      "lat": "Ani-nnebei-l`ażîm"
    },
    {
      "n": 3,
      "lat": "Elleẕî hüm fîhi muḫtelifûn"
    },
    {
      "n": 4,
      "lat": "Kellâ seya`lemûn"
    },
    {
      "n": 5,
      "lat": "Ŝümme kellâ seya`lemûn"
    },
    {
      "n": 6,
      "lat": "Elem nec`ali-l'arḍa mihâdâ"
    },
    {
      "n": 7,
      "lat": "Velcibâle evtâdâ"
    },
    {
      "n": 8,
      "lat": "Veḫalaḳnâküm ezvâcâ"
    },
    {
      "n": 9,
      "lat": "Vece`alnâ nevmeküm sübâtâ"
    },
    {
      "n": 10,
      "lat": "Vece`alne-lleyle libâsâ"
    },
    {
      "n": 11,
      "lat": "Vece`alne-nnehâra me`âşâ"
    },
    {
      "n": 12,
      "lat": "Vebeneynâ fevḳaküm seb`an şidâdâ"
    },
    {
      "n": 13,
      "lat": "Vece`alnâ sirâcev vehhâcâ"
    },
    {
      "n": 14,
      "lat": "Veenzelnâ mine-lmü`ṣirâti mâen ŝeccâcâ"
    },
    {
      "n": 15,
      "lat": "Linuḫrice bihî ḥabbev venebâtâ"
    },
    {
      "n": 16,
      "lat": "Vecennâtin elfâfâ"
    },
    {
      "n": 17,
      "lat": "İnne yevme-lfaṣli kâne mîḳâtâ"
    },
    {
      "n": 18,
      "lat": "Yevme yünfeḫu fi-ṣṣûri fete'tûne efvâcâ"
    },
    {
      "n": 19,
      "lat": "Vefütiḥati-ssemâü fekânet ebvâbâ"
    },
    {
      "n": 20,
      "lat": "Vesüyyirati-lcibâlü fekânet serâbâ"
    },
    {
      "n": 21,
      "lat": "İnne cehenneme kânet mirṣâdâ"
    },
    {
      "n": 22,
      "lat": "Liṭṭâgîne meâbâ"
    },
    {
      "n": 23,
      "lat": "Lâbiŝîne fîhâ aḥḳâbâ"
    },
    {
      "n": 24,
      "lat": "Lâ yeẕûḳûne fîhâ berdev velâ şerâbâ"
    },
    {
      "n": 25,
      "lat": "İllâ ḥamîmev vegassâḳâ"
    },
    {
      "n": 26,
      "lat": "Cezâev vifâḳâ"
    },
    {
      "n": 27,
      "lat": "İnnehüm kânû lâ yercûne ḥisâbâ"
    },
    {
      "n": 28,
      "lat": "Vekeẕẕebû biâyâtinâ kiẕẕâbâ"
    },
    {
      "n": 29,
      "lat": "Vekülle şey'in aḥṣaynâhü kitâbâ"
    },
    {
      "n": 30,
      "lat": "Feẕûḳû felen nezîdeküm illâ `aẕâbâ"
    },
    {
      "n": 31,
      "lat": "İnne lilmütteḳîne mefâzâ"
    },
    {
      "n": 32,
      "lat": "Ḥadâiḳa vea`nâbâ"
    },
    {
      "n": 33,
      "lat": "Vekevâ`ibe etrâbâ"
    },
    {
      "n": 34,
      "lat": "Veke'sen dihâḳâ"
    },
    {
      "n": 35,
      "lat": "Lâ yesme`ûne fîhâ lagvev velâ kiẕẕâbâ"
    },
    {
      "n": 36,
      "lat": "Cezâem mir rabbike `aṭâen ḥisâbâ"
    },
    {
      "n": 37,
      "lat": "Rabbi-ssemâvâti vel'arḍi vemâ beynehüme-rraḥmâni lâ yemlikûne minhü ḫiṭâbâ"
    },
    {
      "n": 38,
      "lat": "Yevme yeḳûmü-rrûḥu velmelâiketü ṣaffâ. Lâ yetekellemûne illâ men eẕine lehü-rraḥmânü veḳâle ṣavâbâ"
    },
    {
      "n": 39,
      "lat": "Ẕâlike-lyevmü-lḥaḳḳ. Femen şâe-tteḫaẕe ilâ rabbihî meâbâ"
    },
    {
      "n": 40,
      "lat": "İnnâ enẕernâküm `aẕâben ḳarîbâ. Yevme yenżuru-lmerü mâ ḳaddemet yedâhü veyeḳûlü-lkâfiru yâ leytenî küntü türâbâ"
    }
  ]
}
