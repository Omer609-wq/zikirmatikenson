  "ayahs": [
    {
      "n": 1,
      "lat": "Sebbiḥi-sme rabbike-l'a`lâ"
    },
    {
      "n": 2,
      "lat": "Elleẕî ḫaleḳa fesevvâ"
    },
    {
      "n": 3,
      "lat": "Velleẕî ḳaddera fehedâ"
    },
    {
      "n": 4,
      "lat": "Velleẕî aḫrace-lmer`â"
    },
    {
      "n": 5,
      "lat": "Fece`alehû guŝâen aḥvâ"
    },
    {
      "n": 6,
      "lat": "Senuḳriüke felâ tensâ"
    },
    {
      "n": 7,
      "lat": "İllâ mâ şâe-llâh. İnnehû ya`lemü-lcehra vemâ yaḫfâ"
    },
    {
      "n": 8,
      "lat": "Venüyessiruke lilyüsrâ"
    },
    {
      "n": 9,
      "lat": "Feẕekkir in nefe`ati-ẕẕikrâ"
    },
    {
      "n": 10,
      "lat": "Seyeẕẕekkeru mey yaḫşâ"
    },
    {
      "n": 11,
      "lat": "Veyetecennebühe-l'eşḳâ"
    },
    {
      "n": 12,
      "lat": "Elleẕî yaṣle-nnâra-lkübrâ"
    },
    {
      "n": 13,
      "lat": "Ŝümme lâ yemûtü fîhâ velâ yaḥyâ"
    },
    {
      "n": 14,
      "lat": "Ḳad efleḥa men tezekkâ"
    },
    {
      "n": 15,
      "lat": "Veẕekera-sme rabbihî feṣallâ"
    },
    {
      "n": 16,
      "lat": "Bel tü'ŝirûne-lḥayâte-ddünyâ"
    },
    {
      "n": 17,
      "lat": "Vel'âḫiratü ḫayruv veebḳâ"
    },
    {
      "n": 18,
      "lat": "İnne hâẕâ lefi-ṣṣuḥufi-l'ûlâ"
    },
    {
      "n": 19,
      "lat": "Ṣuḥufi ibrâhîme vemûsâ"
    }
  ]
}
