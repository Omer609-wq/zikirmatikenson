    },
    {
      "n": 5,
      "lat": "Felmüdebbirâti emrâ"
    },
    {
      "n": 6,
      "lat": "Yevme tercüfü-rrâcifeh"
    },
    {
      "n": 7,
      "lat": "Tetbe`uhe-rrâdifeh"
    },
    {
      "n": 8,
      "lat": "Ḳulûbüy yevmeiẕiv vâcifeh"
    },
    {
      "n": 9,
      "lat": "Ebṣâruhâ ḫâşi`ah"
    },
    {
      "n": 10,
      "lat": "Yeḳûlûne einnâ lemerdûdûne fi-lḥâfirah"
    },
    {
      "n": 11,
      "lat": "Eiẕâ künnâ `iżâmen neḫirah"
    },
    {
      "n": 12,
      "lat": "Ḳâlû tilke iẕen kerratün ḫâsirah"
    },
    {
      "n": 13,
      "lat": "Feinnemâ hiye zecratüv vâḥideh"
    },
    {
      "n": 14,
      "lat": "Feiẕâ hüm bissâhirah"
    },
    {
      "n": 15,
      "lat": "Hel etâke ḥadîŝü mûsâ"
    },
    {
      "n": 16,
      "lat": "İẕ nâdâhü rabbühû bilvâdi-lmüḳaddesi ṭuvâ"
    },
    {
      "n": 17,
      "lat": "İẕheb ilâ fir`avne innehû ṭagâ"
    },
    {
      "n": 18,
      "lat": "Feḳul hel leke ilâ en tezekkâ"
    },
    {
      "n": 19,
      "lat": "Veehdiyeke ilâ rabbike fetaḫşâ"
    },
    {
      "n": 20,
      "lat": "Feerâhü-l'âyete-lkübrâ"
    },
    {
      "n": 21,
      "lat": "Fekeẕẕebe ve`aṣâ"
    },
    {
      "n": 22,
      "lat": "Ŝümme edbera yes`â"
    },
    {
      "n": 23,
      "lat": "Feḥaşera fenâdâ"
    },
    {
      "n": 24,
      "lat": "Feḳâle ene rabbükümü-l'a`lâ"
    },
    {
      "n": 25,
      "lat": "Feeḫaẕehü-llâhü nekâle-l'âḫirati vel'ûlâ"
    },
    {
      "n": 26,
      "lat": "İnne fî ẕâlike le`ibratel limey yaḫşâ"
    },
    {
      "n": 27,
      "lat": "Entüm eşeddü ḫalḳan emi-ssemâü. Benâhâ"
    },
    {
      "n": 28,
      "lat": "Rafe`a semkehâ fesevvâhâ"
    },
    {
      "n": 29,
      "lat": "Veagṭaşe leylehâ veaḫrace ḍuḥâhâ"
    },
    {
      "n": 30,
      "lat": "Vel'arḍa ba`de ẕâlike deḥâhâ"
    },
    {
      "n": 31,
      "lat": "Aḫrace minhâ mâehâ vemer`âhâ"
    },
    {
      "n": 32,
      "lat": "Velcibâle ersâhâ"
    },
    {
      "n": 33,
      "lat": "Metâ`al leküm velien`âmiküm"
    },
    {
      "n": 34,
      "lat": "Feiẕâ câeti-ṭṭâmmetü-lkübrâ"
    },
    {
      "n": 35,
      "lat": "Yevme yeteẕekkeru-l'insânü mâ se`â"
    },
    {
      "n": 36,
      "lat": "Vebürrizeti-lceḥîmü limey yerâ"
    },
    {
      "n": 37,
      "lat": "Feemmâ men ṭagâ"
    },
    {
      "n": 38,
      "lat": "Veâŝera-lḥayâte-ddünyâ"
    },
    {
      "n": 39,
      "lat": "Feinne-lceḥîme hiye-lme'vâ"
    },
    {
      "n": 40,
      "lat": "Veemmâ men ḫâfe meḳâme rabbihî venehe-nnefse `ani-lhevâ"
    },
    {
      "n": 41,
      "lat": "Feinne-lcennete hiye-lme'vâ"
    },
    {
      "n": 42,
      "lat": "Yes'elûneke `ani-ssâ`ati eyyâne mürsâhâ"
    },
    {
      "n": 43,
      "lat": "Fîme ente min ẕikrâhâ"
    },
    {
      "n": 44,
      "lat": "İlâ rabbike müntehâhâ"
    },
    {
      "n": 45,
      "lat": "İnnemâ ente münẕiru mey yaḫşâhâ"
    },
    {
      "n": 46,
      "lat": "Keennehüm yevme yeravnehâ lem yelbeŝû illâ `aşiyyeten ev ḍuḥâhâ"
    }
  ]
}
