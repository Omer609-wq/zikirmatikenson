{
  "translitId": "translit-tr",
  "n": 74,
  "ayahCount": 56,
  "ayahs": [
    {
      "n": 1,
      "lat": "Yâ eyyühe-lmüddeŝŝir"
    },
    {
      "n": 2,
      "lat": "Ḳum feenẕir"
    },
    {
      "n": 3,
      "lat": "Verabbeke fekebbir"
    },
    {
      "n": 4,
      "lat": "Veŝiyâbeke feṭahhir"
    },
    {
      "n": 5,
      "lat": "Verrucze fehcür"
    },
    {
      "n": 6,
      "lat": "Velâ temnün testekŝir"
    },
    {
      "n": 7,
      "lat": "Velirabbike faṣbir"
    },
    {
      "n": 8,
      "lat": "Feiẕâ nüḳira fi-nnâḳûr"
    },
    {
      "n": 9,
      "lat": "Feẕâlike yevmeiẕiy yevmün `asîr"
    },
    {
      "n": 10,
      "lat": "Ale-lkâfirîne gayru yesîr"
    },
    {
      "n": 11,
      "lat": "Ẕernî vemen ḫalaḳtü veḥîdâ"
    },
    {
      "n": 12,
      "lat": "Vece`altü lehû mâlem memdûdâ"
    },
    {
      "n": 13,
      "lat": "Vebenîne şühûdâ"
    },
    {
      "n": 14,
      "lat": "Vemehhettü lehû temhîdâ"
    },
    {
      "n": 15,
      "lat": "Ŝümme yaṭme`u en ezîd"
    },
    {
      "n": 16,
      "lat": "Kellâ. İnnehû kâne liâyâtinâ `anîdâ"
    },
    {
      "n": 17,
      "lat": "Seürhiḳuhû ṣa`ûdâ"
    },
    {
      "n": 18,
      "lat": "İnnehû fekkera veḳaddera"
    },
    {
      "n": 19,
      "lat": "Feḳutile keyfe ḳaddera"
    },
    {
      "n": 20,
      "lat": "Ŝümme ḳutile keyfe ḳaddera"
    },
    {
      "n": 21,
      "lat": "Ŝümme neżara"
    },
    {
      "n": 22,
      "lat": "Ŝümme `abese vebesera"
    },
    {
      "n": 23,
      "lat": "Ŝümme edbera vestekbera"
    },
    {
      "n": 24,
      "lat": "Feḳâle in hâẕâ illâ siḥruy yü'ŝer"
    },
    {
      "n": 25,
      "lat": "İn hâẕâ illâ ḳavlü-lbeşer"
    },
    {
      "n": 26,
      "lat": "Seuṣlîhi seḳara"
    },
    {
      "n": 27,
      "lat": "Vemâ edrâke mâ seḳar"
    },
    {
      "n": 28,
      "lat": "Lâ tübḳî velâ teẕer"
    },
    {
      "n": 29,
      "lat": "Levvâḥatül lilbeşer"
    },
    {
      "n": 30,
      "lat": "Aleyhâ tis`ate `aşer"
    },
    {
      "n": 31,
      "lat": "Vemâ ce`alnâ aṣḥâbe-nnâri illâ melâikeh. Vemâ ce`alnâ `iddetehüm illâ fitneten lilleẕîne keferû liyesteyḳine-lleẕîne ûtü-lkitâbe veyezdâde-lleẕîne âmenû îmânev velâ yertâbe-lleẕîne ûtü-lkitâbe velmü'minûne veliyeḳûle-lleẕîne fî ḳulûbihim meraḍuv velkâfirûne mâẕâ erâde-llâhü bihâẕâ meŝelâ. Keẕâlike yüḍillü-llâhü mey yeşâü veyehdî mey yeşâ'. Vemâ ya`lemü cünûde rabbike illâ hû. Vemâ hiye illâ ẕikrâ lilbeşer"
    },
    {
      "n": 32,
      "lat": "Kellâ velḳamer"
    },
    {
      "n": 33,
      "lat": "Velleyli iẕ edbera"
    },
    {
      "n": 34,
      "lat": "Veṣṣubḥi iẕâ esfera"
    },
    {
      "n": 35,
      "lat": "İnnehâ leiḥde-lküber"
    },
    {
      "n": 36,
      "lat": "Neẕîral lilbeşer"
    },
    {
      "n": 37,
      "lat": "Limen şâe minküm ey yeteḳaddeme ev yeteeḫḫar"
    },
    {
      "n": 38,
      "lat": "Küllü nefsim bimâ kesebet rahîneh"
    },
    {
      "n": 39,
      "lat": "İllâ aṣḥâbe-lyemîn"
    },
    {
      "n": 40,
      "lat": "Fî cennâtin. Yetesâelûn"
    },
    {
      "n": 41,
      "lat": "Ani-lmücrimîn"
    },
    {
      "n": 42,
      "lat": "Mâ selekeküm fî seḳara"
    },
    {
      "n": 43,
      "lat": "Ḳâlû lem nekü mine-lmüṣallîn"
    },
    {
      "n": 44,
      "lat": "Velem nekü nuṭ`imü-lmiskîn"
    },
    {
      "n": 45,
      "lat": "Vekünnâ neḫûḍu me`a-lḫâiḍîn"
    },
    {
      "n": 46,
      "lat": "Vekünnâ nükeẕẕibü biyevmi-ddîn"
    },
    {
      "n": 47,
      "lat": "Ḥattâ etâne-lyeḳîn"
    },
    {
      "n": 48,
      "lat": "Femâ tenfe`uhüm şefâ`atü-şşâfi`în"
    },
    {
      "n": 49,
      "lat": "Femâ lehüm `ani-tteẕkirati mü`riḍîn"
    },
    {
      "n": 50,
      "lat": "Keennehüm ḥumürum müstenfirah"
    },
    {
      "n": 51,
      "lat": "Ferrat min ḳasverah"
    },
    {
      "n": 52,
      "lat": "Bel yürîdü küllü-mriim minhüm ey yü'tâ ṣuḥufem müneşşerah"
    },
    {
      "n": 53,
      "lat": "Kellâ. Bel lâ yeḫâfûne-l'âḫirah"
    },
    {
      "n": 54,
      "lat": "Kellâ innehû teẕkirah"
    },
    {
      "n": 55,
      "lat": "Femen şâe ẕekerah"
    },
    {
      "n": 56,
      "lat": "Vemâ yeẕkürûne illâ ey yeşâe-llâh. Hüve ehlü-ttaḳvâ veehlü-lmagfirah"
    }
  ]
}
