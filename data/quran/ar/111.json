{
  "n": 111,
  "nameAr": "المسد",
  "nameTr": "Tebbet",
  "ayahCount": 5,
  "ayahs": [
    {
      "n": 1,
      "ar": "تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ"
    },
    {
      "n": 3,
      "ar": "سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ"
    },
    {
      "n": 4,
      "ar": "وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ"
    },
    {
      "n": 5,
      "ar": "فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍۭ"
    }
  ]
}
