{
  "n": 99,
  "nameAr": "الزلزلة",
  "nameTr": "Zilzâl",
  "ayahCount": 8,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا زُلْزِلَتِ الْأَرْضُ زِلْزَالَهَا",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَأَخْرَجَتِ الْأَرْضُ أَثْقَالَهَا"
    },
    {
      "n": 3,
      "ar": "وَقَالَ الْإِنسَانُ مَا لَهَا"
    },
    {
      "n": 4,
      "ar": "يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا"
    },
    {
      "n": 5,
      "ar": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا"
    },
    {
      "n": 6,
      "ar": "يَوْمَئِذٍ يَصْدُرُ النَّاسُ أَشْتَاتًا لِّيُرَوْا أَعْمَالَهُمْ"
    },
    {
      "n": 7,
      "ar": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ"
    },
    {
      "n": 8,
      "ar": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُ"
    }
  ]
}
