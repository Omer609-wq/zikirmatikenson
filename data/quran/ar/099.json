{
  "n": 99,
  "nameAr": "الزلزلة",
  "nameTr": "Zilzâl",
  "ayahCount": 8,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا"
    },
    {
      "n": 3,
      "ar": "وَقَالَ ٱلْإِنسَـٰنُ مَا لَهَا"
    },
    {
      "n": 4,
      "ar": "يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا"
    },
    {
      "n": 5,
      "ar": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا"
    },
    {
      "n": 6,
      "ar": "يَوْمَئِذٍ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًا لِّيُرَوْا۟ أَعْمَـٰلَهُمْ"
    },
    {
      "n": 7,
      "ar": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُۥ"
    },
    {
      "n": 8,
      "ar": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُۥ"
    }
  ]
}
