{
  "n": 88,
  "nameAr": "الغاشية",
  "nameTr": "Gâşiye",
  "ayahCount": 26,
  "ayahs": [
    {
      "n": 1,
      "ar": "هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ"
    },
    {
      "n": 3,
      "ar": "عَامِلَةٌ نَّاصِبَةٌ"
    },
    {
      "n": 4,
      "ar": "تَصْلَىٰ نَارًا حَامِيَةً"
    },
    {
      "n": 5,
      "ar": "تُسْقَىٰ مِنْ عَيْنٍ آنِيَةٍ"
    },
    {
      "n": 6,
      "ar": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ"
    },
    {
      "n": 7,
      "ar": "لَّا يُسْمِنُ وَلَا يُغْنِي مِن جُوعٍ"
    },
    {
      "n": 8,
      "ar": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ"
    },
    {
      "n": 9,
      "ar": "لِّسَعْيِهَا رَاضِيَةٌ"
    },
    {
      "n": 10,
      "ar": "فِي جَنَّةٍ عَالِيَةٍ"
    },
    {
      "n": 11,
      "ar": "لَّا تَسْمَعُ فِيهَا لَاغِيَةً"
    },
    {
      "n": 12,
      "ar": "فِيهَا عَيْنٌ جَارِيَةٌ"
    },
    {
      "n": 13,
      "ar": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ"
    },
    {
      "n": 14,
      "ar": "وَأَكْوَابٌ مَّوْضُوعَةٌ"
    },
    {
      "n": 15,
      "ar": "وَنَمَارِقُ مَصْفُوفَةٌ"
    },
    {
      "n": 16,
      "ar": "وَزَرَابِيُّ مَبْثُوثَةٌ"
    },
    {
      "n": 17,
      "ar": "أَفَلَا يَنظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ"
    },
    {
      "n": 18,
      "ar": "وَإِلَى السَّمَاءِ كَيْفَ رُفِعَتْ"
    },
    {
      "n": 19,
      "ar": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ"
    },
    {
      "n": 20,
      "ar": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ"
    },
    {
      "n": 21,
      "ar": "فَذَكِّرْ إِنَّمَا أَنتَ مُذَكِّرٌ"
    },
    {
      "n": 22,
      "ar": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ"
    },
    {
      "n": 23,
      "ar": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ"
    },
    {
      "n": 24,
      "ar": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ"
    },
    {
      "n": 25,
      "ar": "إِنَّ إِلَيْنَا إِيَابَهُمْ"
    },
    {
      "n": 26,
      "ar": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم"
    }
  ]
}
