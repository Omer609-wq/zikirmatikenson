{
  "n": 88,
  "nameAr": "الغاشية",
  "nameTr": "Gâşiye",
  "ayahCount": 26,
  "ayahs": [
    {
      "n": 1,
      "ar": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ"
    },
    {
      "n": 3,
      "ar": "عَامِلَةٌ نَّاصِبَةٌ"
    },
    {
      "n": 4,
      "ar": "تَصْلَىٰ نَارًا حَامِيَةً"
    },
    {
      "n": 5,
      "ar": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ"
    },
    {
      "n": 6,
      "ar": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ"
    },
    {
      "n": 7,
      "ar": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ"
    },
    {
      "n": 8,
      "ar": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ"
    },
    {
      "n": 9,
      "ar": "لِّسَعْيِهَا رَاضِيَةٌ"
    },
    {
      "n": 10,
      "ar": "فِى جَنَّةٍ عَالِيَةٍ"
    },
    {
      "n": 11,
      "ar": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً"
    },
    {
      "n": 12,
      "ar": "فِيهَا عَيْنٌ جَارِيَةٌ"
    },
    {
      "n": 13,
      "ar": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ"
    },
    {
      "n": 14,
      "ar": "وَأَكْوَابٌ مَّوْضُوعَةٌ"
    },
    {
      "n": 15,
      "ar": "وَنَمَارِقُ مَصْفُوفَةٌ"
    },
    {
      "n": 16,
      "ar": "وَزَرَابِىُّ مَبْثُوثَةٌ"
    },
    {
      "n": 17,
      "ar": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ"
    },
    {
      "n": 18,
      "ar": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ"
    },
    {
      "n": 19,
      "ar": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ"
    },
    {
      "n": 20,
      "ar": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ"
    },
    {
      "n": 21,
      "ar": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ"
    },
    {
      "n": 22,
      "ar": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ"
    },
    {
      "n": 23,
      "ar": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ"
    },
    {
      "n": 24,
      "ar": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ"
    },
    {
      "n": 25,
      "ar": "إِنَّ إِلَيْنَآ إِيَابَهُمْ"
    },
    {
      "n": 26,
      "ar": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم"
    }
  ]
}
