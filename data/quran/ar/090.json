{
  "n": 90,
  "nameAr": "البلد",
  "nameTr": "Beled",
  "ayahCount": 20,
  "ayahs": [
    {
      "n": 1,
      "ar": "لَآ أُقْسِمُ بِهَـٰذَا ٱلْبَلَدِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَأَنتَ حِلٌّۢ بِهَـٰذَا ٱلْبَلَدِ"
    },
    {
      "n": 3,
      "ar": "وَوَالِدٍ وَمَا وَلَدَ"
    },
    {
      "n": 4,
      "ar": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِى كَبَدٍ"
    },
    {
      "n": 5,
      "ar": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ"
    },
    {
      "n": 6,
      "ar": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا"
    },
    {
      "n": 7,
      "ar": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ"
    },
    {
      "n": 8,
      "ar": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ"
    },
    {
      "n": 9,
      "ar": "وَلِسَانًا وَشَفَتَيْنِ"
    },
    {
      "n": 10,
      "ar": "وَهَدَيْنَـٰهُ ٱلنَّجْدَيْنِ"
    },
    {
      "n": 11,
      "ar": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ"
    },
    {
      "n": 12,
      "ar": "وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ"
    },
    {
      "n": 13,
      "ar": "فَكُّ رَقَبَةٍ"
    },
    {
      "n": 14,
      "ar": "أَوْ إِطْعَـٰمٌ فِى يَوْمٍ ذِى مَسْغَبَةٍ"
    },
    {
      "n": 15,
      "ar": "يَتِيمًا ذَا مَقْرَبَةٍ"
    },
    {
      "n": 16,
      "ar": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ"
    },
    {
      "n": 17,
      "ar": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ"
    },
    {
      "n": 18,
      "ar": "أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلْمَيْمَنَةِ"
    },
    {
      "n": 19,
      "ar": "وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَـٰتِنَا هُمْ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ"
    },
    {
      "n": 20,
      "ar": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ"
    }
  ]
}
