{
  "n": 90,
  "nameAr": "البلد",
  "nameTr": "Beled",
  "ayahCount": 20,
  "ayahs": [
    {
      "n": 1,
      "ar": "لَا أُقْسِمُ بِهَـٰذَا الْبَلَدِ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَأَنتَ حِلٌّ بِهَـٰذَا الْبَلَدِ"
    },
    {
      "n": 3,
      "ar": "وَوَالِدٍ وَمَا وَلَدَ"
    },
    {
      "n": 4,
      "ar": "لَقَدْ خَلَقْنَا الْإِنسَانَ فِي كَبَدٍ"
    },
    {
      "n": 5,
      "ar": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ"
    },
    {
      "n": 6,
      "ar": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا"
    },
    {
      "n": 7,
      "ar": "أَيَحْسَبُ أَن لَّمْ يَرَهُ أَحَدٌ"
    },
    {
      "n": 8,
      "ar": "أَلَمْ نَجْعَل لَّهُ عَيْنَيْنِ"
    },
    {
      "n": 9,
      "ar": "وَلِسَانًا وَشَفَتَيْنِ"
    },
    {
      "n": 10,
      "ar": "وَهَدَيْنَاهُ النَّجْدَيْنِ"
    },
    {
      "n": 11,
      "ar": "فَلَا اقْتَحَمَ الْعَقَبَةَ"
    },
    {
      "n": 12,
      "ar": "وَمَا أَدْرَاكَ مَا الْعَقَبَةُ"
    },
    {
      "n": 13,
      "ar": "فَكُّ رَقَبَةٍ"
    },
    {
      "n": 14,
      "ar": "أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ"
    },
    {
      "n": 15,
      "ar": "يَتِيمًا ذَا مَقْرَبَةٍ"
    },
    {
      "n": 16,
      "ar": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ"
    },
    {
      "n": 17,
      "ar": "ثُمَّ كَانَ مِنَ الَّذِينَ آمَنُوا وَتَوَاصَوْا بِالصَّبْرِ وَتَوَاصَوْا بِالْمَرْحَمَةِ"
    },
    {
      "n": 18,
      "ar": "أُولَـٰئِكَ أَصْحَابُ الْمَيْمَنَةِ"
    },
    {
      "n": 19,
      "ar": "وَالَّذِينَ كَفَرُوا بِآيَاتِنَا هُمْ أَصْحَابُ الْمَشْأَمَةِ"
    },
    {
      "n": 20,
      "ar": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌ"
    }
  ]
}
