{
  "n": 107,
  "nameAr": "الماعون",
  "nameTr": "Mâûn",
  "ayahCount": 7,
  "ayahs": [
    {
      "n": 1,
      "ar": "أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "فَذَٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ"
    },
    {
      "n": 3,
      "ar": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ"
    },
    {
      "n": 4,
      "ar": "فَوَيْلٌ لِّلْمُصَلِّينَ"
    },
    {
      "n": 5,
      "ar": "الَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ"
    },
    {
      "n": 6,
      "ar": "الَّذِينَ هُمْ يُرَاءُونَ"
    },
    {
      "n": 7,
      "ar": "وَيَمْنَعُونَ الْمَاعُونَ"
    }
  ]
}
