{
  "n": 84,
  "nameAr": "الإنشقاق",
  "nameTr": "İnşikâk",
  "ayahCount": 25,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"
    },
    {
      "n": 3,
      "ar": "وَإِذَا ٱلْأَرْضُ مُدَّتْ"
    },
    {
      "n": 4,
      "ar": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ"
    },
    {
      "n": 5,
      "ar": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"
    },
    {
      "n": 6,
      "ar": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَـٰقِيهِ"
    },
    {
      "n": 7,
      "ar": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ"
    },
    {
      "n": 8,
      "ar": "فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا"
    },
    {
      "n": 9,
      "ar": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا"
    },
    {
      "n": 10,
      "ar": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ"
    },
    {
      "n": 11,
      "ar": "فَسَوْفَ يَدْعُوا۟ ثُبُورًا"
    },
    {
      "n": 12,
      "ar": "وَيَصْلَىٰ سَعِيرًا"
    },
    {
      "n": 13,
      "ar": "إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا"
    },
    {
      "n": 14,
      "ar": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ"
    },
    {
      "n": 15,
      "ar": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا"
    },
    {
      "n": 16,
      "ar": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ"
    },
    {
      "n": 17,
      "ar": "وَٱلَّيْلِ وَمَا وَسَقَ"
    },
    {
      "n": 18,
      "ar": "وَٱلْقَمَرِ إِذَا ٱتَّسَقَ"
    },
    {
      "n": 19,
      "ar": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ"
    },
    {
      "n": 20,
      "ar": "فَمَا لَهُمْ لَا يُؤْمِنُونَ"
    },
    {
      "n": 21,
      "ar": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩"
    },
    {
      "n": 22,
      "ar": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ"
    },
    {
      "n": 23,
      "ar": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ"
    },
    {
      "n": 24,
      "ar": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ"
    },
    {
      "n": 25,
      "ar": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ"
    }
  ]
}
