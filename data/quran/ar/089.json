{
  "n": 89,
  "nameAr": "الفجر",
  "nameTr": "Fecr",
  "ayahCount": 30,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلْفَجْرِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَلَيَالٍ عَشْرٍ"
    },
    {
      "n": 3,
      "ar": "وَٱلشَّفْعِ وَٱلْوَتْرِ"
    },
    {
      "n": 4,
      "ar": "وَٱلَّيْلِ إِذَا يَسْرِ"
    },
    {
      "n": 5,
      "ar": "هَلْ فِى ذَٰلِكَ قَسَمٌ لِّذِى حِجْرٍ"
    },
    {
      "n": 6,
      "ar": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ"
    },
    {
      "n": 7,
      "ar": "إِرَمَ ذَاتِ ٱلْعِمَادِ"
    },
    {
      "n": 8,
      "ar": "ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَـٰدِ"
    },
    {
      "n": 9,
      "ar": "وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ"
    },
    {
      "n": 10,
      "ar": "وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ"
    },
    {
      "n": 11,
      "ar": "ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَـٰدِ"
    },
    {
      "n": 12,
      "ar": "فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ"
    },
    {
      "n": 13,
      "ar": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ"
    },
    {
      "n": 14,
      "ar": "إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ"
    },
    {
      "n": 15,
      "ar": "فَأَمَّا ٱلْإِنسَـٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ"
    },
    {
      "n": 16,
      "ar": "وَأَمَّآ إِذَا مَا ٱبْتَلَىٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ فَيَقُولُ رَبِّىٓ أَهَـٰنَنِ"
    },
    {
      "n": 17,
      "ar": "كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ"
    },
    {
      "n": 18,
      "ar": "وَلَا تَحَـٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"
    },
    {
      "n": 19,
      "ar": "وَتَأْكُلُونَ ٱلتُّرَاثَ أَكْلًا لَّمًّا"
    },
    {
      "n": 20,
      "ar": "وَتُحِبُّونَ ٱلْمَالَ حُبًّا جَمًّا"
    },
    {
      "n": 21,
      "ar": "كَلَّآ إِذَا دُكَّتِ ٱلْأَرْضُ دَكًّا دَكًّا"
    },
    {
      "n": 22,
      "ar": "وَجَآءَ رَبُّكَ وَٱلْمَلَكُ صَفًّا صَفًّا"
    },
    {
      "n": 23,
      "ar": "وَجِا۟ىٓءَ يَوْمَئِذٍۭ بِجَهَنَّمَ ۚ يَوْمَئِذٍ يَتَذَكَّرُ ٱلْإِنسَـٰنُ وَأَنَّىٰ لَهُ ٱلذِّكْرَىٰ"
    },
    {
      "n": 24,
      "ar": "يَقُولُ يَـٰلَيْتَنِى قَدَّمْتُ لِحَيَاتِى"
    },
    {
      "n": 25,
      "ar": "فَيَوْمَئِذٍ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٌ"
    },
    {
      "n": 26,
      "ar": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٌ"
    },
    {
      "n": 27,
      "ar": "يَـٰٓأَيَّتُهَا ٱلنَّفْسُ ٱلْمُطْمَئِنَّةُ"
    },
    {
      "n": 28,
      "ar": "ٱرْجِعِىٓ إِلَىٰ رَبِّكِ رَاضِيَةً مَّرْضِيَّةً"
    },
    {
      "n": 29,
      "ar": "فَٱدْخُلِى فِى عِبَـٰدِى"
    },
    {
      "n": 30,
      "ar": "وَٱدْخُلِى جَنَّتِى"
    }
  ]
}
