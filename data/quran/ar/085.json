{
  "n": 85,
  "nameAr": "البروج",
  "nameTr": "Burûc",
  "ayahCount": 22,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَٱلْيَوْمِ ٱلْمَوْعُودِ"
    },
    {
      "n": 3,
      "ar": "وَشَاهِدٍ وَمَشْهُودٍ"
    },
    {
      "n": 4,
      "ar": "قُتِلَ أَصْحَـٰبُ ٱلْأُخْدُودِ"
    },
    {
      "n": 5,
      "ar": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ"
    },
    {
      "n": 6,
      "ar": "إِذْ هُمْ عَلَيْهَا قُعُودٌ"
    },
    {
      "n": 7,
      "ar": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ"
    },
    {
      "n": 8,
      "ar": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ"
    },
    {
      "n": 9,
      "ar": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ"
    },
    {
      "n": 10,
      "ar": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَـٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ"
    },
    {
      "n": 11,
      "ar": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ جَنَّـٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ"
    },
    {
      "n": 12,
      "ar": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ"
    },
    {
      "n": 13,
      "ar": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ"
    },
    {
      "n": 14,
      "ar": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ"
    },
    {
      "n": 15,
      "ar": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ"
    },
    {
      "n": 16,
      "ar": "فَعَّالٌ لِّمَا يُرِيدُ"
    },
    {
      "n": 17,
      "ar": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ"
    },
    {
      "n": 18,
      "ar": "فِرْعَوْنَ وَثَمُودَ"
    },
    {
      "n": 19,
      "ar": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ"
    },
    {
      "n": 20,
      "ar": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ"
    },
    {
      "n": 21,
      "ar": "بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ"
    },
    {
      "n": 22,
      "ar": "فِى لَوْحٍ مَّحْفُوظٍۭ"
    }
  ]
}
