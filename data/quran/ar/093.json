{
  "n": 93,
  "nameAr": "الضحى",
  "nameTr": "Duha",
  "ayahCount": 11,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلضُّحَىٰ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَٱلَّيْلِ إِذَا سَجَىٰ"
    },
    {
      "n": 3,
      "ar": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ"
    },
    {
      "n": 4,
      "ar": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ"
    },
    {
      "n": 5,
      "ar": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ"
    },
    {
      "n": 6,
      "ar": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ"
    },
    {
      "n": 7,
      "ar": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ"
    },
    {
      "n": 8,
      "ar": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ"
    },
    {
      "n": 9,
      "ar": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ"
    },
    {
      "n": 10,
      "ar": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ"
    },
    {
      "n": 11,
      "ar": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ"
    }
  ]
}
