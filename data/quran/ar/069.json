{
  "n": 69,
  "nameAr": "الحاقة",
  "nameTr": "Hâkka",
  "ayahCount": 52,
  "ayahs": [
    {
      "n": 1,
      "ar": "ٱلْحَآقَّةُ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "مَا ٱلْحَآقَّةُ"
    },
    {
      "n": 3,
      "ar": "وَمَآ أَدْرَىٰكَ مَا ٱلْحَآقَّةُ"
    },
    {
      "n": 4,
      "ar": "كَذَّبَتْ ثَمُودُ وَعَادٌۢ بِٱلْقَارِعَةِ"
    },
    {
      "n": 5,
      "ar": "فَأَمَّا ثَمُودُ فَأُهْلِكُوا۟ بِٱلطَّاغِيَةِ"
    },
    {
      "n": 6,
      "ar": "وَأَمَّا عَادٌ فَأُهْلِكُوا۟ بِرِيحٍ صَرْصَرٍ عَاتِيَةٍ"
    },
    {
      "n": 7,
      "ar": "سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٍ وَثَمَـٰنِيَةَ أَيَّامٍ حُسُومًا فَتَرَى ٱلْقَوْمَ فِيهَا صَرْعَىٰ كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ"
    },
    {
      "n": 8,
      "ar": "فَهَلْ تَرَىٰ لَهُم مِّنۢ بَاقِيَةٍ"
    },
    {
      "n": 9,
      "ar": "وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَٱلْمُؤْتَفِكَـٰتُ بِٱلْخَاطِئَةِ"
    },
    {
      "n": 10,
      "ar": "فَعَصَوْا۟ رَسُولَ رَبِّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً"
    },
    {
      "n": 11,
      "ar": "إِنَّا لَمَّا طَغَا ٱلْمَآءُ حَمَلْنَـٰكُمْ فِى ٱلْجَارِيَةِ"
    },
    {
      "n": 12,
      "ar": "لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَتَعِيَهَآ أُذُنٌ وَٰعِيَةٌ"
    },
    {
      "n": 13,
      "ar": "فَإِذَا نُفِخَ فِى ٱلصُّورِ نَفْخَةٌ وَٰحِدَةٌ"
    },
    {
      "n": 14,
      "ar": "وَحُمِلَتِ ٱلْأَرْضُ وَٱلْجِبَالُ فَدُكَّتَا دَكَّةً وَٰحِدَةً"
    },
    {
      "n": 15,
      "ar": "فَيَوْمَئِذٍ وَقَعَتِ ٱلْوَاقِعَةُ"
    },
    {
      "n": 16,
      "ar": "وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِىَ يَوْمَئِذٍ وَاهِيَةٌ"
    },
    {
      "n": 17,
      "ar": "وَٱلْمَلَكُ عَلَىٰٓ أَرْجَآئِهَا ۚ وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمَـٰنِيَةٌ"
    },
    {
      "n": 18,
      "ar": "يَوْمَئِذٍ تُعْرَضُونَ لَا تَخْفَىٰ مِنكُمْ خَافِيَةٌ"
    },
    {
      "n": 19,
      "ar": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقْرَءُوا۟ كِتَـٰبِيَهْ"
    },
    {
      "n": 20,
      "ar": "إِنِّى ظَنَنتُ أَنِّى مُلَـٰقٍ حِسَابِيَهْ"
    },
    {
      "n": 21,
      "ar": "فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ"
    },
    {
      "n": 22,
      "ar": "فِى جَنَّةٍ عَالِيَةٍ"
    },
    {
      "n": 23,
      "ar": "قُطُوفُهَا دَانِيَةٌ"
    },
    {
      "n": 24,
      "ar": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَآ أَسْلَفْتُمْ فِى ٱلْأَيَّامِ ٱلْخَالِيَةِ"
    },
    {
      "n": 25,
      "ar": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِشِمَالِهِۦ فَيَقُولُ يَـٰلَيْتَنِى لَمْ أُوتَ كِتَـٰبِيَهْ"
    },
    {
      "n": 26,
      "ar": "وَلَمْ أَدْرِ مَا حِسَابِيَهْ"
    },
    {
      "n": 27,
      "ar": "يَـٰلَيْتَهَا كَانَتِ ٱلْقَاضِيَةَ"
    },
    {
      "n": 28,
      "ar": "مَآ أَغْنَىٰ عَنِّى مَالِيَهْ ۜ"
    },
    {
      "n": 29,
      "ar": "هَلَكَ عَنِّى سُلْطَـٰنِيَهْ"
    },
    {
      "n": 30,
      "ar": "خُذُوهُ فَغُلُّوهُ"
    },
    {
      "n": 31,
      "ar": "ثُمَّ ٱلْجَحِيمَ صَلُّوهُ"
    },
    {
      "n": 32,
      "ar": "ثُمَّ فِى سِلْسِلَةٍ ذَرْعُهَا سَبْعُونَ ذِرَاعًا فَٱسْلُكُوهُ"
    },
    {
      "n": 33,
      "ar": "إِنَّهُۥ كَانَ لَا يُؤْمِنُ بِٱللَّهِ ٱلْعَظِيمِ"
    },
    {
      "n": 34,
      "ar": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"
    },
    {
      "n": 35,
      "ar": "فَلَيْسَ لَهُ ٱلْيَوْمَ هَـٰهُنَا حَمِيمٌ"
    },
    {
      "n": 36,
      "ar": "وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ"
    },
    {
      "n": 37,
      "ar": "لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَـٰطِـُٔونَ"
    },
    {
      "n": 38,
      "ar": "فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ"
    },
    {
      "n": 39,
      "ar": "وَمَا لَا تُبْصِرُونَ"
    },
    {
      "n": 40,
      "ar": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"
    },
    {
      "n": 41,
      "ar": "وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَّا تُؤْمِنُونَ"
    },
    {
      "n": 42,
      "ar": "وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَّا تَذَكَّرُونَ"
    },
    {
      "n": 43,
      "ar": "تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "n": 44,
      "ar": "وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ"
    },
    {
      "n": 45,
      "ar": "لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ"
    },
    {
      "n": 46,
      "ar": "ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ"
    },
    {
      "n": 47,
      "ar": "فَمَا مِنكُم مِّنْ أَحَدٍ عَنْهُ حَـٰجِزِينَ"
    },
    {
      "n": 48,
      "ar": "وَإِنَّهُۥ لَتَذْكِرَةٌ لِّلْمُتَّقِينَ"
    },
    {
      "n": 49,
      "ar": "وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ"
    },
    {
      "n": 50,
      "ar": "وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَـٰفِرِينَ"
    },
    {
      "n": 51,
      "ar": "وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ"
    },
    {
      "n": 52,
      "ar": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"
    }
  ]
}
