{
  "n": 114,
  "nameAr": "الناس",
  "nameTr": "Nâs",
  "ayahCount": 6,
  "ayahs": [
    {
      "n": 1,
      "ar": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "مَلِكِ النَّاسِ"
    },
    {
      "n": 3,
      "ar": "إِلَـٰهِ النَّاسِ"
    },
    {
      "n": 4,
      "ar": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ"
    },
    {
      "n": 5,
      "ar": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ"
    },
    {
      "n": 6,
      "ar": "مِنَ الْجِنَّةِ وَالنَّاسِ"
    }
  ]
}
