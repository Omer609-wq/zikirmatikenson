{
  "n": 81,
  "nameAr": "التكوير",
  "nameTr": "Tekvîr",
  "ayahCount": 29,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا ٱلشَّمْسُ كُوِّرَتْ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ"
    },
    {
      "n": 3,
      "ar": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ"
    },
    {
      "n": 4,
      "ar": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ"
    },
    {
      "n": 5,
      "ar": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ"
    },
    {
      "n": 6,
      "ar": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ"
    },
    {
      "n": 7,
      "ar": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ"
    },
    {
      "n": 8,
      "ar": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ"
    },
    {
      "n": 9,
      "ar": "بِأَىِّ ذَنۢبٍ قُتِلَتْ"
    },
    {
      "n": 10,
      "ar": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ"
    },
    {
      "n": 11,
      "ar": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ"
    },
    {
      "n": 12,
      "ar": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ"
    },
    {
      "n": 13,
      "ar": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ"
    },
    {
      "n": 14,
      "ar": "عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ"
    },
    {
      "n": 15,
      "ar": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ"
    },
    {
      "n": 16,
      "ar": "ٱلْجَوَارِ ٱلْكُنَّسِ"
    },
    {
      "n": 17,
      "ar": "وَٱلَّيْلِ إِذَا عَسْعَسَ"
    },
    {
      "n": 18,
      "ar": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ"
    },
    {
      "n": 19,
      "ar": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"
    },
    {
      "n": 20,
      "ar": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ"
    },
    {
      "n": 21,
      "ar": "مُّطَاعٍ ثَمَّ أَمِينٍ"
    },
    {
      "n": 22,
      "ar": "وَمَا صَاحِبُكُم بِمَجْنُونٍ"
    },
    {
      "n": 23,
      "ar": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ"
    },
    {
      "n": 24,
      "ar": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ"
    },
    {
      "n": 25,
      "ar": "وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ"
    },
    {
      "n": 26,
      "ar": "فَأَيْنَ تَذْهَبُونَ"
    },
    {
      "n": 27,
      "ar": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ"
    },
    {
      "n": 28,
      "ar": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ"
    },
    {
      "n": 29,
      "ar": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ"
    }
  ]
}
