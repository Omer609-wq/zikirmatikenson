{
  "n": 75,
  "nameAr": "القيامة",
  "nameTr": "Kıyâmet",
  "ayahCount": 40,
  "ayahs": [
    {
      "n": 1,
      "ar": "لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَـٰمَةِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ"
    },
    {
      "n": 3,
      "ar": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ"
    },
    {
      "n": 4,
      "ar": "بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ"
    },
    {
      "n": 5,
      "ar": "بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ"
    },
    {
      "n": 6,
      "ar": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ"
    },
    {
      "n": 7,
      "ar": "فَإِذَا بَرِقَ ٱلْبَصَرُ"
    },
    {
      "n": 8,
      "ar": "وَخَسَفَ ٱلْقَمَرُ"
    },
    {
      "n": 9,
      "ar": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ"
    },
    {
      "n": 10,
      "ar": "يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ"
    },
    {
      "n": 11,
      "ar": "كَلَّا لَا وَزَرَ"
    },
    {
      "n": 12,
      "ar": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ"
    },
    {
      "n": 13,
      "ar": "يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ"
    },
    {
      "n": 14,
      "ar": "بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ"
    },
    {
      "n": 15,
      "ar": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ"
    },
    {
      "n": 16,
      "ar": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ"
    },
    {
      "n": 17,
      "ar": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ"
    },
    {
      "n": 18,
      "ar": "فَإِذَا قَرَأْنَـٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ"
    },
    {
      "n": 19,
      "ar": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ"
    },
    {
      "n": 20,
      "ar": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ"
    },
    {
      "n": 21,
      "ar": "وَتَذَرُونَ ٱلْـَٔاخِرَةَ"
    },
    {
      "n": 22,
      "ar": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ"
    },
    {
      "n": 23,
      "ar": "إِلَىٰ رَبِّهَا نَاظِرَةٌ"
    },
    {
      "n": 24,
      "ar": "وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ"
    },
    {
      "n": 25,
      "ar": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ"
    },
    {
      "n": 26,
      "ar": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ"
    },
    {
      "n": 27,
      "ar": "وَقِيلَ مَنْ ۜ رَاقٍ"
    },
    {
      "n": 28,
      "ar": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ"
    },
    {
      "n": 29,
      "ar": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ"
    },
    {
      "n": 30,
      "ar": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ"
    },
    {
      "n": 31,
      "ar": "فَلَا صَدَّقَ وَلَا صَلَّىٰ"
    },
    {
      "n": 32,
      "ar": "وَلَـٰكِن كَذَّبَ وَتَوَلَّىٰ"
    },
    {
      "n": 33,
      "ar": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ"
    },
    {
      "n": 34,
      "ar": "أَوْلَىٰ لَكَ فَأَوْلَىٰ"
    },
    {
      "n": 35,
      "ar": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ"
    },
    {
      "n": 36,
      "ar": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَن يُتْرَكَ سُدًى"
    },
    {
      "n": 37,
      "ar": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِىٍّ يُمْنَىٰ"
    },
    {
      "n": 38,
      "ar": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ"
    },
    {
      "n": 39,
      "ar": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ"
    },
    {
      "n": 40,
      "ar": "أَلَيْسَ ذَٰلِكَ بِقَـٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ"
    }
  ]
}
