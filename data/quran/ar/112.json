{
  "n": 112,
  "nameAr": "الإخلاص",
  "nameTr": "İhlâs",
  "ayahCount": 4,
  "ayahs": [
    {
      "n": 1,
      "ar": "قُلْ هُوَ ٱللَّهُ أَحَدٌ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "ٱللَّهُ ٱلصَّمَدُ"
    },
    {
      "n": 3,
      "ar": "لَمْ يَلِدْ وَلَمْ يُولَدْ"
    },
    {
      "n": 4,
      "ar": "وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ"
    }
  ]
