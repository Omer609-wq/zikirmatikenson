{
  "n": 80,
  "nameAr": "عبس",
  "nameTr": "Abese",
  "ayahCount": 42,
  "ayahs": [
    {
      "n": 1,
      "ar": "عَبَسَ وَتَوَلَّىٰ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "أَن جَاءَهُ الْأَعْمَىٰ"
    },
    {
      "n": 3,
      "ar": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ"
    },
    {
      "n": 4,
      "ar": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ الذِّكْرَىٰ"
    },
    {
      "n": 5,
      "ar": "أَمَّا مَنِ اسْتَغْنَىٰ"
    },
    {
      "n": 6,
      "ar": "فَأَنتَ لَهُ تَصَدَّىٰ"
    },
    {
      "n": 7,
      "ar": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ"
    },
    {
      "n": 8,
      "ar": "وَأَمَّا مَن جَاءَكَ يَسْعَىٰ"
    },
    {
      "n": 9,
      "ar": "وَهُوَ يَخْشَىٰ"
    },
    {
      "n": 10,
      "ar": "فَأَنتَ عَنْهُ تَلَهَّىٰ"
    },
    {
      "n": 11,
      "ar": "كَلَّا إِنَّهَا تَذْكِرَةٌ"
    },
    {
      "n": 12,
      "ar": "فَمَن شَاءَ ذَكَرَهُ"
    },
    {
      "n": 13,
      "ar": "فِي صُحُفٍ مُّكَرَّمَةٍ"
    },
    {
      "n": 14,
      "ar": "مَّرْفُوعَةٍ مُّطَهَّرَةٍ"
    },
    {
      "n": 15,
      "ar": "بِأَيْدِي سَفَرَةٍ"
    },
    {
      "n": 16,
      "ar": "كِرَامٍ بَرَرَةٍ"
    },
    {
      "n": 17,
      "ar": "قُتِلَ الْإِنسَانُ مَا أَكْفَرَهُ"
    },
    {
      "n": 18,
      "ar": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ"
    },
    {
      "n": 19,
      "ar": "مِن نُّطْفَةٍ خَلَقَهُ فَقَدَّرَهُ"
    },
    {
      "n": 20,
      "ar": "ثُمَّ السَّبِيلَ يَسَّرَهُ"
    },
    {
      "n": 21,
      "ar": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ"
    },
    {
      "n": 22,
      "ar": "ثُمَّ إِذَا شَاءَ أَنشَرَهُ"
    },
    {
      "n": 23,
      "ar": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ"
    },
    {
      "n": 24,
      "ar": "فَلْيَنظُرِ الْإِنسَانُ إِلَىٰ طَعَامِهِ"
    },
    {
      "n": 25,
      "ar": "أَنَّا صَبَبْنَا الْمَاءَ صَبًّا"
    },
    {
      "n": 26,
      "ar": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا"
    },
    {
      "n": 27,
      "ar": "فَأَنبَتْنَا فِيهَا حَبًّا"
    },
    {
      "n": 28,
      "ar": "وَعِنَبًا وَقَضْبًا"
    },
    {
      "n": 29,
      "ar": "وَزَيْتُونًا وَنَخْلًا"
    },
    {
      "n": 30,
      "ar": "وَحَدَائِقَ غُلْبًا"
    },
    {
      "n": 31,
      "ar": "وَفَاكِهَةً وَأَبًّا"
    },
    {
      "n": 32,
      "ar": "مَّتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ"
    },
    {
      "n": 33,
      "ar": "فَإِذَا جَاءَتِ الصَّاخَّةُ"
    },
    {
      "n": 34,
      "ar": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ"
    },
    {
      "n": 35,
      "ar": "وَأُمِّهِ وَأَبِيهِ"
    },
    {
      "n": 36,
      "ar": "وَصَاحِبَتِهِ وَبَنِيهِ"
    },
    {
      "n": 37,
      "ar": "لِكُلِّ امْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ"
    },
    {
      "n": 38,
      "ar": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ"
    },
    {
      "n": 39,
      "ar": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ"
    },
    {
      "n": 40,
      "ar": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ"
    },
    {
      "n": 41,
      "ar": "تَرْهَقُهَا قَتَرَةٌ"
    },
    {
      "n": 42,
      "ar": "أُولَـٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ"
    }
  ]
}
