{
  "n": 80,
  "nameAr": "عبس",
  "nameTr": "Abese",
  "ayahCount": 42,
  "ayahs": [
    {
      "n": 1,
      "ar": "عَبَسَ وَتَوَلَّىٰٓ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "أَن جَآءَهُ ٱلْأَعْمَىٰ"
    },
    {
      "n": 3,
      "ar": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ"
    },
    {
      "n": 4,
      "ar": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ"
    },
    {
      "n": 5,
      "ar": "أَمَّا مَنِ ٱسْتَغْنَىٰ"
    },
    {
      "n": 6,
      "ar": "فَأَنتَ لَهُۥ تَصَدَّىٰ"
    },
    {
      "n": 7,
      "ar": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ"
    },
    {
      "n": 8,
      "ar": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ"
    },
    {
      "n": 9,
      "ar": "وَهُوَ يَخْشَىٰ"
    },
    {
      "n": 10,
      "ar": "فَأَنتَ عَنْهُ تَلَهَّىٰ"
    },
    {
      "n": 11,
      "ar": "كَلَّآ إِنَّهَا تَذْكِرَةٌ"
    },
    {
      "n": 12,
      "ar": "فَمَن شَآءَ ذَكَرَهُۥ"
    },
    {
      "n": 13,
      "ar": "فِى صُحُفٍ مُّكَرَّمَةٍ"
    },
    {
      "n": 14,
      "ar": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ"
    },
    {
      "n": 15,
      "ar": "بِأَيْدِى سَفَرَةٍ"
    },
    {
      "n": 16,
      "ar": "كِرَامٍۭ بَرَرَةٍ"
    },
    {
      "n": 17,
      "ar": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ"
    },
    {
      "n": 18,
      "ar": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ"
    },
    {
      "n": 19,
      "ar": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ"
    },
    {
      "n": 20,
      "ar": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ"
    },
    {
      "n": 21,
      "ar": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ"
    },
    {
      "n": 22,
      "ar": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ"
    },
    {
      "n": 23,
      "ar": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ"
    },
    {
      "n": 24,
      "ar": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ"
    },
    {
      "n": 25,
      "ar": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا"
    },
    {
      "n": 26,
      "ar": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا"
    },
    {
      "n": 27,
      "ar": "فَأَنۢبَتْنَا فِيهَا حَبًّا"
    },
    {
      "n": 28,
      "ar": "وَعِنَبًا وَقَضْبًا"
    },
    {
      "n": 29,
      "ar": "وَزَيْتُونًا وَنَخْلًا"
    },
    {
      "n": 30,
      "ar": "وَحَدَآئِقَ غُلْبًا"
    },
    {
      "n": 31,
      "ar": "وَفَـٰكِهَةً وَأَبًّا"
    },
    {
      "n": 32,
      "ar": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ"
    },
    {
      "n": 33,
      "ar": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ"
    },
    {
      "n": 34,
      "ar": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ"
    },
    {
      "n": 35,
      "ar": "وَأُمِّهِۦ وَأَبِيهِ"
    },
    {
      "n": 36,
      "ar": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ"
    },
    {
      "n": 37,
      "ar": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ"
    },
    {
      "n": 38,
      "ar": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ"
    },
    {
      "n": 39,
      "ar": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ"
    },
    {
      "n": 40,
      "ar": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ"
    },
    {
      "n": 41,
      "ar": "تَرْهَقُهَا قَتَرَةٌ"
    },
    {
      "n": 42,
      "ar": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ"
    }
  ]
}
