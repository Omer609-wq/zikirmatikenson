{
  "n": 82,
  "nameAr": "الإنفطار",
  "nameTr": "İnfitâr",
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا السَّمَاءُ انفَطَرَتْ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَإِذَا الْكَوَاكِبُ انتَثَرَتْ"
    },
    {
      "n": 3,
      "ar": "وَإِذَا الْبِحَارُ فُجِّرَتْ"
    },
    {
      "n": 4,
      "ar": "وَإِذَا الْقُبُورُ بُعْثِرَتْ"
    },
    {
      "n": 5,
      "ar": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ"
    },
    {
      "n": 6,
      "ar": "يَا أَيُّهَا الْإِنسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ"
    },
    {
      "n": 7,
      "ar": "الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ"
    },
    {
      "n": 8,
      "ar": "فِي أَيِّ صُورَةٍ مَّا شَاءَ رَكَّبَكَ"
    },
    {
      "n": 9,
      "ar": "كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ"
    },
    {
      "n": 10,
      "ar": "وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ"
    },
    {
      "n": 11,
      "ar": "كِرَامًا كَاتِبِينَ"
    },
    {
      "n": 12,
      "ar": "يَعْلَمُونَ مَا تَفْعَلُونَ"
    },
    {
      "n": 13,
      "ar": "إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ"
    },
    {
      "n": 14,
      "ar": "وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ"
    },
    {
      "n": 15,
      "ar": "يَصْلَوْنَهَا يَوْمَ الدِّينِ"
    },
    {
      "n": 16,
      "ar": "وَمَا هُمْ عَنْهَا بِغَائِبِينَ"
    },
    {
      "n": 17,
      "ar": "وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"
    },
    {
      "n": 18,
      "ar": "ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"
    },
    {
      "n": 19,
      "ar": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْئًا ۖ وَالْأَمْرُ يَوْمَئِذٍ لِّلَّهِ"
    }
  ]
}
