{
  "n": 82,
  "nameAr": "الإنفطار",
  "nameTr": "İnfitâr",
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ"
    },
    {
      "n": 3,
      "ar": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ"
    },
    {
      "n": 4,
      "ar": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ"
    },
    {
      "n": 5,
      "ar": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ"
    },
    {
      "n": 6,
      "ar": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ"
    },
    {
      "n": 7,
      "ar": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ"
    },
    {
      "n": 8,
      "ar": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ"
    },
    {
      "n": 9,
      "ar": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ"
    },
    {
      "n": 10,
      "ar": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ"
    },
    {
      "n": 11,
      "ar": "كِرَامًا كَـٰتِبِينَ"
    },
    {
      "n": 12,
      "ar": "يَعْلَمُونَ مَا تَفْعَلُونَ"
    },
    {
      "n": 13,
      "ar": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ"
    },
    {
      "n": 14,
      "ar": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ"
    },
    {
      "n": 15,
      "ar": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ"
    },
    {
      "n": 16,
      "ar": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ"
    },
    {
      "n": 17,
      "ar": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ"
    },
    {
      "n": 18,
      "ar": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ"
    },
    {
      "n": 19,
      "ar": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍ لِّلَّهِ"
    }
  ]
}
