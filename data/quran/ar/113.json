{
  "n": 113,
  "nameAr": "الفلق",
  "nameTr": "Felak",
  "ayahCount": 5,
  "ayahs": [
    {
      "n": 1,
      "ar": "قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "مِن شَرِّ مَا خَلَقَ"
    },
    {
      "n": 3,
      "ar": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ"
    },
    {
      "n": 4,
      "ar": "وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ"
    },
    {
      "n": 5,
      "ar": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"
    }
  ]
}
