{
  "n": 83,
  "nameAr": "المطففين",
  "nameTr": "Mutaffifîn",
  "ayahCount": 36,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَيْلٌ لِّلْمُطَفِّفِينَ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ"
    },
    {
      "n": 3,
      "ar": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ"
    },
    {
      "n": 4,
      "ar": "أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ"
    },
    {
      "n": 5,
      "ar": "لِيَوْمٍ عَظِيمٍ"
    },
    {
      "n": 6,
      "ar": "يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "n": 7,
      "ar": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ"
    },
    {
      "n": 8,
      "ar": "وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ"
    },
    {
      "n": 9,
      "ar": "كِتَـٰبٌ مَّرْقُومٌ"
    },
    {
      "n": 10,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 11,
      "ar": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ"
    },
    {
      "n": 12,
      "ar": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ"
    },
    {
      "n": 13,
      "ar": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ"
    },
    {
      "n": 14,
      "ar": "كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ"
    },
    {
      "n": 15,
      "ar": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ"
    },
    {
      "n": 16,
      "ar": "ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ"
    },
    {
      "n": 17,
      "ar": "ثُمَّ يُقَالُ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ"
    },
    {
      "n": 18,
      "ar": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ"
    },
    {
      "n": 19,
      "ar": "وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ"
    },
    {
      "n": 20,
      "ar": "كِتَـٰبٌ مَّرْقُومٌ"
    },
    {
      "n": 21,
      "ar": "يَشْهَدُهُ ٱلْمُقَرَّبُونَ"
    },
    {
      "n": 22,
      "ar": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ"
    },
    {
      "n": 23,
      "ar": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ"
    },
    {
      "n": 24,
      "ar": "تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ"
    },
    {
      "n": 25,
      "ar": "يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ"
    },
    {
      "n": 26,
      "ar": "خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ"
    },
    {
      "n": 27,
      "ar": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ"
    },
    {
      "n": 28,
      "ar": "عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ"
    },
    {
      "n": 29,
      "ar": "إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ"
    },
    {
      "n": 30,
      "ar": "وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ"
    },
    {
      "n": 31,
      "ar": "وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ"
    },
    {
      "n": 32,
      "ar": "وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَـٰٓؤُلَآءِ لَضَآلُّونَ"
    },
    {
      "n": 33,
      "ar": "وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَـٰفِظِينَ"
    },
    {
      "n": 34,
      "ar": "فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ"
    },
    {
      "n": 35,
      "ar": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ"
    },
    {
      "n": 36,
      "ar": "هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ"
    }
  ]
}
