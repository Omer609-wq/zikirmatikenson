{
  "n": 56,
  "nameAr": "الواقعة",
  "nameTr": "Vâkıa",
  "ayahCount": 96,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِذَا وَقَعَتِ ٱلْوَاقِعَةُ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ"
    },
    {
      "n": 3,
      "ar": "خَافِضَةٌ رَّافِعَةٌ"
    },
    {
      "n": 4,
      "ar": "إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّا"
    },
    {
      "n": 5,
      "ar": "وَبُسَّتِ ٱلْجِبَالُ بَسًّا"
    },
    {
      "n": 6,
      "ar": "فَكَانَتْ هَبَآءً مُّنۢبَثًّا"
    },
    {
      "n": 7,
      "ar": "وَكُنتُمْ أَزْوَٰجًا ثَلَـٰثَةً"
    },
    {
      "n": 8,
      "ar": "فَأَصْحَـٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَـٰبُ ٱلْمَيْمَنَةِ"
    },
    {
      "n": 9,
      "ar": "وَأَصْحَـٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ"
    },
    {
      "n": 10,
      "ar": "وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ"
    },
    {
      "n": 11,
      "ar": "أُو۟لَـٰٓئِكَ ٱلْمُقَرَّبُونَ"
    },
    {
      "n": 12,
      "ar": "فِى جَنَّـٰتِ ٱلنَّعِيمِ"
    },
    {
      "n": 13,
      "ar": "ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ"
    },
    {
      "n": 14,
      "ar": "وَقَلِيلٌ مِّنَ ٱلْـَٔاخِرِينَ"
    },
    {
      "n": 15,
      "ar": "عَلَىٰ سُرُرٍ مَّوْضُونَةٍ"
    },
    {
      "n": 16,
      "ar": "مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَـٰبِلِينَ"
    },
    {
      "n": 17,
      "ar": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌ مُّخَلَّدُونَ"
    },
    {
      "n": 18,
      "ar": "بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِّن مَّعِينٍ"
    },
    {
      "n": 19,
      "ar": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ"
    },
    {
      "n": 20,
      "ar": "وَفَـٰكِهَةٍ مِّمَّا يَتَخَيَّرُونَ"
    },
    {
      "n": 21,
      "ar": "وَلَحْمِ طَيْرٍ مِّمَّا يَشْتَهُونَ"
    },
    {
      "n": 22,
      "ar": "وَحُورٌ عِينٌ"
    },
    {
      "n": 23,
      "ar": "كَأَمْثَـٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ"
    },
    {
      "n": 24,
      "ar": "جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ"
    },
    {
      "n": 25,
      "ar": "لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا"
    },
    {
      "n": 26,
      "ar": "إِلَّا قِيلًا سَلَـٰمًا سَلَـٰمًا"
    },
    {
      "n": 27,
      "ar": "وَأَصْحَـٰبُ ٱلْيَمِينِ مَآ أَصْحَـٰبُ ٱلْيَمِينِ"
    },
    {
      "n": 28,
      "ar": "فِى سِدْرٍ مَّخْضُودٍ"
    },
    {
      "n": 29,
      "ar": "وَطَلْحٍ مَّنضُودٍ"
    },
    {
      "n": 30,
      "ar": "وَظِلٍّ مَّمْدُودٍ"
    },
    {
      "n": 31,
      "ar": "وَمَآءٍ مَّسْكُوبٍ"
    },
    {
      "n": 32,
      "ar": "وَفَـٰكِهَةٍ كَثِيرَةٍ"
    },
    {
      "n": 33,
      "ar": "لَّا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ"
    },
    {
      "n": 34,
      "ar": "وَفُرُشٍ مَّرْفُوعَةٍ"
    },
    {
      "n": 35,
      "ar": "إِنَّآ أَنشَأْنَـٰهُنَّ إِنشَآءً"
    },
    {
      "n": 36,
      "ar": "فَجَعَلْنَـٰهُنَّ أَبْكَارًا"
    },
    {
      "n": 37,
      "ar": "عُرُبًا أَتْرَابًا"
    },
    {
      "n": 38,
      "ar": "لِّأَصْحَـٰبِ ٱلْيَمِينِ"
    },
    {
      "n": 39,
      "ar": "ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ"
    },
    {
      "n": 40,
      "ar": "وَثُلَّةٌ مِّنَ ٱلْـَٔاخِرِينَ"
    },
    {
      "n": 41,
      "ar": "وَأَصْحَـٰبُ ٱلشِّمَالِ مَآ أَصْحَـٰبُ ٱلشِّمَالِ"
    },
    {
      "n": 42,
      "ar": "فِى سَمُومٍ وَحَمِيمٍ"
    },
    {
      "n": 43,
      "ar": "وَظِلٍّ مِّن يَحْمُومٍ"
    },
    {
      "n": 44,
      "ar": "لَّا بَارِدٍ وَلَا كَرِيمٍ"
    },
    {
      "n": 45,
      "ar": "إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ"
    },
    {
      "n": 46,
      "ar": "وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ"
    },
    {
      "n": 47,
      "ar": "وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَبْعُوثُونَ"
    },
    {
      "n": 48,
      "ar": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ"
    },
    {
      "n": 49,
      "ar": "قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْـَٔاخِرِينَ"
    },
    {
      "n": 50,
      "ar": "لَمَجْمُوعُونَ إِلَىٰ مِيقَـٰتِ يَوْمٍ مَّعْلُومٍ"
    },
    {
      "n": 51,
      "ar": "ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ"
    },
    {
      "n": 52,
      "ar": "لَـَٔاكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ"
    },
    {
      "n": 53,
      "ar": "فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ"
    },
    {
      "n": 54,
      "ar": "فَشَـٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ"
    },
    {
      "n": 55,
      "ar": "فَشَـٰرِبُونَ شُرْبَ ٱلْهِيمِ"
    },
    {
      "n": 56,
      "ar": "هَـٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ"
    },
    {
      "n": 57,
      "ar": "نَحْنُ خَلَقْنَـٰكُمْ فَلَوْلَا تُصَدِّقُونَ"
    },
    {
      "n": 58,
      "ar": "أَفَرَءَيْتُم مَّا تُمْنُونَ"
    },
    {
      "n": 59,
      "ar": "ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَـٰلِقُونَ"
    },
    {
      "n": 60,
      "ar": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ"
    },
    {
      "n": 61,
      "ar": "عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَـٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ"
    },
    {
      "n": 62,
      "ar": "وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ"
    },
    {
      "n": 63,
      "ar": "أَفَرَءَيْتُم مَّا تَحْرُثُونَ"
    },
    {
      "n": 64,
      "ar": "ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ"
    },
    {
      "n": 65,
      "ar": "لَوْ نَشَآءُ لَجَعَلْنَـٰهُ حُطَـٰمًا فَظَلْتُمْ تَفَكَّهُونَ"
    },
    {
      "n": 66,
      "ar": "إِنَّا لَمُغْرَمُونَ"
    },
    {
      "n": 67,
      "ar": "بَلْ نَحْنُ مَحْرُومُونَ"
    },
    {
      "n": 68,
      "ar": "أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ"
    },
    {
      "n": 69,
      "ar": "ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ"
    },
    {
      "n": 70,
      "ar": "لَوْ نَشَآءُ جَعَلْنَـٰهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ"
    },
    {
      "n": 71,
      "ar": "أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ"
    },
    {
      "n": 72,
      "ar": "ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ"
    },
    {
      "n": 73,
      "ar": "نَحْنُ جَعَلْنَـٰهَا تَذْكِرَةً وَمَتَـٰعًا لِّلْمُقْوِينَ"
    },
    {
      "n": 74,
      "ar": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"
    },
    {
      "n": 75,
      "ar": "فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ"
    },
    {
      "n": 76,
      "ar": "وَإِنَّهُۥ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ"
    },
    {
      "n": 77,
      "ar": "إِنَّهُۥ لَقُرْءَانٌ كَرِيمٌ"
    },
    {
      "n": 78,
      "ar": "فِى كِتَـٰبٍ مَّكْنُونٍ"
    },
    {
      "n": 79,
      "ar": "لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ"
    },
    {
      "n": 80,
      "ar": "تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "n": 81,
      "ar": "أَفَبِهَـٰذَا ٱلْحَدِيثِ أَنتُم مُّدْهِنُونَ"
    },
    {
      "n": 82,
      "ar": "وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ"
    },
    {
      "n": 83,
      "ar": "فَلَوْلَآ إِذَا بَلَغَتِ ٱلْحُلْقُومَ"
    },
    {
      "n": 84,
      "ar": "وَأَنتُمْ حِينَئِذٍ تَنظُرُونَ"
    },
    {
      "n": 85,
      "ar": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَـٰكِن لَّا تُبْصِرُونَ"
    },
    {
      "n": 86,
      "ar": "فَلَوْلَآ إِن كُنتُمْ غَيْرَ مَدِينِينَ"
    },
    {
      "n": 87,
      "ar": "تَرْجِعُونَهَآ إِن كُنتُمْ صَـٰدِقِينَ"
    },
    {
      "n": 88,
      "ar": "فَأَمَّآ إِن كَانَ مِنَ ٱلْمُقَرَّبِينَ"
    },
    {
      "n": 89,
      "ar": "فَرَوْحٌ وَرَيْحَانٌ وَجَنَّتُ نَعِيمٍ"
    },
    {
      "n": 90,
      "ar": "وَأَمَّآ إِن كَانَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ"
    },
    {
      "n": 91,
      "ar": "فَسَلَـٰمٌ لَّكَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ"
    },
    {
      "n": 92,
      "ar": "وَأَمَّآ إِن كَانَ مِنَ ٱلْمُكَذِّبِينَ ٱلضَّآلِّينَ"
    },
    {
      "n": 93,
      "ar": "فَنُزُلٌ مِّنْ حَمِيمٍ"
    },
    {
      "n": 94,
      "ar": "وَتَصْلِيَةُ جَحِيمٍ"
    },
    {
      "n": 95,
      "ar": "إِنَّ هَـٰذَا لَهُوَ حَقُّ ٱلْيَقِينِ"
    },
    {
      "n": 96,
      "ar": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"
    }
  ]
}
