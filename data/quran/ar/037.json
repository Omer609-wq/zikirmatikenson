{
  "n": 37,
  "nameAr": "الصافات",
  "nameTr": "Sâffât",
  "ayahCount": 182,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلصَّـٰٓفَّـٰتِ صَفًّا",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "فَٱلزَّٰجِرَٰتِ زَجْرًا"
    },
    {
      "n": 3,
      "ar": "فَٱلتَّـٰلِيَـٰتِ ذِكْرًا"
    },
    {
      "n": 4,
      "ar": "إِنَّ إِلَـٰهَكُمْ لَوَٰحِدٌ"
    },
    {
      "n": 5,
      "ar": "رَّبُّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ ٱلْمَشَـٰرِقِ"
    },
    {
      "n": 6,
      "ar": "إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِزِينَةٍ ٱلْكَوَاكِبِ"
    },
    {
      "n": 7,
      "ar": "وَحِفْظًا مِّن كُلِّ شَيْطَـٰنٍ مَّارِدٍ"
    },
    {
      "n": 8,
      "ar": "لَّا يَسَّمَّعُونَ إِلَى ٱلْمَلَإِ ٱلْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٍ"
    },
    {
      "n": 9,
      "ar": "دُحُورًا ۖ وَلَهُمْ عَذَابٌ وَاصِبٌ"
    },
    {
      "n": 10,
      "ar": "إِلَّا مَنْ خَطِفَ ٱلْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٌ ثَاقِبٌ"
    },
    {
      "n": 11,
      "ar": "فَٱسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَآ ۚ إِنَّا خَلَقْنَـٰهُم مِّن طِينٍ لَّازِبٍۭ"
    },
    {
      "n": 12,
      "ar": "بَلْ عَجِبْتَ وَيَسْخَرُونَ"
    },
    {
      "n": 13,
      "ar": "وَإِذَا ذُكِّرُوا۟ لَا يَذْكُرُونَ"
    },
    {
      "n": 14,
      "ar": "وَإِذَا رَأَوْا۟ ءَايَةً يَسْتَسْخِرُونَ"
    },
    {
      "n": 15,
      "ar": "وَقَالُوٓا۟ إِنْ هَـٰذَآ إِلَّا سِحْرٌ مُّبِينٌ"
    },
    {
      "n": 16,
      "ar": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَبْعُوثُونَ"
    },
    {
      "n": 17,
      "ar": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ"
    },
    {
      "n": 18,
      "ar": "قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَ"
    },
    {
      "n": 19,
      "ar": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ فَإِذَا هُمْ يَنظُرُونَ"
    },
    {
      "n": 20,
      "ar": "وَقَالُوا۟ يَـٰوَيْلَنَا هَـٰذَا يَوْمُ ٱلدِّينِ"
    },
    {
      "n": 21,
      "ar": "هَـٰذَا يَوْمُ ٱلْفَصْلِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ"
    },
    {
      "n": 22,
      "ar": "ٱحْشُرُوا۟ ٱلَّذِينَ ظَلَمُوا۟ وَأَزْوَٰجَهُمْ وَمَا كَانُوا۟ يَعْبُدُونَ"
    },
    {
      "n": 23,
      "ar": "مِن دُونِ ٱللَّهِ فَٱهْدُوهُمْ إِلَىٰ صِرَٰطِ ٱلْجَحِيمِ"
    },
    {
      "n": 24,
      "ar": "وَقِفُوهُمْ ۖ إِنَّهُم مَّسْـُٔولُونَ"
    },
    {
      "n": 25,
      "ar": "مَا لَكُمْ لَا تَنَاصَرُونَ"
    },
    {
      "n": 26,
      "ar": "بَلْ هُمُ ٱلْيَوْمَ مُسْتَسْلِمُونَ"
    },
    {
      "n": 27,
      "ar": "وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"
    },
    {
      "n": 28,
      "ar": "قَالُوٓا۟ إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ ٱلْيَمِينِ"
    },
    {
      "n": 29,
      "ar": "قَالُوا۟ بَل لَّمْ تَكُونُوا۟ مُؤْمِنِينَ"
    },
    {
      "n": 30,
      "ar": "وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَـٰنٍۭ ۖ بَلْ كُنتُمْ قَوْمًا طَـٰغِينَ"
    },
    {
      "n": 31,
      "ar": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ ۖ إِنَّا لَذَآئِقُونَ"
    },
    {
      "n": 32,
      "ar": "فَأَغْوَيْنَـٰكُمْ إِنَّا كُنَّا غَـٰوِينَ"
    },
    {
      "n": 33,
      "ar": "فَإِنَّهُمْ يَوْمَئِذٍ فِى ٱلْعَذَابِ مُشْتَرِكُونَ"
    },
    {
      "n": 34,
      "ar": "إِنَّا كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ"
    },
    {
      "n": 35,
      "ar": "إِنَّهُمْ كَانُوٓا۟ إِذَا قِيلَ لَهُمْ لَآ إِلَـٰهَ إِلَّا ٱللَّهُ يَسْتَكْبِرُونَ"
    },
    {
      "n": 36,
      "ar": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓا۟ ءَالِهَتِنَا لِشَاعِرٍ مَّجْنُونٍۭ"
    },
    {
      "n": 37,
      "ar": "بَلْ جَآءَ بِٱلْحَقِّ وَصَدَّقَ ٱلْمُرْسَلِينَ"
    },
    {
      "n": 38,
      "ar": "إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ"
    },
    {
      "n": 39,
      "ar": "وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ"
    },
    {
      "n": 40,
      "ar": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"
    },
    {
      "n": 41,
      "ar": "أُو۟لَـٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُومٌ"
    },
    {
      "n": 42,
      "ar": "فَوَٰكِهُ ۖ وَهُم مُّكْرَمُونَ"
    },
    {
      "n": 43,
      "ar": "فِى جَنَّـٰتِ ٱلنَّعِيمِ"
    },
    {
      "n": 44,
      "ar": "عَلَىٰ سُرُرٍ مُّتَقَـٰبِلِينَ"
    },
    {
      "n": 45,
      "ar": "يُطَافُ عَلَيْهِم بِكَأْسٍ مِّن مَّعِينٍۭ"
    },
    {
      "n": 46,
      "ar": "بَيْضَآءَ لَذَّةٍ لِّلشَّـٰرِبِينَ"
    },
    {
      "n": 47,
      "ar": "لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنزَفُونَ"
    },
    {
      "n": 48,
      "ar": "وَعِندَهُمْ قَـٰصِرَٰتُ ٱلطَّرْفِ عِينٌ"
    },
    {
      "n": 49,
      "ar": "كَأَنَّهُنَّ بَيْضٌ مَّكْنُونٌ"
    },
    {
      "n": 50,
      "ar": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"
    },
    {
      "n": 51,
      "ar": "قَالَ قَآئِلٌ مِّنْهُمْ إِنِّى كَانَ لِى قَرِينٌ"
    },
    {
      "n": 52,
      "ar": "يَقُولُ أَءِنَّكَ لَمِنَ ٱلْمُصَدِّقِينَ"
    },
    {
      "n": 53,
      "ar": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَدِينُونَ"
    },
    {
      "n": 54,
      "ar": "قَالَ هَلْ أَنتُم مُّطَّلِعُونَ"
    },
    {
      "n": 55,
      "ar": "فَٱطَّلَعَ فَرَءَاهُ فِى سَوَآءِ ٱلْجَحِيمِ"
    },
    {
      "n": 56,
      "ar": "قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرْدِينِ"
    },
    {
      "n": 57,
      "ar": "وَلَوْلَا نِعْمَةُ رَبِّى لَكُنتُ مِنَ ٱلْمُحْضَرِينَ"
    },
    {
      "n": 58,
      "ar": "أَفَمَا نَحْنُ بِمَيِّتِينَ"
    },
    {
      "n": 59,
      "ar": "إِلَّا مَوْتَتَنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ"
    },
    {
      "n": 60,
      "ar": "إِنَّ هَـٰذَا لَهُوَ ٱلْفَوْزُ ٱلْعَظِيمُ"
    },
    {
      "n": 61,
      "ar": "لِمِثْلِ هَـٰذَا فَلْيَعْمَلِ ٱلْعَـٰمِلُونَ"
    },
    {
      "n": 62,
      "ar": "أَذَٰلِكَ خَيْرٌ نُّزُلًا أَمْ شَجَرَةُ ٱلزَّقُّومِ"
    },
    {
      "n": 63,
      "ar": "إِنَّا جَعَلْنَـٰهَا فِتْنَةً لِّلظَّـٰلِمِينَ"
    },
    {
      "n": 64,
      "ar": "إِنَّهَا شَجَرَةٌ تَخْرُجُ فِىٓ أَصْلِ ٱلْجَحِيمِ"
    },
    {
      "n": 65,
      "ar": "طَلْعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَـٰطِينِ"
    },
    {
      "n": 66,
      "ar": "فَإِنَّهُمْ لَـَٔاكِلُونَ مِنْهَا فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ"
    },
    {
      "n": 67,
      "ar": "ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْبًا مِّنْ حَمِيمٍ"
    },
    {
      "n": 68,
      "ar": "ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَى ٱلْجَحِيمِ"
    },
    {
      "n": 69,
      "ar": "إِنَّهُمْ أَلْفَوْا۟ ءَابَآءَهُمْ ضَآلِّينَ"
    },
    {
      "n": 70,
      "ar": "فَهُمْ عَلَىٰٓ ءَاثَـٰرِهِمْ يُهْرَعُونَ"
    },
    {
      "n": 71,
      "ar": "وَلَقَدْ ضَلَّ قَبْلَهُمْ أَكْثَرُ ٱلْأَوَّلِينَ"
    },
    {
      "n": 72,
      "ar": "وَلَقَدْ أَرْسَلْنَا فِيهِم مُّنذِرِينَ"
    },
    {
      "n": 73,
      "ar": "فَٱنظُرْ كَيْفَ كَانَ عَـٰقِبَةُ ٱلْمُنذَرِينَ"
    },
    {
      "n": 74,
      "ar": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"
    },
    {
      "n": 75,
      "ar": "وَلَقَدْ نَادَىٰنَا نُوحٌ فَلَنِعْمَ ٱلْمُجِيبُونَ"
    },
    {
      "n": 76,
      "ar": "وَنَجَّيْنَـٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ"
    },
    {
      "n": 77,
      "ar": "وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ ٱلْبَاقِينَ"
    },
    {
      "n": 78,
      "ar": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ"
    },
    {
      "n": 79,
      "ar": "سَلَـٰمٌ عَلَىٰ نُوحٍ فِى ٱلْعَـٰلَمِينَ"
    },
    {
      "n": 80,
      "ar": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"
    },
    {
      "n": 81,
      "ar": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ"
    },
    {
      "n": 82,
      "ar": "ثُمَّ أَغْرَقْنَا ٱلْـَٔاخَرِينَ"
    },
    {
      "n": 83,
      "ar": "وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ"
    },
    {
      "n": 84,
      "ar": "إِذْ جَآءَ رَبَّهُۥ بِقَلْبٍ سَلِيمٍ"
    },
    {
      "n": 85,
      "ar": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَ"
    },
    {
      "n": 86,
      "ar": "أَئِفْكًا ءَالِهَةً دُونَ ٱللَّهِ تُرِيدُونَ"
    },
    {
      "n": 87,
      "ar": "فَمَا ظَنُّكُم بِرَبِّ ٱلْعَـٰلَمِينَ"
    },
    {
      "n": 88,
      "ar": "فَنَظَرَ نَظْرَةً فِى ٱلنُّجُومِ"
    },
    {
      "n": 89,
      "ar": "فَقَالَ إِنِّى سَقِيمٌ"
    },
    {
      "n": 90,
      "ar": "فَتَوَلَّوْا۟ عَنْهُ مُدْبِرِينَ"
    },
    {
      "n": 91,
      "ar": "فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُلُونَ"
    },
    {
      "n": 92,
      "ar": "مَا لَكُمْ لَا تَنطِقُونَ"
    },
    {
      "n": 93,
      "ar": "فَرَاغَ عَلَيْهِمْ ضَرْبًۢا بِٱلْيَمِينِ"
    },
    {
      "n": 94,
      "ar": "فَأَقْبَلُوٓا۟ إِلَيْهِ يَزِفُّونَ"
    },
    {
      "n": 95,
      "ar": "قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ"
    },
    {
      "n": 96,
      "ar": "وَٱللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ"
    },
    {
      "n": 97,
      "ar": "قَالُوا۟ ٱبْنُوا۟ لَهُۥ بُنْيَـٰنًا فَأَلْقُوهُ فِى ٱلْجَحِيمِ"
    },
    {
      "n": 98,
      "ar": "فَأَرَادُوا۟ بِهِۦ كَيْدًا فَجَعَلْنَـٰهُمُ ٱلْأَسْفَلِينَ"
    },
    {
      "n": 99,
      "ar": "وَقَالَ إِنِّى ذَاهِبٌ إِلَىٰ رَبِّى سَيَهْدِينِ"
    },
    {
      "n": 100,
      "ar": "رَبِّ هَبْ لِى مِنَ ٱلصَّـٰلِحِينَ"
    },
    {
      "n": 101,
      "ar": "فَبَشَّرْنَـٰهُ بِغُلَـٰمٍ حَلِيمٍ"
    },
    {
      "n": 102,
      "ar": "فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعْىَ قَالَ يَـٰبُنَىَّ إِنِّىٓ أَرَىٰ فِى ٱلْمَنَامِ أَنِّىٓ أَذْبَحُكَ فَٱنظُرْ مَاذَا تَرَىٰ ۚ قَالَ يَـٰٓأَبَتِ ٱفْعَلْ مَا تُؤْمَرُ ۖ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّـٰبِرِينَ"
    },
    {
      "n": 103,
