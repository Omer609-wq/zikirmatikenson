{
  "n": 109,
  "nameAr": "الكافرون",
  "nameTr": "Kâfirûn",
  "ayahCount": 6,
  "ayahs": [
    {
      "n": 1,
      "ar": "قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "لَآ أَعْبُدُ مَا تَعْبُدُونَ"
    },
    {
      "n": 3,
      "ar": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ"
    },
    {
      "n": 4,
      "ar": "وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ"
    },
    {
      "n": 5,
      "ar": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ"
    },
    {
      "n": 6,
      "ar": "لَكُمْ دِينُكُمْ وَلِىَ دِينِ"
    }
  ]
}
