{
  "n": 96,
  "nameAr": "العلق",
  "nameTr": "Alak",
  "ayahCount": 19,
  "ayahs": [
    {
      "n": 1,
      "ar": "اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ"
    },
    {
      "n": 3,
      "ar": "اقْرَأْ وَرَبُّكَ الْأَكْرَمُ"
    },
    {
      "n": 4,
      "ar": "الَّذِي عَلَّمَ بِالْقَلَمِ"
    },
    {
      "n": 5,
      "ar": "عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ"
    },
    {
      "n": 6,
      "ar": "كَلَّا إِنَّ الْإِنسَانَ لَيَطْغَىٰ"
    },
    {
      "n": 7,
      "ar": "أَن رَّآهُ اسْتَغْنَىٰ"
    },
    {
      "n": 8,
      "ar": "إِنَّ إِلَىٰ رَبِّكَ الرُّجْعَىٰ"
    },
    {
      "n": 9,
      "ar": "أَرَأَيْتَ الَّذِي يَنْهَىٰ"
    },
    {
      "n": 10,
      "ar": "عَبْدًا إِذَا صَلَّىٰ"
    },
    {
      "n": 11,
      "ar": "أَرَأَيْتَ إِن كَانَ عَلَى الْهُدَىٰ"
    },
    {
      "n": 12,
      "ar": "أَوْ أَمَرَ بِالتَّقْوَىٰ"
    },
    {
      "n": 13,
      "ar": "أَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّىٰ"
    },
    {
      "n": 14,
      "ar": "أَلَمْ يَعْلَم بِأَنَّ اللَّهَ يَرَىٰ"
    },
    {
      "n": 15,
      "ar": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ"
    },
    {
      "n": 16,
      "ar": "نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ"
    },
    {
      "n": 17,
      "ar": "فَلْيَدْعُ نَادِيَهُ"
    },
    {
      "n": 18,
      "ar": "سَنَدْعُ الزَّبَانِيَةَ"
    },
    {
      "n": 19,
      "ar": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِب ۩"
    }
  ]
}
