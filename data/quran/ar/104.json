{
  "n": 104,
  "nameAr": "الهمزة",
  "nameTr": "Hümeze",
  "ayahCount": 9,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ"
    },
    {
      "n": 3,
      "ar": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ"
    },
    {
      "n": 4,
      "ar": "كَلَّا ۖ لَيُنبَذَنَّ فِي الْحُطَمَةِ"
    },
    {
      "n": 5,
      "ar": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ"
    },
    {
      "n": 6,
      "ar": "نَارُ اللَّهِ الْمُوقَدَةُ"
    },
    {
      "n": 7,
      "ar": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ"
    },
    {
      "n": 8,
      "ar": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"
    },
    {
      "n": 9,
      "ar": "فِي عَمَدٍ مُّمَدَّدَةٍ"
    }
  ]
}
