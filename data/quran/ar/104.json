{
  "n": 104,
  "nameAr": "الهمزة",
  "nameTr": "Hümeze",
  "ayahCount": 9,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ"
    },
    {
      "n": 3,
      "ar": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ"
    },
    {
      "n": 4,
      "ar": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ"
    },
    {
      "n": 5,
      "ar": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ"
    },
    {
      "n": 6,
      "ar": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ"
    },
    {
      "n": 7,
      "ar": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ"
    },
    {
      "n": 8,
      "ar": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"
    },
    {
      "n": 9,
      "ar": "فِى عَمَدٍ مُّمَدَّدَةٍۭ"
    }
  ]
}
