{
  "n": 106,
  "nameAr": "قريش",
  "nameTr": "Kureyş",
  "ayahCount": 4,
  "ayahs": [
    {
      "n": 1,
      "ar": "لِإِيلَـٰفِ قُرَيْشٍ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "إِۦلَـٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ"
    },
    {
      "n": 3,
      "ar": "فَلْيَعْبُدُوا۟ رَبَّ هَـٰذَا ٱلْبَيْتِ"
    },
    {
      "n": 4,
      "ar": "ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍ وَءَامَنَهُم مِّنْ خَوْفٍۭ"
    }
  ]
}
