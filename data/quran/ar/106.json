{
  "n": 106,
  "nameAr": "قريش",
  "nameTr": "Kureyş",
  "ayahCount": 4,
  "ayahs": [
    {
      "n": 1,
      "ar": "لِإِيلَافِ قُرَيْشٍ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "إِيلَافِهِمْ رِحْلَةَ الشِّتَاءِ وَالصَّيْفِ"
    },
    {
      "n": 3,
      "ar": "فَلْيَعْبُدُوا رَبَّ هَـٰذَا الْبَيْتِ"
    },
    {
      "n": 4,
      "ar": "الَّذِي أَطْعَمَهُم مِّن جُوعٍ وَآمَنَهُم مِّنْ خَوْفٍ"
    }
  ]
}
