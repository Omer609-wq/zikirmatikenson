{
  "n": 97,
  "nameAr": "القدر",
  "nameTr": "Kadr",
  "ayahCount": 5,
  "ayahs": [
    {
      "n": 1,
      "ar": "إِنَّا أَنزَلْنَاهُ فِي لَيْلَةِ الْقَدْرِ",
      "bismillah": "بِّسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَمَا أَدْرَاكَ مَا لَيْلَةُ الْقَدْرِ"
    },
    {
      "n": 3,
      "ar": "لَيْلَةُ الْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ"
    },
    {
      "n": 4,
      "ar": "تَنَزَّلُ الْمَلَائِكَةُ وَالرُّوحُ فِيهَا بِإِذْنِ رَبِّهِم مِّن كُلِّ أَمْرٍ"
    },
    {
      "n": 5,
      "ar": "سَلَامٌ هِيَ حَتَّىٰ مَطْلَعِ الْفَجْرِ"
    }
  ]
}
