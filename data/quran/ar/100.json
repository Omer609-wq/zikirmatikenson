{
  "n": 100,
  "nameAr": "العاديات",
  "nameTr": "Âdiyât",
  "ayahCount": 11,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلْعَـٰدِيَـٰتِ ضَبْحًا",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "فَٱلْمُورِيَـٰتِ قَدْحًا"
    },
    {
      "n": 3,
      "ar": "فَٱلْمُغِيرَٰتِ صُبْحًا"
    },
    {
      "n": 4,
      "ar": "فَأَثَرْنَ بِهِۦ نَقْعًا"
    },
    {
      "n": 5,
      "ar": "فَوَسَطْنَ بِهِۦ جَمْعًا"
    },
    {
      "n": 6,
      "ar": "إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ"
    },
    {
      "n": 7,
      "ar": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ"
    },
    {
      "n": 8,
      "ar": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ"
    },
    {
      "n": 9,
      "ar": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ"
    },
    {
      "n": 10,
      "ar": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ"
    },
    {
      "n": 11,
      "ar": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ"
    }
  ]
}
