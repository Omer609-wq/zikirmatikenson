{
  "n": 101,
  "nameAr": "القارعة",
  "nameTr": "Kâria",
  "ayahCount": 11,
  "ayahs": [
    {
      "n": 1,
      "ar": "الْقَارِعَةُ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "مَا الْقَارِعَةُ"
    },
    {
      "n": 3,
      "ar": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ"
    },
    {
      "n": 4,
      "ar": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ"
    },
    {
      "n": 5,
      "ar": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنفُوشِ"
    },
    {
      "n": 6,
      "ar": "فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ"
    },
    {
      "n": 7,
      "ar": "فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ"
    },
    {
      "n": 8,
      "ar": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ"
    },
    {
      "n": 9,
      "ar": "فَأُمُّهُ هَاوِيَةٌ"
    },
    {
      "n": 10,
      "ar": "وَمَا أَدْرَاكَ مَا هِيَهْ"
    },
    {
      "n": 11,
      "ar": "نَارٌ حَامِيَةٌ"
    }
  ]
}
