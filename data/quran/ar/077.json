{
  "n": 77,
  "nameAr": "المرسلات",
  "nameTr": "Mürselât",
  "ayahCount": 50,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلْمُرْسَلَـٰتِ عُرْفًا",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "فَٱلْعَـٰصِفَـٰتِ عَصْفًا"
    },
    {
      "n": 3,
      "ar": "وَٱلنَّـٰشِرَٰتِ نَشْرًا"
    },
    {
      "n": 4,
      "ar": "فَٱلْفَـٰرِقَـٰتِ فَرْقًا"
    },
    {
      "n": 5,
      "ar": "فَٱلْمُلْقِيَـٰتِ ذِكْرًا"
    },
    {
      "n": 6,
      "ar": "عُذْرًا أَوْ نُذْرًا"
    },
    {
      "n": 7,
      "ar": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٌ"
    },
    {
      "n": 8,
      "ar": "فَإِذَا ٱلنُّجُومُ طُمِسَتْ"
    },
    {
      "n": 9,
      "ar": "وَإِذَا ٱلسَّمَآءُ فُرِجَتْ"
    },
    {
      "n": 10,
      "ar": "وَإِذَا ٱلْجِبَالُ نُسِفَتْ"
    },
    {
      "n": 11,
      "ar": "وَإِذَا ٱلرُّسُلُ أُقِّتَتْ"
    },
    {
      "n": 12,
      "ar": "لِأَىِّ يَوْمٍ أُجِّلَتْ"
    },
    {
      "n": 13,
      "ar": "لِيَوْمِ ٱلْفَصْلِ"
    },
    {
      "n": 14,
      "ar": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ"
    },
    {
      "n": 15,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 16,
      "ar": "أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ"
    },
    {
      "n": 17,
      "ar": "ثُمَّ نُتْبِعُهُمُ ٱلْـَٔاخِرِينَ"
    },
    {
      "n": 18,
      "ar": "كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ"
    },
    {
      "n": 19,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 20,
      "ar": "أَلَمْ نَخْلُقكُّم مِّن مَّآءٍ مَّهِينٍ"
    },
    {
      "n": 21,
      "ar": "فَجَعَلْنَـٰهُ فِى قَرَارٍ مَّكِينٍ"
    },
    {
      "n": 22,
      "ar": "إِلَىٰ قَدَرٍ مَّعْلُومٍ"
    },
    {
      "n": 23,
      "ar": "فَقَدَرْنَا فَنِعْمَ ٱلْقَـٰدِرُونَ"
    },
    {
      "n": 24,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 25,
      "ar": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا"
    },
    {
      "n": 26,
      "ar": "أَحْيَآءً وَأَمْوَٰتًا"
    },
    {
      "n": 27,
      "ar": "وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَـٰمِخَـٰتٍ وَأَسْقَيْنَـٰكُم مَّآءً فُرَاتًا"
    },
    {
      "n": 28,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 29,
      "ar": "ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ"
    },
    {
      "n": 30,
      "ar": "ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّ ذِى ثَلَـٰثِ شُعَبٍ"
    },
    {
      "n": 31,
      "ar": "لَّا ظَلِيلٍ وَلَا يُغْنِى مِنَ ٱللَّهَبِ"
    },
    {
      "n": 32,
      "ar": "إِنَّهَا تَرْمِى بِشَرَرٍ كَٱلْقَصْرِ"
    },
    {
      "n": 33,
      "ar": "كَأَنَّهُۥ جِمَـٰلَتٌ صُفْرٌ"
    },
    {
      "n": 34,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 35,
      "ar": "هَـٰذَا يَوْمُ لَا يَنطِقُونَ"
    },
    {
      "n": 36,
      "ar": "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ"
    },
    {
      "n": 37,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 38,
      "ar": "هَـٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَـٰكُمْ وَٱلْأَوَّلِينَ"
    },
    {
      "n": 39,
      "ar": "فَإِن كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ"
    },
    {
      "n": 40,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 41,
      "ar": "إِنَّ ٱلْمُتَّقِينَ فِى ظِلَـٰلٍ وَعُيُونٍ"
    },
    {
      "n": 42,
      "ar": "وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ"
    },
    {
      "n": 43,
      "ar": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ"
    },
    {
      "n": 44,
      "ar": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"
    },
    {
      "n": 45,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 46,
      "ar": "كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ"
    },
    {
      "n": 47,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 48,
      "ar": "وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ"
    },
    {
      "n": 49,
      "ar": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"
    },
    {
      "n": 50,
      "ar": "فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ"
    }
  ]
}
