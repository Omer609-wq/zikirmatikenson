{
  "n": 86,
  "nameAr": "الطارق",
  "nameTr": "Târık",
  "ayahCount": 17,
  "ayahs": [
    {
      "n": 1,
      "ar": "وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ"
    },
    {
      "n": 3,
      "ar": "ٱلنَّجْمُ ٱلثَّاقِبُ"
    },
    {
      "n": 4,
      "ar": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ"
    },
    {
      "n": 5,
      "ar": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ"
    },
    {
      "n": 6,
      "ar": "خُلِقَ مِن مَّآءٍ دَافِقٍ"
    },
    {
      "n": 7,
      "ar": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ"
    },
    {
      "n": 8,
      "ar": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ"
    },
    {
      "n": 9,
      "ar": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ"
    },
    {
      "n": 10,
      "ar": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ"
    },
    {
      "n": 11,
      "ar": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ"
    },
    {
      "n": 12,
      "ar": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ"
    },
    {
      "n": 13,
      "ar": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ"
    },
    {
      "n": 14,
      "ar": "وَمَا هُوَ بِٱلْهَزْلِ"
    },
    {
      "n": 15,
      "ar": "إِنَّهُمْ يَكِيدُونَ كَيْدًا"
    },
    {
      "n": 16,
      "ar": "وَأَكِيدُ كَيْدًا"
    },
    {
      "n": 17,
      "ar": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا"
    }
  ]
}
