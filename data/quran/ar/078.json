{
  "n": 78,
  "nameAr": "النبإ",
  "nameTr": "Nebe",
  "ayahCount": 40,
  "ayahs": [
    {
      "n": 1,
      "ar": "عَمَّ يَتَسَآءَلُونَ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ"
    },
    {
      "n": 3,
      "ar": "ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ"
    },
    {
      "n": 4,
      "ar": "كَلَّا سَيَعْلَمُونَ"
    },
    {
      "n": 5,
      "ar": "ثُمَّ كَلَّا سَيَعْلَمُونَ"
    },
    {
      "n": 6,
      "ar": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَـٰدًا"
    },
    {
      "n": 7,
      "ar": "وَٱلْجِبَالَ أَوْتَادًا"
    },
    {
      "n": 8,
      "ar": "وَخَلَقْنَـٰكُمْ أَزْوَٰجًا"
    },
    {
      "n": 9,
      "ar": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"
    },
    {
      "n": 10,
      "ar": "وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا"
    },
    {
      "n": 11,
      "ar": "وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًا"
    },
    {
      "n": 12,
      "ar": "وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"
    },
    {
      "n": 13,
      "ar": "وَجَعَلْنَا سِرَاجًا وَهَّاجًا"
    },
    {
      "n": 14,
      "ar": "وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا"
    },
    {
      "n": 15,
      "ar": "لِّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا"
    },
    {
      "n": 16,
      "ar": "وَجَنَّـٰتٍ أَلْفَافًا"
    },
    {
      "n": 17,
      "ar": "إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَـٰتًا"
    },
    {
      "n": 18,
      "ar": "يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا"
    },
    {
      "n": 19,
      "ar": "وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا"
    },
    {
      "n": 20,
      "ar": "وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا"
    },
    {
      "n": 21,
      "ar": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"
    },
    {
      "n": 22,
      "ar": "لِّلطَّـٰغِينَ مَـَٔابًا"
    },
    {
      "n": 23,
      "ar": "لَّـٰبِثِينَ فِيهَآ أَحْقَابًا"
    },
    {
      "n": 24,
      "ar": "لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"
    },
    {
      "n": 25,
      "ar": "إِلَّا حَمِيمًا وَغَسَّاقًا"
    },
    {
      "n": 26,
      "ar": "جَزَآءً وِفَاقًا"
    },
    {
      "n": 27,
      "ar": "إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا"
    },
    {
      "n": 28,
      "ar": "وَكَذَّبُوا۟ بِـَٔايَـٰتِنَا كِذَّابًا"
    },
    {
      "n": 29,
      "ar": "وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ كِتَـٰبًا"
    },
    {
      "n": 30,
      "ar": "فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا"
    },
    {
      "n": 31,
      "ar": "إِنَّ لِلْمُتَّقِينَ مَفَازًا"
    },
    {
      "n": 32,
      "ar": "حَدَآئِقَ وَأَعْنَـٰبًا"
    },
    {
      "n": 33,
      "ar": "وَكَوَاعِبَ أَتْرَابًا"
    },
    {
      "n": 34,
      "ar": "وَكَأْسًا دِهَاقًا"
    },
    {
      "n": 35,
      "ar": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا"
    },
    {
      "n": 36,
      "ar": "جَزَآءً مِّن رَّبِّكَ عَطَآءً حِسَابًا"
    },
    {
      "n": 37,
      "ar": "رَّبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا"
    },
    {
      "n": 38,
      "ar": "يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَـٰٓئِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَـٰنُ وَقَالَ صَوَابًا"
    },
    {
      "n": 39,
      "ar": "ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا"
    },
    {
      "n": 40,
      "ar": "إِنَّآ أَنذَرْنَـٰكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَـٰلَيْتَنِى كُنتُ تُرَٰبًۢا"
    }
  ]
}
