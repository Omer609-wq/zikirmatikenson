{
  "n": 78,
  "nameAr": "النبإ",
  "nameTr": "Nebe",
  "ayahCount": 40,
  "ayahs": [
    {
      "n": 1,
      "ar": "عَمَّ يَتَسَاءَلُونَ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "عَنِ النَّبَإِ الْعَظِيمِ"
    },
    {
      "n": 3,
      "ar": "الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ"
    },
    {
      "n": 4,
      "ar": "كَلَّا سَيَعْلَمُونَ"
    },
    {
      "n": 5,
      "ar": "ثُمَّ كَلَّا سَيَعْلَمُونَ"
    },
    {
      "n": 6,
      "ar": "أَلَمْ نَجْعَلِ الْأَرْضَ مِهَادًا"
    },
    {
      "n": 7,
      "ar": "وَالْجِبَالَ أَوْتَادًا"
    },
    {
      "n": 8,
      "ar": "وَخَلَقْنَاكُمْ أَزْوَاجًا"
    },
    {
      "n": 9,
      "ar": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"
    },
    {
      "n": 10,
      "ar": "وَجَعَلْنَا اللَّيْلَ لِبَاسًا"
    },
    {
      "n": 11,
      "ar": "وَجَعَلْنَا النَّهَارَ مَعَاشًا"
    },
    {
      "n": 12,
      "ar": "وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"
    },
    {
      "n": 13,
      "ar": "وَجَعَلْنَا سِرَاجًا وَهَّاجًا"
    },
    {
      "n": 14,
      "ar": "وَأَنزَلْنَا مِنَ الْمُعْصِرَاتِ مَاءً ثَجَّاجًا"
    },
    {
      "n": 15,
      "ar": "لِّنُخْرِجَ بِهِ حَبًّا وَنَبَاتًا"
    },
    {
      "n": 16,
      "ar": "وَجَنَّاتٍ أَلْفَافًا"
    },
    {
      "n": 17,
      "ar": "إِنَّ يَوْمَ الْفَصْلِ كَانَ مِيقَاتًا"
    },
    {
      "n": 18,
      "ar": "يَوْمَ يُنفَخُ فِي الصُّورِ فَتَأْتُونَ أَفْوَاجًا"
    },
    {
      "n": 19,
      "ar": "وَفُتِحَتِ السَّمَاءُ فَكَانَتْ أَبْوَابًا"
    },
    {
      "n": 20,
      "ar": "وَسُيِّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًا"
    },
    {
      "n": 21,
      "ar": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"
    },
    {
      "n": 22,
      "ar": "لِّلطَّاغِينَ مَآبًا"
    },
    {
      "n": 23,
      "ar": "لَّابِثِينَ فِيهَا أَحْقَابًا"
    },
    {
      "n": 24,
      "ar": "لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"
    },
    {
      "n": 25,
      "ar": "إِلَّا حَمِيمًا وَغَسَّاقًا"
    },
    {
      "n": 26,
      "ar": "جَزَاءً وِفَاقًا"
    },
    {
      "n": 27,
      "ar": "إِنَّهُمْ كَانُوا لَا يَرْجُونَ حِسَابًا"
    },
    {
      "n": 28,
      "ar": "وَكَذَّبُوا بِآيَاتِنَا كِذَّابًا"
    },
    {
      "n": 29,
      "ar": "وَكُلَّ شَيْءٍ أَحْصَيْنَاهُ كِتَابًا"
    },
    {
      "n": 30,
      "ar": "فَذُوقُوا فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا"
    },
    {
      "n": 31,
      "ar": "إِنَّ لِلْمُتَّقِينَ مَفَازًا"
    },
    {
      "n": 32,
      "ar": "حَدَائِقَ وَأَعْنَابًا"
    },
    {
      "n": 33,
      "ar": "وَكَوَاعِبَ أَتْرَابًا"
    },
    {
      "n": 34,
      "ar": "وَكَأْسًا دِهَاقًا"
    },
    {
      "n": 35,
      "ar": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّابًا"
    },
    {
      "n": 36,
      "ar": "جَزَاءً مِّن رَّبِّكَ عَطَاءً حِسَابًا"
    },
    {
      "n": 37,
      "ar": "رَّبِّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا الرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا"
    },
    {
      "n": 38,
      "ar": "يَوْمَ يَقُومُ الرُّوحُ وَالْمَلَائِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ الرَّحْمَـٰنُ وَقَالَ صَوَابًا"
    },
    {
      "n": 39,
      "ar": "ذَٰلِكَ الْيَوْمُ الْحَقُّ ۖ فَمَن شَاءَ اتَّخَذَ إِلَىٰ رَبِّهِ مَآبًا"
    },
    {
      "n": 40,
      "ar": "إِنَّا أَنذَرْنَاكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ الْكَافِرُ يَا لَيْتَنِي كُنتُ تُرَابًا"
    }
  ]
}
