{
  "n": 105,
  "nameAr": "الفيل",
  "nameTr": "Fîl",
  "ayahCount": 5,
  "ayahs": [
    {
      "n": 1,
      "ar": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَـٰبِ ٱلْفِيلِ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍ"
    },
    {
      "n": 3,
      "ar": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"
    },
    {
      "n": 4,
      "ar": "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ"
    },
    {
      "n": 5,
      "ar": "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍۭ"
    }
  ]
}
