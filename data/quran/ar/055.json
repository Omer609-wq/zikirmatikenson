{
  "n": 55,
  "nameAr": "الرحمن",
  "nameTr": "Rahmân",
  "ayahCount": 78,
  "ayahs": [
    {
      "n": 1,
      "ar": "ٱلرَّحْمَـٰنُ",
      "bismillah": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "عَلَّمَ ٱلْقُرْءَانَ"
    },
    {
      "n": 3,
      "ar": "خَلَقَ ٱلْإِنسَـٰنَ"
    },
    {
      "n": 4,
      "ar": "عَلَّمَهُ ٱلْبَيَانَ"
    },
    {
      "n": 5,
      "ar": "ٱلشَّمْسُ وَٱلْقَمَرُ بِحُسْبَانٍ"
    },
    {
      "n": 6,
      "ar": "وَٱلنَّجْمُ وَٱلشَّجَرُ يَسْجُدَانِ"
    },
    {
      "n": 7,
      "ar": "وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلْمِيزَانَ"
    },
    {
      "n": 8,
      "ar": "أَلَّا تَطْغَوْا۟ فِى ٱلْمِيزَانِ"
    },
    {
      "n": 9,
      "ar": "وَأَقِيمُوا۟ ٱلْوَزْنَ بِٱلْقِسْطِ وَلَا تُخْسِرُوا۟ ٱلْمِيزَانَ"
    },
    {
      "n": 10,
      "ar": "وَٱلْأَرْضَ وَضَعَهَا لِلْأَنَامِ"
    },
    {
      "n": 11,
      "ar": "فِيهَا فَـٰكِهَةٌ وَٱلنَّخْلُ ذَاتُ ٱلْأَكْمَامِ"
    },
    {
      "n": 12,
      "ar": "وَٱلْحَبُّ ذُو ٱلْعَصْفِ وَٱلرَّيْحَانُ"
    },
    {
      "n": 13,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 14,
      "ar": "خَلَقَ ٱلْإِنسَـٰنَ مِن صَلْصَـٰلٍ كَٱلْفَخَّارِ"
    },
    {
      "n": 15,
      "ar": "وَخَلَقَ ٱلْجَآنَّ مِن مَّارِجٍ مِّن نَّارٍ"
    },
    {
      "n": 16,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 17,
      "ar": "رَبُّ ٱلْمَشْرِقَيْنِ وَرَبُّ ٱلْمَغْرِبَيْنِ"
    },
    {
      "n": 18,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 19,
      "ar": "مَرَجَ ٱلْبَحْرَيْنِ يَلْتَقِيَانِ"
    },
    {
      "n": 20,
      "ar": "بَيْنَهُمَا بَرْزَخٌ لَّا يَبْغِيَانِ"
    },
    {
      "n": 21,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 22,
      "ar": "يَخْرُجُ مِنْهُمَا ٱللُّؤْلُؤُ وَٱلْمَرْجَانُ"
    },
    {
      "n": 23,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 24,
      "ar": "وَلَهُ ٱلْجَوَارِ ٱلْمُنشَـَٔاتُ فِى ٱلْبَحْرِ كَٱلْأَعْلَـٰمِ"
    },
    {
      "n": 25,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 26,
      "ar": "كُلُّ مَنْ عَلَيْهَا فَانٍ"
    },
    {
      "n": 27,
      "ar": "وَيَبْقَىٰ وَجْهُ رَبِّكَ ذُو ٱلْجَلَـٰلِ وَٱلْإِكْرَامِ"
    },
    {
      "n": 28,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 29,
      "ar": "يَسْـَٔلُهُۥ مَن فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ كُلَّ يَوْمٍ هُوَ فِى شَأْنٍ"
    },
    {
      "n": 30,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 31,
      "ar": "سَنَفْرُغُ لَكُمْ أَيُّهَ ٱلثَّقَلَانِ"
    },
    {
      "n": 32,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 33,
      "ar": "يَـٰمَعْشَرَ ٱلْجِنِّ وَٱلْإِنسِ إِنِ ٱسْتَطَعْتُمْ أَن تَنفُذُوا۟ مِنْ أَقْطَارِ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ فَٱنفُذُوا۟ ۚ لَا تَنفُذُونَ إِلَّا بِسُلْطَـٰنٍ"
    },
    {
      "n": 34,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 35,
      "ar": "يُرْسَلُ عَلَيْكُمَا شُوَاظٌ مِّن نَّارٍ وَنُحَاسٌ فَلَا تَنتَصِرَانِ"
    },
    {
      "n": 36,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 37,
      "ar": "فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتْ وَرْدَةً كَٱلدِّهَانِ"
    },
    {
      "n": 38,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 39,
      "ar": "فَيَوْمَئِذٍ لَّا يُسْـَٔلُ عَن ذَنۢبِهِۦٓ إِنسٌ وَلَا جَآنٌّ"
    },
    {
      "n": 40,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 41,
      "ar": "يُعْرَفُ ٱلْمُجْرِمُونَ بِسِيمَـٰهُمْ فَيُؤْخَذُ بِٱلنَّوَٰصِى وَٱلْأَقْدَامِ"
    },
    {
      "n": 42,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 43,
      "ar": "هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِى يُكَذِّبُ بِهَا ٱلْمُجْرِمُونَ"
    },
    {
      "n": 44,
      "ar": "يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ ءَانٍ"
    },
    {
      "n": 45,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 46,
      "ar": "وَلِمَنْ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ"
    },
    {
      "n": 47,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 48,
      "ar": "ذَوَاتَآ أَفْنَانٍ"
    },
    {
      "n": 49,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 50,
      "ar": "فِيهِمَا عَيْنَانِ تَجْرِيَانِ"
    },
    {
      "n": 51,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 52,
      "ar": "فِيهِمَا مِن كُلِّ فَـٰكِهَةٍ زَوْجَانِ"
    },
    {
      "n": 53,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 54,
      "ar": "مُتَّكِـِٔينَ عَلَىٰ فُرُشٍۭ بَطَآئِنُهَا مِنْ إِسْتَبْرَقٍ ۚ وَجَنَى ٱلْجَنَّتَيْنِ دَانٍ"
    },
    {
      "n": 55,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 56,
      "ar": "فِيهِنَّ قَـٰصِرَٰتُ ٱلطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَآنٌّ"
    },
    {
      "n": 57,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 58,
      "ar": "كَأَنَّهُنَّ ٱلْيَاقُوتُ وَٱلْمَرْجَانُ"
    },
    {
      "n": 59,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 60,
      "ar": "هَلْ جَزَآءُ ٱلْإِحْسَـٰنِ إِلَّا ٱلْإِحْسَـٰنُ"
    },
    {
      "n": 61,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 62,
      "ar": "وَمِن دُونِهِمَا جَنَّتَانِ"
    },
    {
      "n": 63,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 64,
      "ar": "مُدْهَآمَّتَانِ"
    },
    {
      "n": 65,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 66,
      "ar": "فِيهِمَا عَيْنَانِ نَضَّاخَتَانِ"
    },
    {
      "n": 67,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 68,
      "ar": "فِيهِمَا فَـٰكِهَةٌ وَنَخْلٌ وَرُمَّانٌ"
    },
    {
      "n": 69,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 70,
      "ar": "فِيهِنَّ خَيْرَٰتٌ حِسَانٌ"
    },
    {
      "n": 71,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 72,
      "ar": "حُورٌ مَّقْصُورَٰتٌ فِى ٱلْخِيَامِ"
    },
    {
      "n": 73,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 74,
      "ar": "لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَآنٌّ"
    },
    {
      "n": 75,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 76,
      "ar": "مُتَّكِـِٔينَ عَلَىٰ رَفْرَفٍ خُضْرٍ وَعَبْقَرِىٍّ حِسَانٍ"
    },
    {
      "n": 77,
      "ar": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 78,
      "ar": "تَبَـٰرَكَ ٱسْمُ رَبِّكَ ذِى ٱلْجَلَـٰلِ وَٱلْإِكْرَامِ"
    }
  ]
}
