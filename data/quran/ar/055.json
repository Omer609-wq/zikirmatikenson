{
  "n": 55,
  "nameAr": "الرحمن",
  "nameTr": "Rahmân",
  "ayahCount": 78,
  "ayahs": [
    {
      "n": 1,
      "ar": "الرَّحْمَـٰنُ",
      "bismillah": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ"
    },
    {
      "n": 2,
      "ar": "عَلَّمَ الْقُرْآنَ"
    },
    {
      "n": 3,
      "ar": "خَلَقَ الْإِنسَانَ"
    },
    {
      "n": 4,
      "ar": "عَلَّمَهُ الْبَيَانَ"
    },
    {
      "n": 5,
      "ar": "الشَّمْسُ وَالْقَمَرُ بِحُسْبَانٍ"
    },
    {
      "n": 6,
      "ar": "وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَانِ"
    },
    {
      "n": 7,
      "ar": "وَالسَّمَاءَ رَفَعَهَا وَوَضَعَ الْمِيزَانَ"
    },
    {
      "n": 8,
      "ar": "أَلَّا تَطْغَوْا فِي الْمِيزَانِ"
    },
    {
      "n": 9,
      "ar": "وَأَقِيمُوا الْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُوا الْمِيزَانَ"
    },
    {
      "n": 10,
      "ar": "وَالْأَرْضَ وَضَعَهَا لِلْأَنَامِ"
    },
    {
      "n": 11,
      "ar": "فِيهَا فَاكِهَةٌ وَالنَّخْلُ ذَاتُ الْأَكْمَامِ"
    },
    {
      "n": 12,
      "ar": "وَالْحَبُّ ذُو الْعَصْفِ وَالرَّيْحَانُ"
    },
    {
      "n": 13,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 14,
      "ar": "خَلَقَ الْإِنسَانَ مِن صَلْصَالٍ كَالْفَخَّارِ"
    },
    {
      "n": 15,
      "ar": "وَخَلَقَ الْجَانَّ مِن مَّارِجٍ مِّن نَّارٍ"
    },
    {
      "n": 16,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 17,
      "ar": "رَبُّ الْمَشْرِقَيْنِ وَرَبُّ الْمَغْرِبَيْنِ"
    },
    {
      "n": 18,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 19,
      "ar": "مَرَجَ الْبَحْرَيْنِ يَلْتَقِيَانِ"
    },
    {
      "n": 20,
      "ar": "بَيْنَهُمَا بَرْزَخٌ لَّا يَبْغِيَانِ"
    },
    {
      "n": 21,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 22,
      "ar": "يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَالْمَرْجَانُ"
    },
    {
      "n": 23,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 24,
      "ar": "وَلَهُ الْجَوَارِ الْمُنشَآتُ فِي الْبَحْرِ كَالْأَعْلَامِ"
    },
    {
      "n": 25,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 26,
      "ar": "كُلُّ مَنْ عَلَيْهَا فَانٍ"
    },
    {
      "n": 27,
      "ar": "وَيَبْقَىٰ وَجْهُ رَبِّكَ ذُو الْجَلَالِ وَالْإِكْرَامِ"
    },
    {
      "n": 28,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 29,
      "ar": "يَسْأَلُهُ مَن فِي السَّمَاوَاتِ وَالْأَرْضِ ۚ كُلَّ يَوْمٍ هُوَ فِي شَأْنٍ"
    },
    {
      "n": 30,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 31,
      "ar": "سَنَفْرُغُ لَكُمْ أَيُّهَ الثَّقَلَانِ"
    },
    {
      "n": 32,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 33,
      "ar": "يَا مَعْشَرَ الْجِنِّ وَالْإِنسِ إِنِ اسْتَطَعْتُمْ أَن تَنفُذُوا مِنْ أَقْطَارِ السَّمَاوَاتِ وَالْأَرْضِ فَانفُذُوا ۚ لَا تَنفُذُونَ إِلَّا بِسُلْطَانٍ"
    },
    {
      "n": 34,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 35,
      "ar": "يُرْسَلُ عَلَيْكُمَا شُوَاظٌ مِّن نَّارٍ وَنُحَاسٌ فَلَا تَنتَصِرَانِ"
    },
    {
      "n": 36,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 37,
      "ar": "فَإِذَا انشَقَّتِ السَّمَاءُ فَكَانَتْ وَرْدَةً كَالدِّهَانِ"
    },
    {
      "n": 38,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 39,
      "ar": "فَيَوْمَئِذٍ لَّا يُسْأَلُ عَن ذَنبِهِ إِنسٌ وَلَا جَانٌّ"
    },
    {
      "n": 40,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 41,
      "ar": "يُعْرَفُ الْمُجْرِمُونَ بِسِيمَاهُمْ فَيُؤْخَذُ بِالنَّوَاصِي وَالْأَقْدَامِ"
    },
    {
      "n": 42,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 43,
      "ar": "هَـٰذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِهَا الْمُجْرِمُونَ"
    },
    {
      "n": 44,
      "ar": "يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ آنٍ"
    },
    {
      "n": 45,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 46,
      "ar": "وَلِمَنْ خَافَ مَقَامَ رَبِّهِ جَنَّتَانِ"
    },
    {
      "n": 47,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 48,
      "ar": "ذَوَاتَا أَفْنَانٍ"
    },
    {
      "n": 49,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 50,
      "ar": "فِيهِمَا عَيْنَانِ تَجْرِيَانِ"
    },
    {
      "n": 51,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 52,
      "ar": "فِيهِمَا مِن كُلِّ فَاكِهَةٍ زَوْجَانِ"
    },
    {
      "n": 53,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 54,
      "ar": "مُتَّكِئِينَ عَلَىٰ فُرُشٍ بَطَائِنُهَا مِنْ إِسْتَبْرَقٍ ۚ وَجَنَى الْجَنَّتَيْنِ دَانٍ"
    },
    {
      "n": 55,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 56,
      "ar": "فِيهِنَّ قَاصِرَاتُ الطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَانٌّ"
    },
    {
      "n": 57,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 58,
      "ar": "كَأَنَّهُنَّ الْيَاقُوتُ وَالْمَرْجَانُ"
    },
    {
      "n": 59,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 60,
      "ar": "هَلْ جَزَاءُ الْإِحْسَانِ إِلَّا الْإِحْسَانُ"
    },
    {
      "n": 61,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 62,
      "ar": "وَمِن دُونِهِمَا جَنَّتَانِ"
    },
    {
      "n": 63,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 64,
      "ar": "مُدْهَامَّتَانِ"
    },
    {
      "n": 65,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 66,
      "ar": "فِيهِمَا عَيْنَانِ نَضَّاخَتَانِ"
    },
    {
      "n": 67,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 68,
      "ar": "فِيهِمَا فَاكِهَةٌ وَنَخْلٌ وَرُمَّانٌ"
    },
    {
      "n": 69,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 70,
      "ar": "فِيهِنَّ خَيْرَاتٌ حِسَانٌ"
    },
    {
      "n": 71,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 72,
      "ar": "حُورٌ مَّقْصُورَاتٌ فِي الْخِيَامِ"
    },
    {
      "n": 73,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 74,
      "ar": "لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَانٌّ"
    },
    {
      "n": 75,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 76,
      "ar": "مُتَّكِئِينَ عَلَىٰ رَفْرَفٍ خُضْرٍ وَعَبْقَرِيٍّ حِسَانٍ"
    },
    {
      "n": 77,
      "ar": "فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"
    },
    {
      "n": 78,
      "ar": "تَبَارَكَ اسْمُ رَبِّكَ ذِي الْجَلَالِ وَالْإِكْرَامِ"
    }
  ]
}
