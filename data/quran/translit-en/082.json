    {
      "n": 16,
      "lat": "Wama hum AAanha bighaibeena"
    },
    {
      "n": 17,
      "lat": "Wama adraka ma yawmu alddeeni"
    },
    {
      "n": 18,
      "lat": "Thumma ma adraka ma yawmu alddeeni"
