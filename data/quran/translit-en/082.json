    {
      "n": 4,
      "lat": "Waitha alqubooru buAAthirat"
    },
    {
      "n": 5,
      "lat": "AAalimat nafsun ma qaddamat waakhkharat"
    },
    {
      "n": 6,
      "lat": "Ya ayyuha alinsanu ma gharraka birabbika alkareemi"
    },
    {
      "n": 7,
      "lat": "Allathee khalaqaka fasawwaka faAAadalaka"
    },
    {
      "n": 8,
      "lat": "Fee ayyi sooratin ma shaa rakkabaka"
    },
    {
      "n": 9,
      "lat": "Kalla bal tukaththiboona bialddeeni"
    },
    {
      "n": 10,
      "lat": "Wainna AAalaykum lahafitheena"
    },
    {
      "n": 11,
      "lat": "Kiraman katibeena"
    },
    {
      "n": 12,
      "lat": "YaAAlamoona ma tafAAaloona"
    },
    {
      "n": 13,
      "lat": "Inna alabrara lafee naAAeemin"
