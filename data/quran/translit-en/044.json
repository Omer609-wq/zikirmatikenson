    },
    {
      "n": 9,
      "lat": "Bal Hum Fi Shakkin Yal`abuna"
    },
    {
      "n": 10,
      "lat": "Fartaqib Yawma Ta'ti As-Sama'u Bidukhanin Mubinin"
    },
    {
      "n": 11,
      "lat": "Yaghsha An-Nasa Hadha `Adhabun 'Alimun"
    },
    {
      "n": 12,
      "lat": "Rabbana Akshif `Anna Al-`Adhaba 'Inna Mu'uminuna"
    },
    {
      "n": 13,
      "lat": "Anna Lahumu Adh-Dhikra Wa Qad Ja'ahum Rasulun Mubinun"
    },
    {
      "n": 14,
      "lat": "Thumma Tawallaw `Anhu Wa Qalu Mu`allamun Majnunun"
    },
    {
      "n": 15,
      "lat": "Inna Kashifu Al-`Adhabi Qalilaan 'Innakum `A'iduna"
    },
    {
      "n": 16,
      "lat": "Yawma Nabtishu Al-Batshata Al-Kubra 'Inna Muntaqimuna"
    },
    {
      "n": 17,
      "lat": "Wa Laqad Fatanna Qablahum Qawma Fir`awna Wa Ja'ahum Rasulun Karimun"
    },
    {
      "n": 18,
      "lat": "An 'Addu 'Ilayya `Ibada Allahi 'Inni Lakum Rasulun 'Aminun"
    },
    {
      "n": 19,
      "lat": "Wa 'An La Ta`lu `Ala Allahi 'Inni 'Atikum Bisultanin Mubinin"
    },
    {
      "n": 20,
      "lat": "Wa 'Inni `Udhtu Birabbi Wa Rabbikum 'An Tarjumuni"
    },
    {
      "n": 21,
      "lat": "Wa 'In Lam Tu'uminu Li Fa`taziluni"
    },
    {
      "n": 22,
      "lat": "Fada`a Rabbahu 'Anna Ha'uula' Qawmun Mujrimuna"
    },
    {
      "n": 23,
      "lat": "Fa'asri Bi`ibadi Laylaan 'Innakum Muttaba`una"
    },
    {
      "n": 24,
      "lat": "Wa Atruki Al-Bahra Rahwan 'Innahum Jundun Mughraquna"
    },
    {
      "n": 25,
      "lat": "Kam Taraku Min Jannatin Wa `Uyunin"
    },
    {
      "n": 26,
      "lat": "Wa Zuru`in Wa Maqamin Karimin"
    },
    {
      "n": 27,
      "lat": "Wa Na`matin Kanu Fiha Fakihina"
    },
    {
      "n": 28,
      "lat": "Kadhalika Wa 'Awrathnaha Qawmaan 'Akharina"
    },
    {
      "n": 29,
      "lat": "Fama Bakat `Alayhimu As-Sama'u Wa Al-'Arđu Wa Ma Kanu Munzarina"
    },
    {
      "n": 30,
      "lat": "Wa Laqad Najjayna Bani 'Isra'ila Mina Al-`Adhabi Al-Muhini"
    },
    {
      "n": 31,
      "lat": "Min Fir`awna 'Innahu Kana `Aliaan Mina Al-Musrifina"
    },
    {
      "n": 32,
      "lat": "Wa Laqadi Akhtarnahum `Ala `Ilmin `Ala Al-`Alamina"
    },
    {
      "n": 33,
      "lat": "Wa 'Ataynahum Mina Al-'Ayati Ma Fihi Bala'un Mubinun"
    },
    {
      "n": 34,
      "lat": "Inna Ha'uula' Layaquluna"
    },
    {
      "n": 35,
      "lat": "In Hiya 'Illa Mawtatuna Al-'Ula Wa Ma Nahnu Bimunsharina"
    },
    {
      "n": 36,
      "lat": "Fa'tu Bi'aba'ina 'In Kuntum Sadiqina"
    },
    {
