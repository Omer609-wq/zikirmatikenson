# Yerel geliştirme / telefon test build'i (.env.local olarak kopyala; commit'leme)
# cp .env.local.example .env.local

# Premium limitleri + özellik merkezi (yalnızca test; cap:release:android açıkken build'i durdurur)
VITE_PREMIUM_PREVIEW=1

# Telefonda konsol yokken varsayılan önizleme modu (localStorage boşsa):
# VITE_PREMIUM_PREVIEW_MODE=active

# Önizleme ekranı (tarayıcı/telefon konsolu — sayfayı yeniler):
#   setPremiumPreview('teaser')  → tanıtım kartları (lansman öncesi)
#   setPremiumPreview('locked')    → hub + Premium'a geç → satın alma ekranı
#   setPremiumPreview('active')    → aktif abonelik hub'u
# İlk açılış varsayılan: teaser (localStorage boşsa)

# RevenueCat public API anahtarları (Project → API keys)
VITE_REVENUECAT_API_KEY_ANDROID=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# VITE_REVENUECAT_API_KEY_IOS=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
