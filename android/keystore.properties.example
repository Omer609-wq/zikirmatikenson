# Play Store release imzası — bu dosyayı kopyala:
#   cp keystore.properties.example keystore.properties
# Değerleri doldur; keystore.properties ve .jks repoya EKLENMEZ.
#
# Keystore oluşturma (bir kez):
#   keytool -genkey -v -keystore zikirmatik-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile yolu android/app/ modülüne göredir (../ = android/ klasörü).

storeFile=../zikirmatik-release.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
