# Play Store imzası — Gradle / npm run cap:bundle:android bunu okur.
# Android Studio "Remember passwords" SADECE Studio içindir; terminal bunu görmez.
#
# Kurulum (bir kez):
#   1) Bu dosyayı keystore.properties olarak kopyala (aynı klasörde)
#   2) Şifreleri Android Studio → Generate Signed Bundle ekranındaki
#      (Remember açık) alanlardan bir kez buraya yaz
#
# Keystore: C:\keystore\zikirmatik-release.jks  |  alias: zikirmatik

storeFile=C:/keystore/zikirmatik-release.jks
storePassword=CHANGE_ME
keyAlias=zikirmatik
keyPassword=CHANGE_ME
