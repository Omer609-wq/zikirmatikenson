{
    "appId": "com.omerzikirmatik.app",
    "appName": "Zikirmatik Dhikr Quran",
    "webDir": "www",
    "server": {
        "androidScheme": "https"
    },
    "plugins": {
        "FirebaseAuthentication": {
            "skipNativeAuth": true,
            "providers": ["google.com"]
        }
    },
    "ios": {
        "includePlugins": [
            "@capacitor-community/keep-awake",
            "@capacitor/app",
            "@capacitor/haptics",
            "@capacitor/local-notifications",
            "@capacitor/status-bar",
            "@revenuecat/purchases-capacitor"
        ]
    }
}
